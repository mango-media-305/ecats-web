---
interface Props {
    eyebrow?: string;
    title: string;
    description?: string;
    align?: "left" | "center";
    maxWidth?: "sm" | "md" | "lg" | "xl";
    highlight?: string;
}

const {
    eyebrow,
    title,
    description,
    align = "left",
    maxWidth = "lg",
    highlight,
} = Astro.props;

const alignmentClasses = {
    left: "items-start text-left",
    center: "mx-auto items-center text-center",
};

const maxWidthClasses = {
    sm: "max-w-2xl",
    md: "max-w-3xl",
    lg: "max-w-4xl",
    xl: "max-w-5xl",
};

const titleParts =
    highlight && title.includes(highlight) ? title.split(highlight) : null;
---

<div
    class={`relative flex flex-col ${alignmentClasses[align]} ${maxWidthClasses[maxWidth]}`}
>
    {
        eyebrow && (
        <div class="section-kicker">
            <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[rgb(var(--color-secondary))] opacity-60" />
            <span class="relative inline-flex h-2 w-2 rounded-full bg-[rgb(var(--color-secondary))]" />
            </span>
            {eyebrow}
        </div>
        )
    }

    <h2
        class="mt-5 text-balance text-3xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))] sm:text-4xl lg:text-5xl"
    >
        {
        titleParts ? (
            <>
            {titleParts[0]}
            <span class="gradient-text">{highlight}</span>
            {titleParts[1]}
            </>
        ) : (
            title
        )
        }
    </h2>

    {description && <p class="lead-text mt-5">{description}</p>}

    <slot />
</div>
