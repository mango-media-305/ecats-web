---
import type { HTMLAttributes } from "astro/types";
import { ArrowRight } from "@lucide/astro";

interface Props extends HTMLAttributes<"a"> {
    href: string;
    variant?: "primary" | "secondary" | "ghost" | "light" | "dark";
    size?: "sm" | "md" | "lg";
    icon?: any;
    iconPosition?: "left" | "right";
    external?: boolean;
    fullWidth?: boolean;
    magnetic?: boolean;
}

const {
    href,
    variant = "primary",
    size = "md",
    icon: Icon = ArrowRight,
    iconPosition = "right",
    external = false,
    fullWidth = false,
    magnetic = true,
    class: className = "",
    ...attrs
} = Astro.props;

const baseClasses =
    "group relative inline-flex items-center justify-center overflow-hidden rounded-full font-inter font-extrabold leading-none transition duration-300 focus-visible:outline focus-visible:outline-4 focus-visible:outline-offset-4 focus-visible:outline-[rgb(var(--color-secondary)/0.35)]";

const sizeClasses = {
    sm: "min-h-10 gap-2 px-4 py-2 text-sm",
    md: "min-h-12 gap-2.5 px-5 py-3 text-[0.95rem]",
    lg: "min-h-14 gap-3 px-7 py-4 text-base",
};

const variantClasses = {
    primary:
    "border border-[rgb(var(--color-secondary)/0.42)] bg-[linear-gradient(135deg,rgb(var(--color-primary))_0%,rgb(var(--color-secondary))_100%)] !text-white shadow-blue hover:shadow-[0_26px_90px_rgb(var(--color-secondary)/0.34)]",
    secondary:
        "border border-[rgb(var(--color-border)/0.78)] bg-[rgb(var(--color-surface)/0.8)] text-[rgb(var(--color-heading))] shadow-soft hover:border-[rgb(var(--color-secondary)/0.48)] hover:bg-[rgb(var(--color-secondary)/0.08)]",
    ghost:
        "border border-transparent bg-transparent text-[rgb(var(--color-heading))] hover:border-[rgb(var(--color-border)/0.78)] hover:bg-[rgb(var(--color-surface-soft)/0.74)]",
    light:
        "border border-white/25 bg-white text-[#0B2150] shadow-[0_22px_70px_rgb(255_255_255/0.2)] hover:bg-white/92",
    dark:
        "border border-[#0B2150]/20 bg-[#0B2150] text-white shadow-[0_22px_70px_rgb(11_33_80/0.28)] hover:bg-[#102d6b]",
};

const widthClasses = fullWidth ? "w-full" : "w-fit";
const motionClasses = magnetic ? "hover:-translate-y-1 active:translate-y-0" : "";
const iconSize = size === "lg" ? "h-5 w-5" : "h-4 w-4";
---

<a
    href={href}
    target={external ? "_blank" : undefined}
    rel={external ? "noreferrer" : undefined}
    class:list={[
        baseClasses,
        sizeClasses[size],
        variantClasses[variant],
        widthClasses,
        motionClasses,
        className,
    ]}
    {...attrs}
>
    {
        variant === "primary" && (
        <>
            <span class="pointer-events-none absolute inset-0 opacity-0 transition duration-300 group-hover:opacity-100">
            <span class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,rgba(255,255,255,0.34),transparent_34%)]" />
            </span>

            <span class="pointer-events-none absolute -left-16 top-0 h-full w-12 rotate-12 bg-white/30 blur-md transition duration-700 group-hover:left-[120%]" />
        </>
        )
    }

    {
        Icon && iconPosition === "left" && (
        <Icon class={`${iconSize} relative z-10 shrink-0 transition duration-300 group-hover:scale-110`} />
        )
    }

    <span class="relative z-10">
        <slot />
    </span>

    {
        Icon && iconPosition === "right" && (
        <Icon
            class={`${iconSize} relative z-10 shrink-0 transition duration-300 group-hover:translate-x-0.5 group-hover:scale-110`}
        />
        )
    }
</a>