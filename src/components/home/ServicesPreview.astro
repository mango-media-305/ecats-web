---
import { ArrowUpRight, CheckCircle2 } from "@lucide/astro";

import SectionHeading from "../ui/SectionHeading.astro";
import CTAButton from "../ui/CTAButton.astro";
import Badge from "../ui/Badge.astro";
import { homeServicesSection } from "../../data/home";
---

<section class="section-shell relative overflow-hidden">
    <!-- Background accents -->
    <div class="pointer-events-none absolute inset-0 -z-10">
        <div
            class="absolute left-[-12rem] top-16 h-96 w-96 rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-3xl"
        >
        </div>

        <div
            class="absolute right-[-10rem] bottom-10 h-96 w-96 rounded-full bg-[rgb(var(--color-primary)/0.08)] blur-3xl"
        >
        </div>
    </div>

    <div class="container-wide">
        <!-- Heading + floating visual -->
        <div class="grid gap-10 lg:grid-cols-[0.95fr_0.75fr] lg:items-center">
            <SectionHeading
                eyebrow={homeServicesSection.eyebrow}
                title={homeServicesSection.title}
                highlight="built around clarity."
                description={homeServicesSection.description}
            />

            <!-- Floating decorative image: tablet + desktop only -->
            <div class="relative hidden min-h-[18rem] md:block lg:min-h-[22rem]">
                <div
                    class="pointer-events-none absolute inset-0 rounded-full bg-[radial-gradient(circle,rgb(var(--color-secondary)/0.18),transparent_62%)] blur-3xl"
                >
                </div>

                <div
                    class="pointer-events-none absolute left-1/2 top-1/2 h-56 w-56 -translate-x-1/2 -translate-y-1/2 rounded-full border border-[rgb(var(--color-secondary)/0.18)]"
                >
                </div>

                <div
                    class="pointer-events-none absolute right-10 top-8 h-24 w-24 rounded-full bg-[rgb(var(--color-secondary)/0.12)] blur-2xl"
                >
                </div>

                <img
                    src="/images/home/services-floating-documents.webp"
                    alt=""
                    width="900"
                    height="700"
                    loading="lazy"
                    decoding="async"
                    class="services-floating-image relative z-10 mx-auto w-full max-w-[30rem] object-contain drop-shadow-[0_34px_80px_rgb(5_162_236/0.22)]"
                />
            </div>

            <div class="flex justify-start lg:col-span-2 lg:justify-end">
                <CTAButton href={homeServicesSection.cta.href} variant="secondary">
                    {homeServicesSection.cta.label}
                </CTAButton>
            </div>
        </div>

        <!-- Services cards -->
        <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
            {
                homeServicesSection.services.map((service, index) => {
                    const Icon = service.icon;

                    return (
                        <article
                            class:list={[
                                "group glow-card card-hover relative min-h-[25rem] p-6",
                                index === 0 ? "xl:-translate-y-4" : "",
                                index === 1 ? "xl:translate-y-4" : "",
                                index === 2 ? "xl:-translate-y-2" : "",
                                index === 3 ? "xl:translate-y-6" : "",
                            ]}
                        >
                            <!-- Icon watermark -->
                            <div class="pointer-events-none absolute right-5 top-5 font-inter text-6xl font-extrabold tracking-[-0.08em] text-[rgb(var(--color-primary)/0.05)] transition group-hover:text-[rgb(var(--color-secondary)/0.08)] dark:text-white/5">
                                <Icon class="h-17 w-17" />
                            </div>

                            <div class="relative z-10">
                                <div class="flex items-start justify-between gap-4">
                                    <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                        <Icon class="h-7 w-7" />
                                    </span>

                                    <a
                                        href={service.href}
                                        aria-label={`Learn more about ${service.title}`}
                                        class="flex h-10 w-10 items-center justify-center rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.7)] text-[rgb(var(--color-heading))] transition duration-300 group-hover:-translate-y-1 group-hover:translate-x-1 group-hover:border-[rgb(var(--color-secondary)/0.45)] group-hover:bg-[rgb(var(--color-secondary))] group-hover:text-white dark:group-hover:text-[rgb(3_11_29)]"
                                    >
                                        <ArrowUpRight class="h-4.5 w-4.5" />
                                    </a>
                                </div>

                                <Badge variant="soft" size="sm" class="mt-7">
                                    {service.eyebrow}
                                </Badge>

                                <h3 class="mt-4 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                    {service.title}
                                </h3>

                                <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                    {service.summary}
                                </p>

                                <div class="mt-6 grid gap-3">
                                    {
                                        service.features.slice(0, 3).map((feature) => (
                                            <div class="flex items-start gap-3">
                                                <CheckCircle2 class="mt-0.5 h-4.5 w-4.5 shrink-0 text-[rgb(var(--color-secondary))]" />
                                                <span class="text-sm font-bold leading-6 text-[rgb(var(--color-text))]">
                                                    {feature}
                                                </span>
                                            </div>
                                        ))
                                    }
                                </div>

                                <div class="mt-7">
                                    <a
                                        href={service.href}
                                        class="group/link inline-flex items-center gap-2 font-inter text-sm font-extrabold text-[rgb(var(--color-secondary))]"
                                    >
                                        Learn more
                                        <ArrowUpRight class="h-4 w-4 transition group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5" />
                                    </a>
                                </div>
                            </div>
                        </article>
                    );
                })
            }
        </div>

        <!-- Bottom SEO / conversion strip -->
        <div
            class="mt-16 overflow-hidden rounded-[2rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-5 shadow-soft backdrop-blur"
        >
            <div class="grid gap-5 lg:grid-cols-[1fr_auto] lg:items-center">
                <div>
                    <p class="font-inter text-lg font-extrabold tracking-[-0.04em] text-[rgb(var(--color-heading))]">
                        Need help choosing the right service?
                    </p>

                    <p class="mt-1 max-w-3xl text-sm leading-6 text-[rgb(var(--color-text-soft))]">
                        Start with the contact form and tell us whether you need help with
                        taxes, bookkeeping, payroll, business accounting, or IRS-related
                        questions. Our Miami office can guide you toward the right next step.
                    </p>
                </div>

                <CTAButton href="/contact">
                    Contact Our Office
                </CTAButton>
            </div>
        </div>
    </div>
</section>

<style>
    @keyframes services-float {
        0%,
        100% {
            transform: translateY(0) rotate(-1deg) scale(1);
        }

        50% {
            transform: translateY(-14px) rotate(1deg) scale(1.02);
        }
    }

    .services-floating-image {
        animation: services-float 7s ease-in-out infinite;
    }

    @media (prefers-reduced-motion: reduce) {
        .services-floating-image {
            animation: none;
        }
    }
</style>