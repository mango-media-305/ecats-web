---
import {
    ArrowUpRight,
    CheckCircle2,
    Mail,
    MessageSquareText,
    Sparkles,
} from "@lucide/astro";

import CTAButton from "../ui/CTAButton.astro";
import Badge from "../ui/Badge.astro";
import { homeFinalCta } from "../../data/home";
import { siteConfig } from "../../data/site";
---

<section class="section-shell relative isolate overflow-hidden">
    <!-- Background effects -->
    <div class="pointer-events-none absolute inset-0 -z-10">
        <div
        class="absolute left-1/2 top-1/2 h-[44rem] w-[44rem] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[radial-gradient(circle,rgb(var(--color-secondary)/0.16),transparent_68%)] blur-2xl"
        >
        </div>

        <div
        class="absolute left-[-12rem] bottom-[-10rem] h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.12)] blur-3xl"
        >
        </div>

        <div
        class="absolute right-[-12rem] top-[-10rem] h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-secondary)/0.12)] blur-3xl"
        >
        </div>
    </div>

    <div class="container-wide">
        <div
        class="relative overflow-hidden rounded-[2.5rem] border border-[rgb(var(--color-border)/0.72)] bg-[linear-gradient(135deg,rgb(var(--color-primary))_0%,rgb(var(--color-secondary))_100%)] p-6 text-white shadow-blue sm:p-8 lg:p-10"
        >
        <!-- Internal background -->
        <div
            class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_0%,rgba(255,255,255,0.3),transparent_34%),radial-gradient(circle_at_92%_100%,rgba(255,255,255,0.16),transparent_34%)]"
        >
        </div>

        <div
            class="pointer-events-none absolute inset-0 opacity-35"
            style="background-image: linear-gradient(rgba(255,255,255,0.12) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.12) 1px, transparent 1px); background-size: 42px 42px;"
        >
        </div>

        <div class="relative grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
            <!-- Content -->
            <div>
            <Badge
                variant="outline"
                class="border-white/25 bg-white/10 text-white"
                icon={Sparkles}
                glow
            >
                {homeFinalCta.eyebrow}
            </Badge>

            <h2
                class="mt-6 max-w-4xl text-balance font-inter text-4xl font-extrabold tracking-[-0.065em] text-white sm:text-5xl lg:text-6xl"
            >
                {homeFinalCta.title}
            </h2>

            <p class="mt-6 max-w-2xl text-base leading-8 text-white/78 sm:text-lg">
                {homeFinalCta.description}
            </p>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                <CTAButton
                href={homeFinalCta.primaryCta.href}
                variant="light"
                size="lg"
                icon={homeFinalCta.primaryCta.icon}
                >
                {homeFinalCta.primaryCta.label}
                </CTAButton>

                <CTAButton
                href={homeFinalCta.secondaryCta.href}
                variant="ghost"
                size="lg"
                icon={homeFinalCta.secondaryCta.icon}
                iconPosition="left"
                class="border-white/20 bg-white/10 text-white hover:border-white/35 hover:bg-white/16"
                >
                {homeFinalCta.secondaryCta.label}
                </CTAButton>
            </div>

            <div class="mt-8 flex flex-wrap gap-3">
                {
                homeFinalCta.supportingPoints.map((point) => {
                    const Icon = point.icon;

                    return (
                    <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/10 px-4 py-2 backdrop-blur">
                        <span class="flex h-7 w-7 items-center justify-center rounded-full bg-white/12 text-white">
                        <Icon class="h-3.5 w-3.5" />
                        </span>
                        <span class="font-inter text-sm font-bold text-white/86">
                        {point.label}
                        </span>
                    </div>
                    );
                })
                }
            </div>
            </div>

            <!-- Contact preview panel -->
            <div class="relative">
            <div class="rounded-[2rem] border border-white/18 bg-white/12 p-4 shadow-[0_28px_90px_rgba(0,0,0,0.18)] backdrop-blur-xl sm:p-5">
                <div class="rounded-[1.6rem] border border-white/14 bg-white/12 p-5">
                <div class="flex items-start justify-between gap-4">
                    <div>
                    <p class="font-inter text-xs font-extrabold uppercase tracking-[0.14em] text-white/70">
                        Contact Preview
                    </p>
                    <h3 class="mt-2 font-inter text-2xl font-extrabold tracking-[-0.055em] text-white">
                        Start with a simple message.
                    </h3>
                    </div>

                    <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-white/12 text-white">
                    <MessageSquareText class="h-6 w-6" />
                    </span>
                </div>

                <div class="mt-6 grid gap-3">
                    <div class="rounded-2xl border border-white/12 bg-white/10 p-4">
                    <p class="font-inter text-xs font-bold uppercase tracking-[0.12em] text-white/60">
                        Service Needed
                    </p>
                    <p class="mt-1 font-inter text-sm font-extrabold text-white">
                        Taxes · Bookkeeping · Payroll
                    </p>
                    </div>

                    <div class="rounded-2xl border border-white/12 bg-white/10 p-4">
                    <p class="font-inter text-xs font-bold uppercase tracking-[0.12em] text-white/60">
                        Client Type
                    </p>
                    <p class="mt-1 font-inter text-sm font-extrabold text-white">
                        Individual or Business
                    </p>
                    </div>

                    <div class="rounded-2xl border border-white/12 bg-white/10 p-4">
                    <p class="font-inter text-xs font-bold uppercase tracking-[0.12em] text-white/60">
                        Next Step
                    </p>
                    <p class="mt-1 font-inter text-sm font-extrabold text-white">
                        Office review and follow-up
                    </p>
                    </div>
                </div>

                <div class="mt-6 grid gap-3">
                    {
                    [
                        "Contact form as the main CTA",
                        "Phone and email as secondary options",
                        "Bilingual support available",
                    ].map((item) => (
                        <div class="flex items-center gap-3">
                        <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-white/12 text-white">
                            <CheckCircle2 class="h-3.5 w-3.5" />
                        </span>

                        <span class="text-sm font-bold leading-6 text-white/80">
                            {item}
                        </span>
                        </div>
                    ))
                    }
                </div>

                <a
                    href={`mailto:${siteConfig.contact.email}`}
                    class="group mt-6 flex items-center justify-between gap-4 rounded-[1.35rem] border border-white/14 bg-white/10 p-4 transition hover:-translate-y-1 hover:bg-white/16"
                >
                    <div class="flex items-center gap-3">
                    <span class="flex h-10 w-10 items-center justify-center rounded-full bg-white text-[#0B2150]">
                        <Mail class="h-5 w-5" />
                    </span>

                    <div>
                        <p class="font-inter text-sm font-extrabold text-white">
                        Prefer email?
                        </p>
                        <p class="text-xs text-white/68">
                        {siteConfig.contact.email}
                        </p>
                    </div>
                    </div>

                    <ArrowUpRight class="h-5 w-5 text-white transition group-hover:-translate-y-0.5 group-hover:translate-x-0.5" />
                </a>
                </div>
            </div>

            <!-- Floating mini badge -->
            <div class="absolute -right-3 -top-4 hidden rounded-full border border-white/18 bg-white/14 px-4 py-3 shadow-[0_18px_50px_rgba(0,0,0,0.16)] backdrop-blur-xl xl:flex">
                <span class="mr-2 flex h-7 w-7 items-center justify-center rounded-full bg-white/14 text-white">
                <Sparkles class="h-3.5 w-3.5" />
                </span>
                <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-white">
                Ready to convert
                </span>
            </div>
            </div>
        </div>
        </div>
    </div>
</section>