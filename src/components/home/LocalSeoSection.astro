---
import {
    ArrowUpRight,
    Building2,
    Clock3,
    Mail,
    MapPin,
    Phone,
    Sparkles,
} from "@lucide/astro";

import SectionHeading from "../ui/SectionHeading.astro";
import CTAButton from "../ui/CTAButton.astro";
import Badge from "../ui/Badge.astro";
import { homeLocalSeoSection } from "../../data/home";
---

<section class="section-shell accounting-grid relative isolate overflow-hidden">
    <!-- Ambient background -->
    <div class="pointer-events-none absolute inset-0 -z-10">
        <div
        class="absolute left-[-12rem] top-20 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.12)] blur-3xl"
        >
        </div>

        <div
        class="absolute bottom-[-12rem] right-[-10rem] h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.13)] blur-3xl"
        >
        </div>

        <div
        class="absolute inset-x-0 bottom-0 h-48 bg-[linear-gradient(to_top,rgb(var(--color-bg)),transparent)]"
        >
        </div>
    </div>

    <div class="container-wide">
        <div class="grid gap-12 lg:items-start">

        <!-- Right map/service area experience -->
        <div class="relative">
            <div
            class="glass-panel relative overflow-hidden rounded-[2.25rem] p-4 sm:p-6"
            >
            <div
                class="pointer-events-none absolute inset-x-10 top-0 h-px bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.8),transparent)]"
            >
            </div>

            <!-- Office Card -->
            <div
                class="relative overflow-hidden rounded-[1.85rem] bg-[linear-gradient(135deg,rgb(var(--color-primary))_0%,rgb(var(--color-secondary))_100%)] p-6 text-white shadow-blue"
            >
                <div
                class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_0%,rgba(255,255,255,0.3),transparent_34%),radial-gradient(circle_at_92%_100%,rgba(255,255,255,0.16),transparent_34%)]"
                >
                </div>

                <div
                class="relative grid gap-6 md:grid-cols-[1fr_auto] md:items-start"
                >
                <div>
                    <Badge
                    variant="outline"
                    class="border-white/25 bg-white/10 text-white"
                    icon={Sparkles}
                    >
                    Miami Office
                    </Badge>

                    <h3
                    class="mt-5 font-inter text-3xl font-extrabold tracking-[-0.06em] !text-white"
                    >
                    {homeLocalSeoSection.officeCard.title}
                    </h3>

                    <div class="mt-5 flex flex-col gap-3">
                        <a
                            href={homeLocalSeoSection.officeCard.mapHref}
                            target="_blank"
                            rel="noreferrer"
                            class="group flex items-start gap-3 text-sm font-bold leading-6 text-white/82 transition hover:text-white"
                        >
                            <MapPin class="mt-0.5 h-4.5 w-4.5 shrink-0" />
                            <span>
                                {homeLocalSeoSection.officeCard.address}
                            </span>
                        </a>

                        <div
                            class="flex items-center gap-3 text-sm font-bold text-white/82"
                        >
                            <Clock3 class="h-4.5 w-4.5 shrink-0" />
                            {homeLocalSeoSection.officeCard.hours}
                        </div>

                        <a
                            href={`tel:${homeLocalSeoSection.officeCard.phone.replace(/[^0-9+]/g, "")}`}
                            class="flex items-center gap-3 text-sm font-bold text-white/82 transition hover:text-white"
                        >
                            <Phone class="h-4.5 w-4.5 shrink-0" />
                            {homeLocalSeoSection.officeCard.phone}
                        </a>

                        <a
                            href={`mailto:${homeLocalSeoSection.officeCard.email}`}
                            class="flex items-center gap-3 text-sm font-bold text-white/82 transition hover:text-white"
                        >
                            <Mail class="h-4.5 w-4.5 shrink-0" />
                            {homeLocalSeoSection.officeCard.email}
                        </a>
                    </div>
                </div>

                <a
                    href={homeLocalSeoSection.officeCard.mapHref}
                    target="_blank"
                    rel="noreferrer"
                    class="group hidden h-28 w-28 shrink-0 items-center justify-center rounded-[2rem] border border-white/20 bg-white/12 text-white backdrop-blur transition duration-300 hover:-translate-y-1 hover:bg-white/18 md:flex"
                    aria-label="Open office location in Google Maps"
                >
                    <MapPin class="h-10 w-10 transition group-hover:scale-110" />
                </a>
                </div>
            </div>

            <!-- Service area cards -->
            <div class="mt-5 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
                {
                homeLocalSeoSection.serviceAreas.map((area) => {
                    const Icon = area.icon;

                    return (
                    <a
                        href={area.href}
                        class="group relative min-h-[15rem] overflow-hidden rounded-[1.5rem] border border-[rgb(var(--color-border)/0.68)] bg-[rgb(var(--color-surface)/0.68)] p-5 shadow-soft backdrop-blur transition duration-300 hover:-translate-y-1 hover:border-[rgb(var(--color-secondary)/0.42)]"
                    >
                        <!-- Location image background -->
                        <img
                            src={area.image}
                            alt=""
                            width="1200"
                            height="800"
                            loading="lazy"
                            decoding="async"
                            class="absolute inset-0 h-full w-full object-cover opacity-35 blur-md scale-110 transition duration-500 group-hover:opacity-55 group-hover:blur-none group-hover:scale-105"
                        />

                        <!-- Readability overlays -->
                        <div class="absolute inset-0 bg-[linear-gradient(180deg,rgb(var(--color-surface)/0.82)_0%,rgb(var(--color-surface)/0.72)_42%,rgb(var(--color-bg)/0.88)_100%)] transition duration-500 group-hover:bg-[linear-gradient(180deg,rgb(var(--color-surface)/0.72)_0%,rgb(var(--color-surface)/0.58)_42%,rgb(var(--color-bg)/0.84)_100%)]"></div>

                        <div class="absolute inset-0 bg-[radial-gradient(circle_at_85%_0%,rgb(var(--color-secondary)/0.22),transparent_45%)] opacity-70"></div>

                        <div class="pointer-events-none absolute right-[-2rem] top-[-2rem] h-24 w-24 rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-2xl opacity-0 transition group-hover:opacity-100"></div>

                        <div class="relative z-10 flex h-full flex-col justify-between">
                            <div class="flex items-start justify-between gap-4">
                                <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.14)] text-[rgb(var(--color-secondary))] shadow-soft backdrop-blur transition group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.22)]">
                                    <Icon class="h-5 w-5" />
                                </span>

                                <span class="flex h-10 w-10 items-center justify-center rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] text-[rgb(var(--color-heading))] shadow-soft backdrop-blur transition group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:border-[rgb(var(--color-secondary)/0.42)] group-hover:bg-[rgb(var(--color-secondary))] group-hover:text-white">
                                    <ArrowUpRight class="h-4.5 w-4.5" />
                                </span>
                            </div>

                            <div class="mt-8">
                                <h3 class="font-inter text-xl font-extrabold tracking-[-0.045em] text-[rgb(var(--color-heading))]">
                                    {area.city}, {area.state}
                                </h3>

                                <p class="mt-2 line-clamp-3 text-sm font-semibold leading-6 text-[rgb(var(--color-text-soft))]">
                                    {area.seoDescription}
                                </p>
                            </div>
                        </div>
                    </a>
                    );
                })
                }
            </div>

            <!-- CTA strip -->
            <div
                class="mt-5 grid gap-5 rounded-[1.75rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-5 shadow-soft backdrop-blur lg:grid-cols-[1fr_auto] lg:items-center"
            >
                <div>
                <p
                    class="font-inter text-xl font-extrabold tracking-[-0.045em] text-[rgb(var(--color-heading))]"
                >
                    Looking for tax or accounting help near Miami?
                </p>
                <p
                    class="mt-1 text-sm leading-6 text-[rgb(var(--color-text-soft))]"
                >
                    Start with the contact form and our office will help guide you
                    toward the right service.
                </p>
                </div>

                <CTAButton href="/contact"> Contact Our Office </CTAButton>
            </div>
            </div>
        </div>
        </div>
    </div>
</section>

<style>
    .location-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgb(var(--color-border) / 0.72);
        border-radius: 999px;
        background: rgb(var(--color-surface) / 0.88);
        color: rgb(var(--color-heading));
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        padding: 0.65rem 0.9rem;
        font-family: var(--font-inter);
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: -0.01em;
        white-space: nowrap;
        transition:
        transform 200ms ease,
        border-color 200ms ease,
        background 200ms ease,
        color 200ms ease;
    }

    .location-pill:hover {
        transform: translateY(-3px);
        border-color: rgb(var(--color-secondary) / 0.48);
        background: rgb(var(--color-secondary));
        color: white;
    }

    :root[data-theme="dark"] .location-pill:hover {
        color: rgb(3 11 29);
    }
</style>
