---
import {
    ArrowUpRight,
    CheckCircle2,
    FileSpreadsheet,
    LineChart,
    PieChart,
    Sparkles,
} from "@lucide/astro";

import SectionHeading from "../ui/SectionHeading.astro";
import CTAButton from "../ui/CTAButton.astro";
import Badge from "../ui/Badge.astro";
import { homeFinancialClarity } from "../../data/home";
---

<section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
    <!-- Background system -->
    <div class="pointer-events-none absolute inset-0 -z-10">
        <div
        class="absolute left-1/2 top-0 h-px w-[min(92%,1180px)] -translate-x-1/2 bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.55),transparent)]"
        >
        </div>

        <div
        class="absolute left-[-12rem] bottom-[-10rem] h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.11)] blur-3xl"
        >
        </div>

        <div
        class="absolute right-[-10rem] top-16 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.11)] blur-3xl"
        >
        </div>

        <div
        class="absolute inset-0 bg-[linear-gradient(135deg,transparent_0%,rgb(var(--color-secondary)/0.045)_46%,transparent_76%)]"
        >
        </div>
    </div>

    <div class="container-wide">
        <div class="grid gap-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <!-- Left content/cards -->
        <div>
            <SectionHeading
            eyebrow={homeFinancialClarity.eyebrow}
            title={homeFinancialClarity.title}
            highlight="easier to understand"
            description={homeFinancialClarity.description}
            />

            <div class="mt-9 grid gap-5 sm:grid-cols-3">
            {
                homeFinancialClarity.cards.map((card) => {
                const Icon = card.icon;

                return (
                    <article class="group glow-card card-hover p-5">
                    <div class="relative z-10">
                        <span class="flex h-12 w-12 items-center justify-center rounded-[1.1rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                        <Icon class="h-6 w-6" />
                        </span>

                        <h3 class="mt-5 font-inter text-xl font-extrabold tracking-[-0.045em] text-[rgb(var(--color-heading))]">
                        {card.title}
                        </h3>

                        <p class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                        {card.description}
                        </p>
                    </div>
                    </article>
                );
                })
            }
            </div>

            <div
            class="mt-8 overflow-hidden rounded-[2rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-5 shadow-soft backdrop-blur"
            >
            <div class="grid gap-5 md:grid-cols-[1fr_auto] md:items-center">
                <div>
                <Badge variant="blue" icon={Sparkles}>
                    Better Financial Visibility
                </Badge>

                <h3 class="mt-4 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                    Clean records make every next step easier.
                </h3>

                <p class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                    The right accounting support can help clients prepare for tax season,
                    understand business activity, and reduce last-minute stress around
                    documents, payroll, and bookkeeping.
                </p>
                </div>

                <CTAButton href="/contact" variant="secondary">
                Get Organized
                </CTAButton>
            </div>
            </div>
        </div>

        <!-- Right visual dashboard -->
        <div class="relative">
            <div
            class="glass-panel relative overflow-hidden rounded-[2.25rem] p-4 sm:p-6"
            >
            <div
                class="pointer-events-none absolute inset-x-10 top-0 h-px bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.8),transparent)]"
            >
            </div>

            <!-- Main financial panel -->
            <div
                class="relative overflow-hidden rounded-[1.85rem] bg-[linear-gradient(135deg,rgb(var(--color-primary))_0%,rgb(var(--color-secondary))_100%)] p-6 text-white shadow-blue"
            >
                <div
                class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_0%,rgba(255,255,255,0.28),transparent_34%),radial-gradient(circle_at_90%_100%,rgba(255,255,255,0.16),transparent_30%)]"
                >
                </div>

                <div class="relative">
                <div class="flex items-start justify-between gap-5">
                    <div>
                    <p class="font-inter text-xs font-extrabold uppercase tracking-[0.14em] !text-white/70">
                        Financial Snapshot
                    </p>

                    <h3 class="mt-2 max-w-md font-inter text-3xl font-extrabold tracking-[-0.06em] !text-white sm:text-4xl">
                        From scattered records to clear reporting.
                    </h3>
                    </div>

                    <span class="hidden h-14 w-14 shrink-0 items-center justify-center rounded-2xl border border-white/15 bg-white/12 text-white backdrop-blur sm:flex">
                    <LineChart class="h-7 w-7" />
                    </span>
                </div>

                    <!-- Animated fun facts -->
                    <div class="mt-8 grid gap-3 sm:grid-cols-3" data-counter-section>
                        {
                            [
                                {
                                    label: "Tax documents managed",
                                    value: 750,
                                    suffix: "+",
                                    detail: "organized this year",
                                },
                                {
                                    label: "Bookkeeping records",
                                    value: 52,
                                    suffix: "",
                                    detail: "reviewed and organized",
                                },
                                {
                                    label: "Payroll organizations",
                                    value: 45,
                                    suffix: "",
                                    detail: "supported",
                                },
                            ].map((item) => (
                                <div class="rounded-[1.35rem] border border-white/14 bg-white/10 p-4 backdrop-blur transition duration-300 hover:-translate-y-1 hover:bg-white/14">
                                    <p
                                        class="font-inter text-4xl font-extrabold tracking-[-0.06em] !text-white sm:text-5xl"
                                        data-counter
                                        data-target={item.value}
                                        data-suffix={item.suffix}
                                    >
                                        0{item.suffix}
                                    </p>

                                    <p class="mt-2 font-inter text-[0.68rem] font-extrabold uppercase tracking-[0.13em] !text-white/72">
                                        {item.label}
                                    </p>

                                    <p class="mt-2 text-xs leading-5 !text-white/70">
                                        {item.detail}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>

            <!-- Lower dashboard grid -->
            <div class="mt-5 grid gap-5">
                <!-- Checklist panel -->
                <div class="rounded-[1.75rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-5 shadow-soft backdrop-blur">
                <div class="flex items-center justify-between">
                    <div>
                    <p class="font-inter text-xs font-extrabold uppercase tracking-[0.14em] text-[rgb(var(--color-secondary))]">
                        Clarity checklist
                    </p>

                    <h4 class="mt-1 font-inter text-xl font-extrabold tracking-[-0.05em] text-[rgb(var(--color-heading))]">
                        What better organization helps with
                    </h4>
                    </div>

                    <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                    <FileSpreadsheet class="h-5 w-5" />
                    </span>
                </div>

                <div class="mt-5 grid gap-3">
                    {
                    [
                        "Preparing for tax season with less stress",
                        "Reviewing income and expenses more clearly",
                        "Keeping payroll details easier to understand",
                        "Supporting better business decisions",
                    ].map((item) => (
                        <div class="flex items-start gap-3 rounded-2xl border border-[rgb(var(--color-border)/0.55)] bg-[rgb(var(--color-bg)/0.36)] p-3">
                        <CheckCircle2 class="mt-0.5 h-4.5 w-4.5 shrink-0 text-[rgb(var(--color-secondary))]" />
                        <span class="text-sm font-bold leading-6 text-[rgb(var(--color-text))]">
                            {item}
                        </span>
                        </div>
                    ))
                    }
                </div>
                </div>
            </div>

            <!-- Bottom link -->
            <a
                href="/services"
                class="group mt-5 flex items-center justify-between gap-4 rounded-[1.5rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-4 shadow-soft backdrop-blur transition hover:-translate-y-1 hover:border-[rgb(var(--color-secondary)/0.42)] hover:bg-[rgb(var(--color-secondary)/0.07)]"
            >
                <div>
                <p class="font-inter text-sm font-extrabold text-[rgb(var(--color-heading))]">
                    Explore tax, bookkeeping, and payroll services
                </p>
                <p class="mt-1 text-sm text-[rgb(var(--color-text-soft))]">
                    See how each service supports better organization.
                </p>
                </div>

                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[rgb(var(--color-secondary))] text-white transition group-hover:scale-105 dark:text-[rgb(3_11_29)]">
                <ArrowUpRight class="h-5 w-5" />
                </span>
            </a>
            </div>
        </div>
        </div>
    </div>
</section>

<script>
    const counterSections = document.querySelectorAll("[data-counter-section]");

    const formatNumber = (value) => {
        return new Intl.NumberFormat("en-US").format(value);
    };

    const animateCounter = (counter) => {
        const target = Number(counter.getAttribute("data-target") || "0");
        const suffix = counter.getAttribute("data-suffix") || "";
        const duration = 1400;
        const startTime = performance.now();

        const update = (currentTime) => {
            const elapsed = currentTime - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const easedProgress = 1 - Math.pow(1 - progress, 3);
            const currentValue = Math.floor(easedProgress * target);

            counter.textContent = `${formatNumber(currentValue)}${suffix}`;

            if (progress < 1) {
                requestAnimationFrame(update);
            } else {
                counter.textContent = `${formatNumber(target)}${suffix}`;
            }
        };

        requestAnimationFrame(update);
    };

    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (!entry.isIntersecting) return;

                const counters = entry.target.querySelectorAll("[data-counter]");

                counters.forEach((counter) => {
                    if (counter.dataset.animated === "true") return;

                    counter.dataset.animated = "true";
                    animateCounter(counter);
                });

                observer.unobserve(entry.target);
            });
        },
        {
            threshold: 0.35,
        }
    );

    counterSections.forEach((section) => observer.observe(section));
</script>