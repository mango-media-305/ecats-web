---
import {
    ArrowUpRight,
    CheckCircle2,
    CircleDollarSign,
    FileCheck2,
    Sparkles,
} from "@lucide/astro";

import SectionHeading from "../ui/SectionHeading.astro";
import CTAButton from "../ui/CTAButton.astro";
import Badge from "../ui/Badge.astro";
import { homeWhyChooseUs } from "../../data/home";
---

<section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.52)]">
    <!-- Decorative background -->
    <div class="pointer-events-none absolute inset-0 -z-10">
        <div
        class="absolute left-1/2 top-0 h-px w-[min(92%,1180px)] -translate-x-1/2 bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.55),transparent)]"
        >
        </div>

        <div
        class="absolute right-[-12rem] top-20 h-96 w-96 rounded-full bg-[rgb(var(--color-secondary)/0.11)] blur-3xl"
        >
        </div>

        <div
        class="absolute bottom-[-12rem] left-[-10rem] h-96 w-96 rounded-full bg-[rgb(var(--color-primary)/0.1)] blur-3xl"
        >
        </div>

        <div
        class="absolute inset-0 bg-[linear-gradient(115deg,transparent_0%,rgb(var(--color-secondary)/0.045)_45%,transparent_78%)]"
        >
        </div>
    </div>

    <div class="container-wide">
        <div class="grid gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
        <!-- Left visual card -->
        <div class="relative order-2 lg:order-1">
            <div
            class="glass-panel relative overflow-hidden rounded-[2.25rem] p-5 sm:p-6"
            >
            <div
                class="pointer-events-none absolute inset-x-10 top-0 h-px bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.8),transparent)]"
            >
            </div>

            <div class="relative overflow-hidden rounded-[1.75rem] bg-[linear-gradient(135deg,rgb(var(--color-primary))_0%,rgb(var(--color-secondary))_100%)] p-6 text-white shadow-blue">
                <div
                class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_0%,rgba(255,255,255,0.28),transparent_32%),radial-gradient(circle_at_100%_100%,rgba(255,255,255,0.18),transparent_34%)]"
                >
                </div>

                <div class="relative">
                <Badge variant="outline" class="border-white/25 bg-white/10 text-white">
                    <Sparkles class="h-3.5 w-3.5" />
                    Modern Office Experience
                </Badge>

                <h3 class="mt-5 max-w-md font-inter text-3xl font-extrabold tracking-[-0.06em] text-white sm:text-4xl">
                    More than filing. A clearer way to organize your financial life.
                </h3>

                <p class="mt-4 max-w-md text-sm leading-7 text-white/78">
                    A website experience built around trust, clarity, bilingual access,
                    and the real financial questions Miami clients have.
                </p>
                </div>
            </div>

            <!-- Floating checklist panel -->
            <div class="relative -mt-8 ml-auto max-w-md rounded-[1.75rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.88)] p-5 shadow-card backdrop-blur">
                <p class="font-inter text-xs font-extrabold uppercase tracking-[0.14em] text-[rgb(var(--color-secondary))]">
                Client-first support
                </p>

                <div class="mt-5 grid gap-4">
                {
                    [
                    "Clear next steps before tax season",
                    "Organized records for personal and business needs",
                    "Bilingual communication in English and Spanish",
                    "Local support from a Miami-based office",
                    ].map((item) => (
                    <div class="flex items-start gap-3">
                        <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                        <CheckCircle2 class="h-3.5 w-3.5" />
                        </span>
                        <p class="text-sm font-bold leading-6 text-[rgb(var(--color-heading))]">
                        {item}
                        </p>
                    </div>
                    ))
                }
                </div>
            </div>

            <!-- Bottom mini metrics -->
            <div class="mt-5 grid gap-4 sm:grid-cols-2">
                <div class="rounded-[1.5rem] border border-[rgb(var(--color-border)/0.66)] bg-[rgb(var(--color-bg)/0.5)] p-5">
                <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                    <FileCheck2 class="h-5 w-5" />
                </span>
                <p class="mt-4 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                    Organized
                </p>
                <p class="mt-1 text-sm leading-6 text-[rgb(var(--color-text-soft))]">
                    Tax documents, bookkeeping, payroll, and business records.
                </p>
                </div>

                <div class="rounded-[1.5rem] border border-[rgb(var(--color-border)/0.66)] bg-[rgb(var(--color-bg)/0.5)] p-5">
                <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                    <CircleDollarSign class="h-5 w-5" />
                </span>
                <p class="mt-4 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                    Practical
                </p>
                <p class="mt-1 text-sm leading-6 text-[rgb(var(--color-text-soft))]">
                    Guidance that helps clients understand what matters next.
                </p>
                </div>
            </div>
            </div>

            <!-- Decorative floating badge -->
            <div class="glass-panel absolute -right-3 top-8 hidden rounded-full px-4 py-3 shadow-card xl:flex">
            <span class="mr-2 flex h-7 w-7 items-center justify-center rounded-full bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                <Sparkles class="h-3.5 w-3.5" />
            </span>
            <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-heading))]">
                Miami · EN/ES
            </span>
            </div>
        </div>

        <!-- Right content -->
        <div class="order-1 lg:order-2">
            <SectionHeading
            eyebrow={homeWhyChooseUs.eyebrow}
            title={homeWhyChooseUs.title}
            highlight="organization, accuracy"
            description={homeWhyChooseUs.description}
            />

            <div class="mt-9 grid gap-4">
            {
                homeWhyChooseUs.items.map((item, index) => {
                const Icon = item.icon;

                return (
                    <article class="group relative overflow-hidden rounded-[1.6rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-5 shadow-soft backdrop-blur transition duration-300 hover:-translate-y-1 hover:border-[rgb(var(--color-secondary)/0.42)] hover:bg-[rgb(var(--color-secondary)/0.065)]">
                    <div class="pointer-events-none absolute right-[-3rem] top-[-3rem] h-28 w-28 rounded-full bg-[rgb(var(--color-secondary)/0.08)] blur-2xl opacity-0 transition group-hover:opacity-100" />

                    <div class="relative flex gap-4">
                        <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-[1.1rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                        <Icon class="h-6 w-6" />
                        </span>

                        <div>
                        <div class="flex items-center gap-3">
                            <span class="font-inter text-xs font-extrabold uppercase tracking-[0.14em] text-[rgb(var(--color-secondary))]">
                            0{index + 1}
                            </span>
                            <span class="h-px w-10 bg-[rgb(var(--color-border))]"></span>
                        </div>

                        <h3 class="mt-2 font-inter text-xl font-extrabold tracking-[-0.045em] text-[rgb(var(--color-heading))]">
                            {item.title}
                        </h3>

                        <p class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                            {item.description}
                        </p>
                        </div>
                    </div>
                    </article>
                );
                })
            }
            </div>

            <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <CTAButton href="/contact">
                Contact Our Office
            </CTAButton>

            <CTAButton href="/about" variant="secondary" icon={ArrowUpRight}>
                Learn About Us
            </CTAButton>
            </div>
        </div>
        </div>
    </div>
</section>