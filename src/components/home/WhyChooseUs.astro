---
import { ArrowUpRight } from "@lucide/astro";

import SectionHeading from "../ui/SectionHeading.astro";
import CTAButton from "../ui/CTAButton.astro";
import { homeWhyChooseUs } from "../../data/home";
---

<section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.52)]">
    <!-- Decorative background -->
    <div class="pointer-events-none absolute inset-0 -z-10">
        <div
            class="absolute left-1/2 top-0 h-px w-[min(92%,1180px)] -translate-x-1/2 bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.55),transparent)]"
        >
        </div>

        <div
            class="absolute right-[-12rem] top-20 h-96 w-96 rounded-full bg-[rgb(var(--color-secondary)/0.11)] blur-3xl"
        >
        </div>

        <div
            class="absolute bottom-[-12rem] left-[-10rem] h-96 w-96 rounded-full bg-[rgb(var(--color-primary)/0.1)] blur-3xl"
        >
        </div>

        <div
            class="absolute inset-0 bg-[linear-gradient(115deg,transparent_0%,rgb(var(--color-secondary)/0.045)_45%,transparent_78%)]"
        >
        </div>
    </div>

    <div class="container-wide">
        <!-- Heading + floating visual -->
        <div class="grid gap-10 lg:grid-cols-[0.95fr_0.75fr] lg:items-center">
            <SectionHeading
                eyebrow={homeWhyChooseUs.eyebrow}
                title={homeWhyChooseUs.title}
                highlight="organization, accuracy,"
                description={homeWhyChooseUs.description}
            />

            <!-- Floating decorative image: tablet + desktop only -->
            <div class="relative hidden min-h-[18rem] md:block lg:min-h-[22rem]">
                <div
                    class="pointer-events-none absolute inset-0 rounded-full bg-[radial-gradient(circle,rgb(var(--color-secondary)/0.16),transparent_62%)] blur-3xl"
                >
                </div>

                <div
                    class="pointer-events-none absolute left-1/2 top-1/2 h-60 w-60 -translate-x-1/2 -translate-y-1/2 rounded-full border border-[rgb(var(--color-secondary)/0.18)]"
                >
                </div>

                <div
                    class="pointer-events-none absolute right-8 top-8 h-24 w-24 rounded-full bg-[rgb(var(--color-secondary)/0.12)] blur-2xl"
                >
                </div>

                <div
                    class="pointer-events-none absolute left-6 bottom-8 h-24 w-24 rounded-full bg-[rgb(var(--color-primary)/0.12)] blur-2xl"
                >
                </div>

                <img
                    src="/images/home/why-choose-floating-support.webp"
                    alt=""
                    width="900"
                    height="700"
                    loading="lazy"
                    decoding="async"
                    class="why-choose-floating-image relative z-10 mx-auto w-full max-w-[30rem] object-contain drop-shadow-[0_34px_80px_rgb(5_162_236/0.22)]"
                />

                <div
                    class="absolute right-8 top-6 z-20 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.78)] px-4 py-2 shadow-soft backdrop-blur"
                >
                    <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-secondary))]">
                        Miami · EN/ES
                    </span>
                </div>

                <div
                    class="absolute bottom-8 left-4 z-20 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.78)] px-4 py-2 shadow-soft backdrop-blur"
                >
                    <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-heading))]">
                        Local · Accurate · Practical
                    </span>
                </div>
            </div>
        </div>

        <!-- Why choose us cards -->
        <div class="mt-12 grid gap-4 sm:grid-cols-2">
            {
                homeWhyChooseUs.items.map((item) => {
                    const Icon = item.icon;

                    return (
                        <article class="group relative overflow-hidden rounded-[1.6rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-5 shadow-soft backdrop-blur transition duration-300 hover:-translate-y-1 hover:border-[rgb(var(--color-secondary)/0.42)] hover:bg-[rgb(var(--color-secondary)/0.065)]">
                            <div class="pointer-events-none absolute right-[-3rem] top-[-3rem] h-28 w-28 rounded-full bg-[rgb(var(--color-secondary)/0.08)] blur-2xl opacity-0 transition group-hover:opacity-100" />

                            <div class="pointer-events-none absolute bottom-4 right-5 text-[rgb(var(--color-primary)/0.045)] transition group-hover:text-[rgb(var(--color-secondary)/0.075)] dark:text-white/5">
                                <Icon class="h-24 w-24" />
                            </div>

                            <div class="relative flex flex-col gap-4">
                                <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-[1.1rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                    <Icon class="h-6 w-6" />
                                </span>

                                <div>
                                    <h3 class="mt-2 font-inter text-xl font-extrabold tracking-[-0.045em] text-[rgb(var(--color-heading))]">
                                        {item.title}
                                    </h3>

                                    <p class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                        {item.description}
                                    </p>
                                </div>
                            </div>
                        </article>
                    );
                })
            }
        </div>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <CTAButton href="/contact">
                Contact Our Office
            </CTAButton>

            <CTAButton href="/about" variant="secondary" icon={ArrowUpRight}>
                Learn About Us
            </CTAButton>
        </div>
    </div>
</section>

<style>
    @keyframes why-choose-float {
        0%,
        100% {
            transform: translateY(0) rotate(1deg) scale(1);
        }

        50% {
            transform: translateY(-14px) rotate(-1deg) scale(1.02);
        }
    }

    .why-choose-floating-image {
        animation: why-choose-float 7.5s ease-in-out infinite;
    }

    @media (prefers-reduced-motion: reduce) {
        .why-choose-floating-image {
            animation: none;
        }
    }
</style>