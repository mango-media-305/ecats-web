---
import { ArrowUpRight, CheckCircle2, Sparkles } from "@lucide/astro";

import SectionHeading from "../ui/SectionHeading.astro";
import CTAButton from "../ui/CTAButton.astro";
import Badge from "../ui/Badge.astro";
import { homeIndustriesSection } from "../../data/home";
---

<section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
    <!-- Background accents -->
    <div class="pointer-events-none absolute inset-0 -z-10">
        <div
            class="absolute left-1/2 top-0 h-px w-[min(92%,1180px)] -translate-x-1/2 bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.55),transparent)]"
        >
        </div>

        <div
            class="absolute left-[-14rem] top-24 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-3xl"
        >
        </div>

        <div
            class="absolute right-[-12rem] bottom-10 h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.1)] blur-3xl"
        >
        </div>

        <div
            class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgb(var(--color-secondary)/0.06),transparent_34rem)]"
        >
        </div>
    </div>

    <div class="container-wide">
        <!-- Heading + floating visual -->
        <div class="grid gap-10 lg:grid-cols-[0.95fr_0.75fr] lg:items-center">
            <SectionHeading
                eyebrow={homeIndustriesSection.eyebrow}
                title={homeIndustriesSection.title}
                highlight="Miami"
                description={homeIndustriesSection.description}
            />

            <!-- Floating decorative image: tablet + desktop only -->
            <div class="relative hidden min-h-[18rem] md:block lg:min-h-[22rem]">
                <div
                    class="pointer-events-none absolute inset-0 rounded-full bg-[radial-gradient(circle,rgb(var(--color-secondary)/0.16),transparent_62%)] blur-3xl"
                >
                </div>

                <div
                    class="pointer-events-none absolute left-1/2 top-1/2 h-60 w-60 -translate-x-1/2 -translate-y-1/2 rounded-full border border-[rgb(var(--color-secondary)/0.18)]"
                >
                </div>

                <div
                    class="pointer-events-none absolute right-8 top-8 h-24 w-24 rounded-full bg-[rgb(var(--color-secondary)/0.12)] blur-2xl"
                >
                </div>

                <div
                    class="pointer-events-none absolute left-6 bottom-8 h-24 w-24 rounded-full bg-[rgb(var(--color-primary)/0.12)] blur-2xl"
                >
                </div>

                <img
                    src="/images/home/industries-floating-businesses.webp"
                    alt=""
                    width="900"
                    height="700"
                    loading="lazy"
                    decoding="async"
                    class="industries-floating-image relative z-10 mx-auto w-full max-w-[30rem] object-contain drop-shadow-[0_34px_80px_rgb(5_162_236/0.22)]"
                />

                <div
                    class="absolute right-8 top-6 z-20 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.78)] px-4 py-2 shadow-soft backdrop-blur"
                >
                    <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-secondary))]">
                        Miami businesses
                    </span>
                </div>

                <div
                    class="absolute bottom-8 left-4 z-20 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.78)] px-4 py-2 shadow-soft backdrop-blur"
                >
                    <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-heading))]">
                        Contractors · Restaurants · Pros
                    </span>
                </div>
            </div>

            <div class="flex justify-start lg:col-span-2 lg:justify-end">
                <CTAButton href={homeIndustriesSection.cta.href} variant="secondary">
                    {homeIndustriesSection.cta.label}
                </CTAButton>
            </div>
        </div>

        <!-- Industries cards -->
        <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
            {
                homeIndustriesSection.industries.map((industry, index) => {
                    const Icon = industry.icon;

                    return (
                        <article class="group glow-card card-hover relative overflow-hidden p-6">
                            <!-- Subtle corner glow -->
                            <div class="pointer-events-none absolute right-[-4rem] top-[-4rem] h-40 w-40 rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-2xl opacity-0 transition duration-300 group-hover:opacity-100"></div>

                            <!-- Decorative icon watermark -->
                            <div class="pointer-events-none absolute bottom-4 right-5 font-inter text-7xl font-extrabold tracking-[-0.08em] text-[rgb(var(--color-primary)/0.045)] transition group-hover:text-[rgb(var(--color-secondary)/0.075)] dark:text-white/5">
                                <Icon class="h-24 w-24" />
                            </div>

                            <div class="relative z-10 flex h-full flex-col">
                                <div class="flex items-start justify-between gap-4">
                                    <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                        <Icon class="h-7 w-7" />
                                    </span>

                                    <a
                                        href={industry.href}
                                        aria-label={`Learn more about ${industry.title}`}
                                        class="flex h-10 w-10 items-center justify-center rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] text-[rgb(var(--color-heading))] transition duration-300 group-hover:-translate-y-1 group-hover:translate-x-1 group-hover:border-[rgb(var(--color-secondary)/0.45)] group-hover:bg-[rgb(var(--color-secondary))] group-hover:text-white dark:group-hover:text-[rgb(3_11_29)]"
                                    >
                                        <ArrowUpRight class="h-4.5 w-4.5" />
                                    </a>
                                </div>

                                <Badge variant="soft" size="sm" class="mt-7">
                                    {industry.eyebrow}
                                </Badge>

                                <h3 class="mt-4 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                    {industry.title}
                                </h3>

                                <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                    {industry.summary}
                                </p>

                                <div class="mt-6 grid gap-3">
                                    {
                                        industry.commonNeeds.slice(0, index === 0 ? 5 : 3).map((need) => (
                                            <div class="flex items-start gap-3">
                                                <CheckCircle2 class="mt-0.5 h-4.5 w-4.5 shrink-0 text-[rgb(var(--color-secondary))]" />
                                                <span class="text-sm font-bold leading-6 text-[rgb(var(--color-text))]">
                                                    {need}
                                                </span>
                                            </div>
                                        ))
                                    }
                                </div>

                                <div class="mt-auto pt-7">
                                    <a
                                        href={industry.href}
                                        class="group/link inline-flex items-center gap-2 font-inter text-sm font-extrabold text-[rgb(var(--color-secondary))]"
                                    >
                                        View industry support
                                        <ArrowUpRight class="h-4 w-4 transition group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5" />
                                    </a>
                                </div>
                            </div>
                        </article>
                    );
                })
            }
        </div>

        <!-- Bottom feature panel -->
        <div
            class="mt-14 overflow-hidden rounded-[2rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.74)] p-5 shadow-soft backdrop-blur md:p-6"
        >
            <div class="grid gap-6 lg:grid-cols-[1fr_auto] lg:items-center">
                <div>
                    <Badge variant="blue" icon={Sparkles}>
                        Local Business Support
                    </Badge>

                    <h3 class="mt-4 max-w-3xl font-inter text-3xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))] md:text-4xl">
                        Built for the way Miami businesses actually operate.
                    </h3>

                    <p class="mt-3 max-w-4xl text-sm leading-7 text-[rgb(var(--color-text-soft))] md:text-base">
                        Contractors, restaurants, real estate professionals, healthcare practices,
                        service companies, and self-employed professionals all have different
                        financial needs. These industry pages help the website rank for specific
                        searches while showing clients that East Coast Accounting understands
                        their situation.
                    </p>
                </div>

                <CTAButton href="/contact">
                    Contact Our Office
                </CTAButton>
            </div>
        </div>
    </div>
</section>

<style>
    @keyframes industries-float {
        0%,
        100% {
            transform: translateY(0) rotate(1deg) scale(1);
        }

        50% {
            transform: translateY(-14px) rotate(-1deg) scale(1.02);
        }
    }

    .industries-floating-image {
        animation: industries-float 7.4s ease-in-out infinite;
    }

    @media (prefers-reduced-motion: reduce) {
        .industries-floating-image {
            animation: none;
        }
    }
</style>