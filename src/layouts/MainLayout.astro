---
import "../styles/global.css";

import Header from "../components/global/Header.astro";
import Footer from "../components/global/Footer.astro";

import {
    businessSchema,
    organizationSchema,
    siteConfig,
    websiteSchema,
} from "../data/site";
import {
    defaultLanguage,
    getLanguageFromUrl,
    getTranslations,
    languages,
    type LanguageCode,
} from "../data/i18n";

type SchemaObject = Record<string, unknown>;

interface Props {
    title?: string;
    description?: string;
    image?: string;
    canonical?: string;
    noindex?: boolean;
    language?: LanguageCode;
    bodyClass?: string;
    schema?: SchemaObject | SchemaObject[];
}

const {
    title,
    description = siteConfig.seo.defaultDescription,
    image = siteConfig.seo.defaultImage,
    canonical,
    noindex = false,
    language,
    bodyClass = "",
    schema = [],
} = Astro.props;

const currentLanguage = language ?? getLanguageFromUrl(Astro.url.pathname);
const t = getTranslations(currentLanguage);

const pageTitle = title
    ? siteConfig.seo.titleTemplate.replace("%s", title)
    : siteConfig.seo.defaultTitle;

const pageDescription = description;
const siteUrl = siteConfig.url.replace(/\/$/, "");
const currentPath = Astro.url.pathname;

const canonicalUrl =
    canonical ??
    `${siteUrl}${currentPath === "/" ? "" : currentPath}`.replace(/\/$/, "");

const absoluteImage = image.startsWith("http") ? image : `${siteUrl}${image}`;

const schemaList = [
    organizationSchema,
    businessSchema,
    websiteSchema,
    ...(Array.isArray(schema) ? schema : [schema]),
].filter(Boolean);

const alternateEnglish = currentPath.startsWith("/es")
    ? `${siteUrl}${currentPath.replace(/^\/es/, "") || "/"}`
    : `${siteUrl}${currentPath}`;

const alternateSpanish = currentPath.startsWith("/es")
    ? `${siteUrl}${currentPath}`
    : `${siteUrl}/es${currentPath === "/" ? "" : currentPath}`;

const htmlClass =
    currentLanguage === defaultLanguage ? "" : `lang-${currentLanguage}`;
---

<!doctype html>
<html
    lang={languages[currentLanguage]?.locale ?? languages[defaultLanguage].locale}
    class={htmlClass}
>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>{pageTitle}</title>
        <meta name="description" content={pageDescription} />

        {
        noindex ? (
            <meta name="robots" content="noindex, nofollow" />
        ) : (
            <meta name="robots" content="index, follow, max-image-preview:large" />
        )
        }

        <link rel="canonical" href={canonicalUrl} />

        <link rel="alternate" hreflang="en-US" href={alternateEnglish} />
        <link rel="alternate" hreflang="es-US" href={alternateSpanish} />
        <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />

        <meta name="theme-color" content="#0B2150" />
        <meta name="color-scheme" content="light dark" />

        <meta property="og:type" content="website" />
        <meta property="og:site_name" content={siteConfig.name} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={absoluteImage} />
        <meta
        property="og:locale"
        content={currentLanguage === "es" ? "es_US" : "en_US"}
        />

        {
        currentLanguage === "en" ? (
            <meta property="og:locale:alternate" content="es_US" />
        ) : (
            <meta property="og:locale:alternate" content="en_US" />
        )
        }

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={pageDescription} />
        <meta name="twitter:image" content={absoluteImage} />

        <link rel="icon" type="image/webp" href={siteConfig.logos.dark} />
        <link rel="apple-touch-icon" href={siteConfig.logos.dark} />

        <link
        rel="preload"
        href="/fonts/inter/inter-regular.woff2"
        as="font"
        type="font/woff2"
        crossorigin
        />
        <link
        rel="preload"
        href="/fonts/inter/inter-semibold.woff2"
        as="font"
        type="font/woff2"
        crossorigin
        />
        <link
        rel="preload"
        href="/fonts/lato/lato-regular.woff2"
        as="font"
        type="font/woff2"
        crossorigin
        />

        <script is:inline>
        const savedTheme = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
        ).matches;
        const theme = savedTheme || (prefersDark ? "dark" : "light");

        document.documentElement.dataset.theme = theme;
        </script>

        {
        schemaList.map((schemaItem) => (
            <script
            type="application/ld+json"
            set:html={JSON.stringify(schemaItem)}
            />
        ))
        }
    </head>

    <body class={bodyClass}>
        <a class="skip-link" href="#main-content">{t.skipToContent}</a>

        <div class="site-shell">
            <Header />

            <main id="main-content">
                <slot />
            </main>

            <Footer />
        </div>

        <script is:inline>
        const root = document.documentElement;

        function setTheme(theme) {
            root.dataset.theme = theme;
            localStorage.setItem("theme", theme);

            document.dispatchEvent(
            new CustomEvent("themechange", {
                detail: { theme },
            }),
            );
        }

        function syncThemeButtons(theme) {
            document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
            const isDark = theme === "dark";
            button.setAttribute("aria-pressed", String(isDark));

            const lightIcon = button.querySelector("[data-theme-icon='light']");
            const darkIcon = button.querySelector("[data-theme-icon='dark']");
            const label = button.querySelector("[data-theme-label]");

            if (lightIcon) lightIcon.classList.toggle("hidden", isDark);
            if (darkIcon) darkIcon.classList.toggle("hidden", !isDark);

            if (label) {
                label.textContent = isDark ? "Dark mode" : "Light mode";
            }
            });
        }

        function getCurrentTheme() {
            return root.dataset.theme === "dark" ? "dark" : "light";
        }

        syncThemeButtons(getCurrentTheme());

        document.addEventListener("click", (event) => {
            const button = event.target.closest("[data-theme-toggle]");
            if (!button) return;

            const nextTheme = getCurrentTheme() === "dark" ? "light" : "dark";
            setTheme(nextTheme);
            syncThemeButtons(nextTheme);
        });

        document.addEventListener("themechange", (event) => {
            syncThemeButtons(event.detail.theme);
        });
        </script>
    </body>
</html>
