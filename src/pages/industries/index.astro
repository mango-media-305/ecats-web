---
import {
    ArrowUpRight,
    BriefcaseBusiness,
    Building2,
    CheckCircle2,
    Handshake,
    MapPin,
    MessageSquareText,
    Send,
    Sparkles,
    UsersRound,
} from "@lucide/astro";

import MainLayout from "../../layouts/MainLayout.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";
import CTAButton from "../../components/ui/CTAButton.astro";
import Badge from "../../components/ui/Badge.astro";

import { homeIndustriesSection } from "../../data/home";
import { siteConfig } from "../../data/site";

const title = "Industries We Support in Miami, FL";
const description =
    "Industry-specific tax, bookkeeping, payroll, and accounting support for small businesses, contractors, restaurants, real estate professionals, healthcare practices, and self-employed professionals in Miami, FL.";

const industriesSchema = {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    description,
    url: `${siteConfig.url.replace(/\/$/, "")}/industries`,
    mainEntity: {
        "@type": "ItemList",
        itemListElement: homeIndustriesSection.industries.map((industry, index) => ({
            "@type": "ListItem",
            position: index + 1,
            name: industry.title,
            url: `${siteConfig.url.replace(/\/$/, "")}${industry.href}`,
        })),
    },
};
---

<MainLayout
    title={title}
    description={description}
    image="/images/og/industries-og.webp"
    schema={industriesSchema}
>
    <!-- Industries Hero -->
    <section class="accounting-grid relative isolate overflow-hidden py-16 sm:py-20 lg:py-24">
        <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
            <div class="industries-kenburns-bg absolute inset-0 overflow-hidden">
                <img
                    src="/images/industries/industries-hero-miami-businesses.webp"
                    alt=""
                    width="2400"
                    height="1600"
                    class="absolute inset-0 h-full min-h-full w-full min-w-full object-cover object-center"
                    loading="eager"
                    decoding="async"
                />
            </div>

            <!-- <div class="absolute inset-0 bg-[rgb(var(--color-bg)/0.78)]"></div> -->

            <div class="absolute inset-0 bg-[linear-gradient(90deg,rgb(var(--color-bg)/0.96)_0%,rgb(var(--color-bg)/0.74)_52%,rgb(var(--color-bg)/0.46)_100%)]"></div>

            <div class="absolute left-[-12rem] top-20 h-[32rem] w-[32rem] rounded-full bg-[rgb(var(--color-secondary)/0.14)] blur-3xl"></div>

            <div class="absolute right-[-10rem] bottom-[-10rem] h-[34rem] w-[34rem] rounded-full bg-[rgb(var(--color-primary)/0.13)] blur-3xl"></div>

            <div class="absolute inset-x-0 bottom-0 h-48 bg-[linear-gradient(to_top,rgb(var(--color-bg)),transparent)]"></div>
        </div>

        <div class="container-wide">
            <div class="grid gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
                <div class="relative z-10 max-w-3xl">
                    <Badge variant="blue" icon={Sparkles} glow>
                        Miami Industry Accounting Support
                    </Badge>

                    <h1 class="mt-6 text-balance font-inter text-4xl font-extrabold tracking-[-0.065em] text-[rgb(var(--color-heading))] sm:text-5xl lg:text-6xl">
                        Accounting support built for the way
                        <span class="gradient-text block">Miami businesses operate.</span>
                    </h1>

                    <p class="lead-text mt-6">
                        Different industries have different financial needs. East Coast Accounting & Tax Services helps local businesses, contractors, restaurants, real estate professionals, healthcare practices, and self-employed professionals stay organized with tax, bookkeeping, payroll, and accounting support.
                    </p>

                    <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                        <CTAButton href="/contact" icon={Send} size="lg">
                            Contact Our Office
                        </CTAButton>

                        <CTAButton href="/services" variant="secondary" icon={ArrowUpRight} size="lg">
                            View Services
                        </CTAButton>
                    </div>

                    <div class="mt-8 grid gap-3 sm:grid-cols-3">
                        {
                            [
                                {
                                    label: "Miami-Dade",
                                    detail: "Local business support",
                                    icon: MapPin,
                                },
                                {
                                    label: "EN / ES",
                                    detail: "Bilingual assistance",
                                    icon: UsersRound,
                                },
                                {
                                    label: "Year-round",
                                    detail: "Beyond tax season",
                                    icon: CheckCircle2,
                                },
                            ].map((item) => {
                                const Icon = item.icon;

                                return (
                                    <div class="glass-panel rounded-[1.35rem] p-4">
                                        <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                                            <Icon class="h-5 w-5" />
                                        </span>

                                        <p class="mt-3 font-inter text-sm font-extrabold text-[rgb(var(--color-heading))]">
                                            {item.label}
                                        </p>

                                        <p class="mt-1 text-xs leading-5 text-[rgb(var(--color-text-soft))]">
                                            {item.detail}
                                        </p>
                                    </div>
                                );
                            })
                        }
                    </div>
                </div>

                <!-- Floating visual -->
                <div class="relative hidden md:block">
                    <div class="pointer-events-none absolute inset-0 rounded-full bg-[radial-gradient(circle,rgb(var(--color-secondary)/0.18),transparent_62%)] blur-3xl"></div>

                    <div class="pointer-events-none absolute left-1/2 top-1/2 h-72 w-72 -translate-x-1/2 -translate-y-1/2 rounded-full border border-[rgb(var(--color-secondary)/0.18)]"></div>

                    <img
                        src="/images/industries/industries-floating-businesses.webp"
                        alt=""
                        width="900"
                        height="700"
                        loading="eager"
                        decoding="async"
                        class="industries-floating-image relative z-10 mx-auto w-full max-w-[48rem] object-contain drop-shadow-[0_34px_80px_rgb(5_162_236/0.24)]"
                    />
                </div>
            </div>
        </div>
    </section>

    <!-- Industry Cards -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-1/2 top-0 h-px w-[min(92%,1180px)] -translate-x-1/2 bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.55),transparent)]"></div>

            <div class="absolute left-[-14rem] top-24 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-10 h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.1)] blur-3xl"></div>
        </div>

        <div class="container-wide">
            <SectionHeading
                eyebrow="Industries We Support"
                title="Tax and accounting support for local business needs."
                highlight="local business needs"
                description="Explore industry-focused support designed to help each type of client quickly understand how East Coast Accounting & Tax Services can help."
            />

            <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
                {
                    homeIndustriesSection.industries.map((industry, index) => {
                        const Icon = industry.icon;

                        return (
                            <article class="group glow-card card-hover relative overflow-hidden p-6">
                                <div class="pointer-events-none absolute right-[-4rem] top-[-4rem] h-40 w-40 rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-2xl opacity-0 transition duration-300 group-hover:opacity-100"></div>

                                <div class="pointer-events-none absolute bottom-4 right-5 text-[rgb(var(--color-primary)/0.045)] transition group-hover:text-[rgb(var(--color-secondary)/0.075)] dark:text-white/5">
                                    <Icon class="h-24 w-24" />
                                </div>

                                <div class="relative z-10 flex h-full flex-col">
                                    <div class="flex items-start justify-between gap-4">
                                        <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                            <Icon class="h-7 w-7" />
                                        </span>

                                        <a
                                            href={industry.href}
                                            aria-label={`Learn more about ${industry.title}`}
                                            class="flex h-10 w-10 items-center justify-center rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] text-[rgb(var(--color-heading))] transition duration-300 group-hover:-translate-y-1 group-hover:translate-x-1 group-hover:border-[rgb(var(--color-secondary)/0.45)] group-hover:bg-[rgb(var(--color-secondary))] group-hover:text-white dark:group-hover:text-[rgb(3_11_29)]"
                                        >
                                            <ArrowUpRight class="h-4.5 w-4.5" />
                                        </a>
                                    </div>

                                    <Badge variant="soft" size="sm" class="mt-7">
                                        {industry.eyebrow}
                                    </Badge>

                                    <h2 class="mt-4 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                        {industry.title}
                                    </h2>

                                    <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                        {industry.summary}
                                    </p>

                                    <div class="mt-6 grid gap-3">
                                        {
                                            industry.commonNeeds.slice(0, index === 0 ? 5 : 3).map((need) => (
                                                <div class="flex items-start gap-3">
                                                    <CheckCircle2 class="mt-0.5 h-4.5 w-4.5 shrink-0 text-[rgb(var(--color-secondary))]" />
                                                    <span class="text-sm font-bold leading-6 text-[rgb(var(--color-text))]">
                                                        {need}
                                                    </span>
                                                </div>
                                            ))
                                        }
                                    </div>

                                    <div class="mt-auto pt-7">
                                        <a
                                            href={industry.href}
                                            class="group/link inline-flex items-center gap-2 font-inter text-sm font-extrabold text-[rgb(var(--color-secondary))]"
                                        >
                                            View industry support
                                            <ArrowUpRight class="h-4 w-4 transition group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5" />
                                        </a>
                                    </div>
                                </div>
                            </article>
                        );
                    })
                }
            </div>
        </div>
    </section>

    <!-- Why industry-specific support matters -->
    <section class="section-shell relative overflow-hidden">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-[-12rem] top-20 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.09)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-10 h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.09)] blur-3xl"></div>
        </div>

        <div class="container-wide">
            <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
                <SectionHeading
                    eyebrow="Why It Matters"
                    title="Every industry has different accounting priorities."
                    highlight="different accounting priorities"
                    description="A restaurant, contractor, healthcare practice, and real estate professional may all need tax support, but the records, payroll, expenses, and reporting details often look very different."
                />

                <div class="grid gap-5 md:grid-cols-2">
                    {
                        [
                            {
                                title: "Different expense patterns",
                                description:
                                    "Industry-specific support helps clients organize the income, expenses, payroll, and documents that matter most for their type of work.",
                                icon: BriefcaseBusiness,
                            },
                            {
                                title: "Cleaner tax preparation",
                                description:
                                    "When records are organized by the way the business actually operates, tax preparation becomes easier to understand and manage.",
                                icon: CheckCircle2,
                            },
                            {
                                title: "Better financial visibility",
                                description:
                                    "Clearer books and reports help owners understand what is happening inside the business throughout the year.",
                                icon: Building2,
                            },
                            {
                                title: "Local business guidance",
                                description:
                                    "A Miami-based office can help local clients think through common business needs with bilingual support.",
                                icon: Handshake,
                            },
                        ].map((item) => {
                            const Icon = item.icon;

                            return (
                                <article class="group glow-card card-hover p-6">
                                    <div class="relative z-10">
                                        <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                            <Icon class="h-7 w-7" />
                                        </span>

                                        <h3 class="mt-5 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                            {item.title}
                                        </h3>

                                        <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                            {item.description}
                                        </p>
                                    </div>
                                </article>
                            );
                        })
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Local support panel -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="container-wide">
            <div class="relative overflow-hidden rounded-[2.5rem] border border-[rgb(var(--color-border)/0.72)] bg-[linear-gradient(135deg,rgb(var(--color-primary))_0%,rgb(var(--color-secondary))_100%)] p-6 text-white shadow-blue sm:p-8 lg:p-10">
                <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_0%,rgba(255,255,255,0.28),transparent_34%),radial-gradient(circle_at_92%_100%,rgba(255,255,255,0.16),transparent_34%)]"></div>

                <div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
                    <div>
                        <Badge
                            variant="outline"
                            class="border-white/25 bg-white/10 !text-white"
                            icon={MapPin}
                        >
                            Miami Business Support
                        </Badge>

                        <h2 class="mt-5 max-w-4xl font-inter text-3xl font-extrabold tracking-[-0.055em] !text-white md:text-4xl">
                            Built for small business owners who want clearer numbers and better organization.
                        </h2>

                        <p class="mt-4 max-w-3xl text-sm leading-7 !text-white/78 md:text-base">
                            From tax preparation and bookkeeping to payroll and accounting support, our Miami office helps business owners understand what is needed and move forward with more confidence.
                        </p>
                    </div>

                    <div class="grid gap-3 sm:grid-cols-3 lg:w-[28rem]">
                        {
                            [
                                "Tax support",
                                "Bookkeeping",
                                "Payroll",
                            ].map((item) => (
                                <div class="rounded-2xl border border-white/15 bg-white/10 p-4 text-center backdrop-blur">
                                    <CheckCircle2 class="mx-auto h-5 w-5 text-white" />
                                    <p class="mt-3 font-inter text-sm font-extrabold !text-white">
                                        {item}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ / Helpful questions -->
    <section class="section-shell relative overflow-hidden">
        <div class="container-wide">
            <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
                <SectionHeading
                    eyebrow="Helpful Questions"
                    title="Questions about industry-specific accounting support."
                    highlight="Questions"
                    description="Simple answers for business owners comparing tax, bookkeeping, payroll, and accounting support."
                />

                <div class="grid gap-4">
                    {
                        [
                            {
                                question: "Do different industries really need different accounting support?",
                                answer:
                                    "Yes. Many businesses need the same core services, but the records, expenses, payroll structure, and tax details can vary by industry.",
                            },
                            {
                                question: "Can one office help with taxes, bookkeeping, payroll, and accounting?",
                                answer:
                                    "Yes. East Coast Accounting & Tax Services provides support across taxes, bookkeeping, payroll, and accounting so clients can keep related financial needs connected.",
                            },
                            {
                                question: "Do you support both individuals and businesses?",
                                answer:
                                    "Yes. The office supports individuals, families, self-employed professionals, and businesses across Miami and nearby South Florida communities.",
                            },
                        ].map((faq, index) => (
                            <article class="rounded-[1.6rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-5 shadow-soft backdrop-blur">
                                <div class="flex gap-4">
                                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] font-inter text-xs font-extrabold text-[rgb(var(--color-secondary))]">
                                        {String(index + 1).padStart(2, "0")}
                                    </span>

                                    <div>
                                        <h3 class="font-inter text-lg font-extrabold tracking-[-0.045em] text-[rgb(var(--color-heading))]">
                                            {faq.question}
                                        </h3>

                                        <p class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                            {faq.answer}
                                        </p>
                                    </div>
                                </div>
                            </article>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="section-shell relative isolate overflow-hidden">
        <div class="container-wide">
            <div class="relative overflow-hidden rounded-[2.5rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.74)] p-6 shadow-card backdrop-blur sm:p-8 lg:p-10">
                <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_0%,rgb(var(--color-secondary)/0.12),transparent_34rem)]"></div>

                <div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
                    <div>
                        <Badge variant="blue" icon={MessageSquareText}>
                            Talk to Our Office
                        </Badge>

                        <h2 class="mt-5 max-w-4xl font-inter text-3xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))] md:text-4xl">
                            Need accounting support for your industry?
                        </h2>

                        <p class="mt-4 max-w-3xl text-sm leading-7 text-[rgb(var(--color-text-soft))] md:text-base">
                            Send a message and tell us what type of business or financial situation you need help with. Our office will guide you toward the right next step.
                        </p>
                    </div>

                    <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
                        <CTAButton href="/contact" icon={Send}>
                            Contact Our Office
                        </CTAButton>

                        <CTAButton href="/services" variant="secondary" icon={ArrowUpRight}>
                            View Services
                        </CTAButton>
                    </div>
                </div>
            </div>
        </div>
    </section>
</MainLayout>

<style>
    .industries-kenburns-bg {
        inset: 0;
        width: 100%;
        height: 100%;
        opacity: 0.24;
        transform: scale(1.08);
        transform-origin: center center;
        animation: industries-kenburns 18s ease-in-out infinite alternate;
    }

    .industries-kenburns-bg img {
        object-fit: cover;
        object-position: center center;
    }

    :root[data-theme="dark"] .industries-kenburns-bg {
        opacity: 0.16;
    }

    @keyframes industries-kenburns {
        0% {
            transform: scale(1.08) translate3d(0, 0, 0);
        }

        100% {
            transform: scale(1.18) translate3d(-1.5%, -1.2%, 0);
        }
    }

    @keyframes industries-float {
        0%,
        100% {
            transform: translateY(0) rotate(1deg) scale(1);
        }

        50% {
            transform: translateY(-14px) rotate(-1deg) scale(1.02);
        }
    }

    .industries-floating-image {
        animation: industries-float 7.4s ease-in-out infinite;
    }

    @media (max-width: 1023px) {
        .industries-kenburns-bg img {
            object-position: center top;
        }
    }

    @media (max-width: 767px) {
        .industries-kenburns-bg {
            transform: scale(1.12);
        }

        .industries-kenburns-bg img {
            object-position: center center;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .industries-kenburns-bg,
        .industries-floating-image {
            animation: none;
        }

        .industries-kenburns-bg {
            transform: scale(1.1);
        }
    }
</style>