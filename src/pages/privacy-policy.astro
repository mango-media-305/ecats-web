---
import {
    ArrowLeft,
    CheckCircle2,
    Clock3,
    Database,
    FileText,
    LockKeyhole,
    Mail,
    MapPin,
    Phone,
    Send,
    ShieldCheck,
    Sparkles,
    UserCheck,
} from "@lucide/astro";

import MainLayout from "../layouts/MainLayout.astro";
import CTAButton from "../components/ui/CTAButton.astro";
import Badge from "../components/ui/Badge.astro";
import { siteConfig } from "../data/site";

const title = "Privacy Policy";
const description =
    "Read the Privacy Policy for East Coast Accounting & Tax Services, including how information submitted through the website may be collected, used, and protected.";

const effectiveDate = "May 2026";

const privacyHighlights = [
    {
        title: "Information you submit",
        description:
            "Contact form details, email messages, phone inquiries, and service-related information may be used to respond to your request.",
        icon: FileText,
    },
    {
        title: "Website usage information",
        description:
            "Basic website analytics or technical information may be collected to improve website performance, security, and user experience.",
        icon: Database,
    },
    {
        title: "Reasonable protection",
        description:
            "The office takes reasonable steps to protect information submitted through the website and related communication channels.",
        icon: LockKeyhole,
    },
];

const sections = [
    {
        title: "1. Information We May Collect",
        body: [
            "East Coast Accounting & Tax Services may collect information that you voluntarily provide through the website, including your name, phone number, email address, service interest, message details, and any other information you choose to submit through a contact form or direct communication.",
            "The website may also collect basic technical information such as browser type, device information, pages visited, approximate location data, referral source, and similar usage information through analytics, hosting tools, or security-related technologies.",
        ],
    },
    {
        title: "2. How We May Use Information",
        body: [
            "Information submitted through the website may be used to respond to inquiries, schedule or discuss services, provide client support, improve communication, maintain website functionality, and understand how visitors use the website.",
            "East Coast Accounting & Tax Services may also use submitted information to follow up about tax preparation, bookkeeping, payroll, accounting, business tax services, or related support requested by the visitor.",
        ],
    },
    {
        title: "3. Contact Forms and Website Submissions",
        body: [
            "When you submit a contact form, the information provided may be delivered to the office by email or stored through the website hosting or form-processing system. Please avoid submitting highly sensitive information through the website contact form unless specifically requested through a secure communication method.",
            "Submitting a form does not automatically create a client relationship. The office may review your request and follow up to determine whether and how services may be provided.",
        ],
    },
    {
        title: "4. Sharing of Information",
        body: [
            "East Coast Accounting & Tax Services does not sell personal information submitted through the website.",
            "Information may be shared with trusted service providers when reasonably necessary to operate the website, process communications, manage hosting, improve security, or support business operations. Information may also be disclosed when required by law, regulation, legal process, or to protect the rights, safety, and security of the business, clients, or website visitors.",
        ],
    },
    {
        title: "5. Cookies, Analytics, and Tracking",
        body: [
            "The website may use cookies, analytics tools, or similar technologies to understand website traffic, improve performance, measure page activity, and maintain a better user experience.",
            "You may be able to disable cookies through your browser settings. Some website features may not function as intended if cookies or similar technologies are disabled.",
        ],
    },
    {
        title: "6. Data Security",
        body: [
            "East Coast Accounting & Tax Services takes reasonable administrative, technical, and organizational steps to help protect information submitted through the website.",
            "However, no website, email, or online transmission method can be guaranteed to be completely secure. Visitors should use care when sharing sensitive information online.",
        ],
    },
    {
        title: "7. Third-Party Links",
        body: [
            "The website may include links to third-party websites, tools, maps, platforms, or resources. East Coast Accounting & Tax Services is not responsible for the privacy practices, security, or content of third-party websites.",
            "Visitors should review the privacy policies of any third-party websites they choose to access.",
        ],
    },
    {
        title: "8. Children’s Privacy",
        body: [
            "This website is intended for general business and informational purposes and is not directed to children. East Coast Accounting & Tax Services does not knowingly collect personal information from children through the website.",
        ],
    },
    {
        title: "9. Updates to This Policy",
        body: [
            "This Privacy Policy may be updated from time to time to reflect changes in website practices, business operations, or legal requirements. The effective date above indicates the latest version of this page.",
        ],
    },
    {
        title: "10. Contact Us",
        body: [
            `If you have questions about this Privacy Policy or how website information is handled, you may contact East Coast Accounting & Tax Services at ${siteConfig.contact.email} or ${siteConfig.contact.phone}.`,
        ],
    },
];

const pageSchema = {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    description,
    url: `${siteConfig.url.replace(/\/$/, "")}/privacy-policy`,
};
---

<MainLayout
    title={title}
    description={description}
    noindex={false}
    schema={pageSchema}
>
    <section class="section-shell accounting-grid relative isolate overflow-hidden">
        <!-- Background effects -->
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-[-12rem] top-20 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.12)] blur-3xl"></div>

            <div class="absolute bottom-[-12rem] right-[-10rem] h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.13)] blur-3xl"></div>

            <div class="absolute inset-x-0 bottom-0 h-48 bg-[linear-gradient(to_top,rgb(var(--color-bg)),transparent)]"></div>
        </div>

        <div class="container-narrow">
            <a
                href="/"
                class="mb-6 inline-flex items-center gap-2 font-inter text-sm font-extrabold text-[rgb(var(--color-secondary))] transition hover:gap-3"
            >
                <ArrowLeft class="h-4 w-4" />
                Back to Home
            </a>

            <div class="glass-panel relative overflow-hidden rounded-[2.5rem] p-5 shadow-card sm:p-8 lg:p-10">
                <div class="pointer-events-none absolute inset-x-10 top-0 h-px bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.8),transparent)]"></div>

                <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgb(var(--color-secondary)/0.1),transparent_34rem)]"></div>

                <div class="relative">
                    <Badge variant="blue" icon={ShieldCheck} glow>
                        Website Privacy
                    </Badge>

                    <h1 class="mt-6 text-balance font-inter text-4xl font-extrabold tracking-[-0.065em] text-[rgb(var(--color-heading))] sm:text-5xl lg:text-6xl">
                        Privacy Policy
                    </h1>

                    <p class="lead-text mt-6">
                        This Privacy Policy explains how East Coast Accounting & Tax Services may collect, use, and protect information submitted through this website.
                    </p>

                    <div class="mt-8 flex flex-wrap gap-3">
                        <div class="inline-flex items-center gap-2 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] px-4 py-2 shadow-soft backdrop-blur">
                            <Clock3 class="h-4 w-4 text-[rgb(var(--color-secondary))]" />
                            <span class="font-inter text-sm font-bold text-[rgb(var(--color-heading))]">
                                Effective: {effectiveDate}
                            </span>
                        </div>

                        <div class="inline-flex items-center gap-2 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] px-4 py-2 shadow-soft backdrop-blur">
                            <UserCheck class="h-4 w-4 text-[rgb(var(--color-secondary))]" />
                            <span class="font-inter text-sm font-bold text-[rgb(var(--color-heading))]">
                                Applies to website visitors
                            </span>
                        </div>
                    </div>

                    <div class="mt-10 grid gap-4 md:grid-cols-3">
                        {
                            privacyHighlights.map((item) => {
                                const Icon = item.icon;

                                return (
                                    <article class="rounded-[1.6rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-5 shadow-soft backdrop-blur">
                                        <span class="flex h-12 w-12 items-center justify-center rounded-[1.1rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                                            <Icon class="h-6 w-6" />
                                        </span>

                                        <h2 class="mt-4 font-inter text-lg font-extrabold tracking-[-0.045em] text-[rgb(var(--color-heading))]">
                                            {item.title}
                                        </h2>

                                        <p class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                            {item.description}
                                        </p>
                                    </article>
                                );
                            })
                        }
                    </div>
                </div>
            </div>

            <!-- Policy Content -->
            <div class="mt-8 rounded-[2.25rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.74)] p-5 shadow-soft backdrop-blur sm:p-8">
                <div class="prose-like">
                    <p class="rounded-[1.5rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-bg)/0.42)] p-4 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                        <strong class="text-[rgb(var(--color-heading))]">Important:</strong>
                        This page is provided for general website privacy information and should not be considered legal advice. East Coast Accounting & Tax Services may update this policy as website practices or business needs change.
                    </p>

                    <div class="mt-8 grid gap-6">
                        {
                            sections.map((section) => (
                                <article class="rounded-[1.6rem] border border-[rgb(var(--color-border)/0.64)] bg-[rgb(var(--color-bg)/0.36)] p-5">
                                    <h2 class="font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                        {section.title}
                                    </h2>

                                    <div class="mt-4 grid gap-4">
                                        {
                                            section.body.map((paragraph) => (
                                                <p class="text-sm leading-7 text-[rgb(var(--color-text-soft))] md:text-base">
                                                    {paragraph}
                                                </p>
                                            ))
                                        }
                                    </div>
                                </article>
                            ))
                        }
                    </div>
                </div>
            </div>

            <!-- Contact Strip -->
            <div class="mt-8 overflow-hidden rounded-[2rem] border border-[rgb(var(--color-border)/0.72)] bg-[linear-gradient(135deg,rgb(var(--color-primary))_0%,rgb(var(--color-secondary))_100%)] p-6 text-white shadow-blue md:p-8">
                <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
                    <div>
                        <Badge
                            variant="outline"
                            class="border-white/25 bg-white/10 !text-white"
                            icon={Sparkles}
                        >
                            Questions About Privacy?
                        </Badge>

                        <h2 class="mt-5 max-w-3xl font-inter text-3xl font-extrabold tracking-[-0.055em] !text-white md:text-4xl">
                            Contact our Miami office if you have questions about this policy.
                        </h2>

                        <div class="mt-5 grid gap-3 text-sm font-bold !text-white/82">
                            <a
                                href={siteConfig.contact.phoneHref}
                                class="flex items-center gap-3 transition hover:!text-white"
                            >
                                <Phone class="h-4.5 w-4.5 shrink-0" />
                                {siteConfig.contact.phone}
                            </a>

                            <a
                                href={siteConfig.contact.emailHref}
                                class="flex items-center gap-3 transition hover:!text-white"
                            >
                                <Mail class="h-4.5 w-4.5 shrink-0" />
                                {siteConfig.contact.email}
                            </a>

                            <div class="flex items-start gap-3">
                                <MapPin class="mt-0.5 h-4.5 w-4.5 shrink-0" />
                                <span>{siteConfig.address.full}</span>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
                        <CTAButton href="/contact" variant="dark" icon={Send}>
                            Contact Our Office
                        </CTAButton>

                        <CTAButton
                            href="/terms-of-service"
                            variant="ghost"
                            class="border-white/20 bg-white/10 text-white hover:border-white/35 hover:bg-white/16"
                        >
                            Terms of Service
                        </CTAButton>
                    </div>
                </div>
            </div>

            <!-- Related Legal Links -->
            <div class="mt-8 grid gap-4 sm:grid-cols-2">
                {
                    [
                        {
                            label: "Terms of Service",
                            href: "/terms-of-service",
                            description:
                                "Review general terms for using this website and requesting information.",
                        },
                        {
                            label: "Accessibility",
                            href: "/accessibility",
                            description:
                                "Learn about the website accessibility commitment and how to report issues.",
                        },
                    ].map((item) => (
                        <a
                            href={item.href}
                            class="group rounded-[1.6rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-5 shadow-soft backdrop-blur transition duration-300 hover:-translate-y-1 hover:border-[rgb(var(--color-secondary)/0.42)]"
                        >
                            <div class="flex items-start gap-4">
                                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                                    <CheckCircle2 class="h-5 w-5" />
                                </span>

                                <span>
                                    <span class="block font-inter text-lg font-extrabold text-[rgb(var(--color-heading))]">
                                        {item.label}
                                    </span>

                                    <span class="mt-1 block text-sm leading-6 text-[rgb(var(--color-text-soft))]">
                                        {item.description}
                                    </span>
                                </span>
                            </div>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>
</MainLayout>