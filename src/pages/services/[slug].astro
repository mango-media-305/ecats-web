---
import {
    ArrowLeft,
    ArrowUpRight,
    CheckCircle2,
    HelpCircle,
    MessageSquareText,
    Send,
    Sparkles,
} from "@lucide/astro";

import MainLayout from "../../layouts/MainLayout.astro";
import CTAButton from "../../components/ui/CTAButton.astro";
import Badge from "../../components/ui/Badge.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";

import { services } from "../../data/services";
import { siteConfig } from "../../data/site";

export function getStaticPaths() {
    return services.map((service) => ({
        params: { slug: service.slug },
        props: { service },
    }));
}

const { service } = Astro.props;

const Icon = service.icon;

const title = `${service.title} in Miami, FL`;
const description =
    service.description ??
    `${service.title} services in Miami, FL from East Coast Accounting & Tax Services. Support for individuals and businesses across Miami-Dade and nearby South Florida communities.`;

const serviceUrl = `${siteConfig.url.replace(/\/$/, "")}${service.href}`;

const serviceSchema = {
    "@context": "https://schema.org",
    "@type": "Service",
    name: service.title,
    description,
    provider: {
        "@type": "LocalBusiness",
        name: siteConfig.name,
        telephone: siteConfig.contact.phone,
        email: siteConfig.contact.email,
        address: {
            "@type": "PostalAddress",
            streetAddress: siteConfig.address.street,
            addressLocality: siteConfig.address.city,
            addressRegion: siteConfig.address.state,
            postalCode: siteConfig.address.postalCode,
            addressCountry: "US",
        },
    },
    areaServed: [
        "Miami",
        "Miami-Dade County",
        "South Florida",
    ],
    url: serviceUrl,
};

const faqSchema = service.faqs?.length
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: service.faqs.map((faq) => ({
            "@type": "Question",
            name: faq.question,
            acceptedAnswer: {
                "@type": "Answer",
                text: faq.answer,
            },
        })),
    }
    : null;

const pageSchema = faqSchema ? [serviceSchema, faqSchema] : serviceSchema;
---

<MainLayout
    title={title}
    description={description}
    image={service.image}
    schema={pageSchema}
>
    <!-- Service Hero -->
    <section class="service-detail-hero accounting-grid relative isolate overflow-hidden py-16 sm:py-20 lg:py-24">
        <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
            <!-- Ken Burns background image -->
            <div class="service-detail-kenburns-bg absolute inset-0 overflow-hidden">
                <img
                    src={service.heroImage}
                    alt=""
                    width="2400"
                    height="1600"
                    class="absolute inset-0 h-full min-h-full w-full min-w-full object-cover object-center"
                    loading="eager"
                    decoding="async"
                />
            </div>

            <!-- Readability overlays -->
            <!-- <div class="absolute inset-0 bg-[rgb(var(--color-bg)/0.76)]"></div> -->

            <!-- <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_25%,rgb(var(--color-bg)/0.42),transparent_34rem),radial-gradient(circle_at_78%_30%,rgb(var(--color-secondary)/0.16),transparent_32rem)]"></div> -->

            <div class="absolute inset-0 bg-[linear-gradient(90deg,rgb(var(--color-bg)/0.94)_0%,rgb(var(--color-bg)/0.72)_50%,rgb(var(--color-bg)/0.5)_100%)]"></div>

            <div class="absolute left-[-12rem] top-20 h-[32rem] w-[32rem] rounded-full bg-[rgb(var(--color-secondary)/0.14)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-[-8rem] h-[34rem] w-[34rem] rounded-full bg-[rgb(var(--color-primary)/0.13)] blur-3xl"></div>

            <div class="absolute inset-x-0 bottom-0 h-56 bg-[linear-gradient(to_top,rgb(var(--color-bg)),transparent)]"></div>
        </div>

        <div class="container-wide">
            <div class="grid gap-10 lg:grid-cols-[0.95fr_0.75fr] lg:items-center">
                <div>

                    <Badge variant="blue" icon={Sparkles} glow>
                        {service.eyebrow ?? "Miami Accounting Service"}
                    </Badge>

                    <h1 class="mt-6 max-w-5xl text-balance font-inter text-4xl font-extrabold tracking-[-0.065em] text-[rgb(var(--color-heading))] sm:text-5xl lg:text-6xl">
                        {service.title} in Miami, FL
                    </h1>

                    <p class="lead-text mt-6">
                        {service.description ?? service.summary}
                    </p>

                    <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                        <CTAButton href="/contact" icon={Send} size="lg">
                            Contact Our Office
                        </CTAButton>

                        <CTAButton
                            href={siteConfig.contact.phoneHref}
                            variant="secondary"
                            icon={ArrowUpRight}
                            size="lg"
                        >
                            Call Now
                        </CTAButton>
                    </div>
                </div>

                <!-- Hero service visual -->
                <div class="relative hidden md:block">
                    <div class="pointer-events-none absolute inset-0 rounded-full bg-[radial-gradient(circle,rgb(var(--color-secondary)/0.18),transparent_62%)] blur-3xl"></div>

                    <div class="glass-panel relative overflow-hidden rounded-[2.25rem] p-5 shadow-card">
                        <div class="pointer-events-none absolute inset-x-10 top-0 h-px bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.8),transparent)]"></div>

                        <div class="relative rounded-[1.85rem] border border-[rgb(var(--color-border)/0.68)] bg-[rgb(var(--color-surface)/0.72)] p-6">
                            <div class="pointer-events-none absolute bottom-4 right-5 text-[rgb(var(--color-primary)/0.045)] dark:text-white/5">
                                <Icon class="h-40 w-40" />
                            </div>

                            <div class="relative z-10">
                                <span class="flex h-16 w-16 items-center justify-center rounded-[1.35rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                                    <Icon class="h-8 w-8" />
                                </span>

                                <p class="mt-6 font-inter text-xs font-extrabold uppercase tracking-[0.14em] text-[rgb(var(--color-secondary))]">
                                    Service Overview
                                </p>

                                <h2 class="mt-2 font-inter text-3xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                    Clear support for your next financial step.
                                </h2>

                                <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                    East Coast Accounting & Tax Services helps Miami clients understand what is needed, organize the right information, and move forward with more confidence.
                                </p>

                                <div class="mt-6 grid gap-3">
                                    {
                                        service.features?.slice(0, 3).map((feature) => (
                                            <div class="flex items-start gap-3 rounded-2xl border border-[rgb(var(--color-border)/0.58)] bg-[rgb(var(--color-bg)/0.42)] p-3">
                                                <CheckCircle2 class="mt-0.5 h-4.5 w-4.5 shrink-0 text-[rgb(var(--color-secondary))]" />
                                                <span class="text-sm font-bold leading-6 text-[rgb(var(--color-text))]">
                                                    {feature}
                                                </span>
                                            </div>
                                        ))
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Main content -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-1/2 top-0 h-px w-[min(92%,1180px)] -translate-x-1/2 bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.55),transparent)]"></div>

            <div class="absolute left-[-12rem] top-20 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-0 h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.1)] blur-3xl"></div>
        </div>

        <div class="container-wide">
            <div class="grid gap-10 lg:items-start">

                <!-- Details -->
                <div class="grid gap-8">
                    <div class="rounded-[2.25rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-6 shadow-soft backdrop-blur md:p-8">
                        <Badge variant="blue" icon={CheckCircle2}>
                            What This Service Helps With
                        </Badge>

                        <h2 class="mt-5 font-inter text-3xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))] md:text-4xl">
                            Practical support designed to make the process easier to understand.
                        </h2>

                        <div class="mt-8 grid gap-4 md:grid-cols-2">
                            {
                                service.features?.map((feature) => (
                                    <div class="flex items-start gap-3 rounded-[1.35rem] border border-[rgb(var(--color-border)/0.58)] bg-[rgb(var(--color-bg)/0.42)] p-4">
                                        <CheckCircle2 class="mt-0.5 h-4.5 w-4.5 shrink-0 text-[rgb(var(--color-secondary))]" />
                                        <span class="text-sm font-bold leading-6 text-[rgb(var(--color-text))]">
                                            {feature}
                                        </span>
                                    </div>
                                ))
                            }
                        </div>
                    </div>

                    {
                        service.benefits?.length && (
                            <div class="rounded-[2.25rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-6 shadow-soft backdrop-blur md:p-8">
                                <SectionHeading
                                    eyebrow="Benefits"
                                    title={`Why ${service.title.toLowerCase()} matters`}
                                    highlight={service.title.toLowerCase()}
                                    description="The right accounting support can help reduce confusion, improve organization, and make tax or business decisions feel more manageable."
                                />

                                <div class="mt-8 grid gap-5 md:grid-cols-2">
                                    {service.benefits.map((benefit) => (
                                        <article class="glow-card card-hover p-5">
                                            <CheckCircle2 class="h-6 w-6 text-[rgb(var(--color-secondary))]" />

                                            <h3 class="mt-4 font-inter text-xl font-extrabold tracking-[-0.045em] text-[rgb(var(--color-heading))]">
                                                {benefit.title}
                                            </h3>

                                            <p class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                                {benefit.description}
                                            </p>
                                        </article>
                                    ))}
                                </div>
                            </div>
                        )
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- FAQs -->
    {
        service.faqs?.length && (
            <section class="section-shell relative overflow-hidden">
                <div class="container-wide">
                    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
                        <div>
                            <SectionHeading
                                eyebrow="Service Questions"
                                title={`Questions about ${service.title.toLowerCase()}`}
                                highlight="Questions"
                                description="Helpful answers for clients considering this service."
                            />

                            <div class="mt-8">
                                <CTAButton href="/contact" variant="secondary" icon={HelpCircle}>
                                    Ask a Question
                                </CTAButton>
                            </div>
                        </div>

                        <div class="grid gap-4">
                            {service.faqs.map((faq, index) => (
                                <article class="rounded-[1.6rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-5 shadow-soft backdrop-blur">
                                    <div class="flex gap-4">
                                        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] font-inter text-xs font-extrabold text-[rgb(var(--color-secondary))]">
                                            {String(index + 1).padStart(2, "0")}
                                        </span>

                                        <div>
                                            <h3 class="font-inter text-lg font-extrabold tracking-[-0.045em] text-[rgb(var(--color-heading))]">
                                                {faq.question}
                                            </h3>

                                            <p class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                                {faq.answer}
                                            </p>
                                        </div>
                                    </div>
                                </article>
                            ))}
                        </div>
                    </div>
                </div>
            </section>
        )
    }

    <!-- Final CTA -->
    <section class="section-shell relative isolate overflow-hidden">
        <div class="container-wide">
            <div class="relative overflow-hidden rounded-[2.5rem] border border-[rgb(var(--color-border)/0.72)] bg-[linear-gradient(135deg,rgb(var(--color-primary))_0%,rgb(var(--color-secondary))_100%)] p-6 text-white shadow-blue sm:p-8 lg:p-10">
                <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_0%,rgba(255,255,255,0.3),transparent_34%),radial-gradient(circle_at_92%_100%,rgba(255,255,255,0.16),transparent_34%)]"></div>

                <div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
                    <div>
                        <Badge
                            variant="outline"
                            class="border-white/25 bg-white/10 !text-white"
                            icon={MessageSquareText}
                        >
                            Ready to Get Started?
                        </Badge>

                        <h2 class="mt-5 max-w-4xl font-inter text-3xl font-extrabold tracking-[-0.055em] !text-white md:text-4xl">
                            Need help with {service.title.toLowerCase()} in Miami?
                        </h2>

                        <p class="mt-4 max-w-3xl text-sm leading-7 !text-white/78 md:text-base">
                            Contact East Coast Accounting & Tax Services and tell us what you need help with. The office will review your request and guide you toward the right next step.
                        </p>
                    </div>

                    <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
                        <CTAButton href="/contact" variant="dark" icon={Send}>
                            Contact Our Office
                        </CTAButton>

                        <CTAButton
                            href="/services"
                            variant="ghost"
                            icon={ArrowLeft}
                            iconPosition="left"
                            class="border-white/20 bg-white/10 text-white hover:border-white/35 hover:bg-white/16"
                        >
                            View All Services
                        </CTAButton>
                    </div>
                </div>
            </div>
        </div>
    </section>
</MainLayout>

<style>
    .service-detail-kenburns-bg {
        inset: 0;
        width: 100%;
        height: 100%;
        opacity: 0.3;
        transform: scale(1.08);
        transform-origin: center center;
        animation: service-detail-kenburns 18s ease-in-out infinite alternate;
    }

    .service-detail-kenburns-bg img {
        object-fit: cover;
        object-position: center center;
    }

    :root[data-theme="dark"] .service-detail-kenburns-bg {
        opacity: 0.2;
    }

    @keyframes service-detail-kenburns {
        0% {
            transform: scale(1.08) translate3d(0, 0, 0);
        }

        100% {
            transform: scale(1.18) translate3d(-1.5%, -1.2%, 0);
        }
    }

    @media (max-width: 1023px) {
        .service-detail-kenburns-bg img {
            object-position: center top;
        }
    }

    @media (max-width: 767px) {
        .service-detail-kenburns-bg {
            transform: scale(1.12);
        }

        .service-detail-kenburns-bg img {
            object-position: center center;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .service-detail-kenburns-bg {
            animation: none;
            transform: scale(1.1);
        }
    }
</style>