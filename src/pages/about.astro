---
import {
    ArrowUpRight,
    BookOpenCheck,
    BriefcaseBusiness,
    Building2,
    CheckCircle2,
    Clock3,
    FileCheck2,
    Languages,
    Mail,
    MapPin,
    MessageSquareText,
    Phone,
    ReceiptText,
    Send,
    ShieldCheck,
    Sparkles,
    UsersRound,
    WalletCards,
} from "@lucide/astro";

import MainLayout from "../layouts/MainLayout.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import CTAButton from "../components/ui/CTAButton.astro";
import Badge from "../components/ui/Badge.astro";

import { siteConfig } from "../data/site";

const title = "About East Coast Accounting & Tax Services";
const description =
    "Learn about East Coast Accounting & Tax Services, a Miami accounting office providing tax preparation, bookkeeping, payroll, and accounting support for individuals and businesses.";

const siteUrl = siteConfig.url.replace(/\/$/, "");

const values = [
    {
        title: "Clarity first",
        description:
            "Accounting and tax support should feel understandable. Our goal is to help clients know what documents, records, or next steps may be needed.",
        icon: Sparkles,
    },
    {
        title: "Organized support",
        description:
            "From tax preparation to bookkeeping and payroll, we help clients keep financial information easier to review and manage.",
        icon: FileCheck2,
    },
    {
        title: "Local Miami service",
        description:
            "East Coast Accounting & Tax Services is based in Miami and supports individuals and businesses across Miami-Dade County.",
        icon: MapPin,
    },
    {
        title: "English & Spanish help",
        description:
            "Clear communication matters. Our office supports clients in English and Spanish for tax, bookkeeping, payroll, and accounting questions.",
        icon: Languages,
    },
];

const services = [
    {
        label: "Tax Preparation",
        href: "/services/tax-preparation",
        icon: ReceiptText,
    },
    {
        label: "Bookkeeping",
        href: "/services/bookkeeping",
        icon: BookOpenCheck,
    },
    {
        label: "Payroll Services",
        href: "/services/payroll",
        icon: WalletCards,
    },
    {
        label: "Business Tax Services",
        href: "/services/business-tax-services",
        icon: BriefcaseBusiness,
    },
];

const whoWeHelp = [
    {
        title: "Individuals & Families",
        description:
            "Support for personal tax preparation, document organization, and questions about what may be needed during filing.",
        icon: UsersRound,
    },
    {
        title: "Self-Employed Professionals",
        description:
            "Tax and accounting support for freelancers, independent contractors, consultants, and 1099 workers.",
        icon: BriefcaseBusiness,
    },
    {
        title: "Small Businesses",
        description:
            "Bookkeeping, payroll, business tax, and accounting support for Miami businesses that need better financial organization.",
        icon: Building2,
    },
];

const process = [
    {
        title: "Tell us what you need",
        description:
            "Start with the contact form, phone call, or email and explain whether you need tax, bookkeeping, payroll, or accounting support.",
    },
    {
        title: "We review the situation",
        description:
            "Our office helps identify what information, documents, records, or next steps may be needed based on your request.",
    },
    {
        title: "We guide the next step",
        description:
            "You receive clear direction so your financial information can be handled with better organization and less confusion.",
    },
];

const faqs = [
    {
        question: "Where is East Coast Accounting & Tax Services located?",
        answer:
            `East Coast Accounting & Tax Services is located at ${siteConfig.address.full}.`,
    },
    {
        question: "What services does East Coast Accounting & Tax Services provide?",
        answer:
            "The office provides tax preparation, bookkeeping, payroll services, business tax services, small business accounting, IRS tax help, and accounting support for individuals and businesses.",
    },
    {
        question: "Do you provide support in English and Spanish?",
        answer:
            "Yes. East Coast Accounting & Tax Services provides bilingual support in English and Spanish.",
    },
    {
        question: "Do you work with both individuals and businesses?",
        answer:
            "Yes. The office supports individuals, families, self-employed professionals, small businesses, and local employers.",
    },
];

const pageSchema = {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    name: title,
    description,
    url: `${siteUrl}/about`,
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
            "@type": "Answer",
            text: faq.answer,
        },
    })),
};
---

<MainLayout
    title={title}
    description={description}
    image="/images/og/about-og.webp"
    schema={[pageSchema, faqSchema]}
>
    <!-- About Hero -->
    <section class="accounting-grid relative isolate overflow-hidden py-16 sm:py-20 lg:py-24">
        <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
            <div class="about-kenburns-bg absolute inset-0 overflow-hidden">
                <img
                    src="/images/about/about-hero.webp"
                    alt=""
                    width="2400"
                    height="1600"
                    class="absolute inset-0 h-full min-h-full w-full min-w-full object-cover object-center"
                    loading="eager"
                    decoding="async"
                />
            </div>

            <!-- <div class="absolute inset-0 bg-[rgb(var(--color-bg)/0.8)]"></div> -->

            <!-- <div class="absolute inset-0 bg-[linear-gradient(90deg,rgb(var(--color-bg)/0.97)_0%,rgb(var(--color-bg)/0.76)_54%,rgb(var(--color-bg)/0.5)_100%)]"></div> -->

            <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_25%,rgb(var(--color-secondary)/0.12),transparent_34rem),radial-gradient(circle_at_80%_30%,rgb(var(--color-primary)/0.1),transparent_32rem)]"></div>

            <div class="absolute left-[-12rem] top-20 h-[32rem] w-[32rem] rounded-full bg-[rgb(var(--color-secondary)/0.14)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-[-8rem] h-[34rem] w-[34rem] rounded-full bg-[rgb(var(--color-primary)/0.13)] blur-3xl"></div>

            <div class="absolute inset-x-0 bottom-0 h-56 bg-[linear-gradient(to_top,rgb(var(--color-bg)),transparent)]"></div>
        </div>

        <div class="container-wide">
            <div class="grid gap-12 lg:grid-cols-[0.95fr_0.75fr] lg:items-center">
                <div class="relative z-10 max-w-3xl">
                    <Badge variant="blue" icon={Building2} glow>
                        Miami Accounting Office
                    </Badge>

                    <h1 class="mt-6 text-balance font-inter text-4xl font-extrabold tracking-[-0.065em] text-[rgb(var(--color-heading))] sm:text-5xl lg:text-6xl">
                        Accounting support built around
                        <span class="gradient-text block">clarity and organization.</span>
                    </h1>

                    <p class="lead-text mt-6">
                        East Coast Accounting & Tax Services helps Miami individuals, families, self-employed professionals, and businesses with tax preparation, bookkeeping, payroll, and accounting support.
                    </p>

                    <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                        <CTAButton href="/contact" icon={Send} size="lg">
                            Contact Our Office
                        </CTAButton>

                        <CTAButton
                            href="/services"
                            variant="secondary"
                            icon={ArrowUpRight}
                            size="lg"
                        >
                            View Services
                        </CTAButton>
                    </div>

                    <div class="mt-8 grid gap-3 sm:grid-cols-3">
                        {
                            [
                                {
                                    label: "Miami, FL",
                                    detail: "Local office",
                                    icon: MapPin,
                                },
                                {
                                    label: "EN / ES",
                                    detail: "Bilingual support",
                                    icon: Languages,
                                },
                                {
                                    label: "Year-round",
                                    detail: "Tax and accounting help",
                                    icon: ShieldCheck,
                                },
                            ].map((item) => {
                                const Icon = item.icon;

                                return (
                                    <div class="glass-panel rounded-[1.35rem] p-4">
                                        <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                                            <Icon class="h-5 w-5" />
                                        </span>

                                        <p class="mt-3 font-inter text-sm font-extrabold text-[rgb(var(--color-heading))]">
                                            {item.label}
                                        </p>

                                        <p class="mt-1 text-xs leading-5 text-[rgb(var(--color-text-soft))]">
                                            {item.detail}
                                        </p>
                                    </div>
                                );
                            })
                        }
                    </div>
                </div>

                <!-- Floating visual -->
                <div class="relative hidden md:block">
                    <div class="pointer-events-none absolute inset-0 rounded-full bg-[radial-gradient(circle,rgb(var(--color-secondary)/0.18),transparent_62%)] blur-3xl"></div>

                    <div class="pointer-events-none absolute left-1/2 top-1/2 h-64 w-64 -translate-x-1/2 -translate-y-1/2 rounded-full border border-[rgb(var(--color-secondary)/0.18)]"></div>

                    <img
                        src="/images/about/about-floating-office.webp"
                        alt=""
                        width="900"
                        height="700"
                        loading="eager"
                        decoding="async"
                        class="about-floating-image relative z-10 mx-auto w-full max-w-[32rem] object-contain drop-shadow-[0_34px_80px_rgb(5_162_236/0.24)]"
                    />

                    <div class="absolute right-6 top-8 z-20 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.82)] px-4 py-2 shadow-soft backdrop-blur">
                        <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-secondary))]">
                            Miami Office
                        </span>
                    </div>

                    <div class="absolute bottom-8 left-4 z-20 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.82)] px-4 py-2 shadow-soft backdrop-blur">
                        <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-heading))]">
                            Taxes · Books · Payroll
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- About Intro -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-1/2 top-0 h-px w-[min(92%,1180px)] -translate-x-1/2 bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.55),transparent)]"></div>

            <div class="absolute left-[-14rem] top-24 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-10 h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.1)] blur-3xl"></div>
        </div>

        <div class="container-wide">
            <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
                <SectionHeading
                    eyebrow="Who We Are"
                    title="A local Miami office helping clients feel more prepared."
                    highlight="more prepared"
                    description="East Coast Accounting & Tax Services provides practical financial support for clients who want taxes, books, payroll, and records to feel easier to understand and manage."
                />

                <div class="grid gap-5">
                    <div class="glass-panel overflow-hidden rounded-[2.25rem] p-5">
                        <div class="rounded-[1.85rem] border border-[rgb(var(--color-border)/0.68)] bg-[rgb(var(--color-surface)/0.72)] p-6">
                            <Badge variant="blue" icon={Sparkles}>
                                About the Office
                            </Badge>

                            <h2 class="mt-5 font-inter text-3xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                Support for personal and business financial needs.
                            </h2>

                            <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-soft))] md:text-base">
                                Located in Miami, East Coast Accounting & Tax Services works with individuals, families, self-employed professionals, and business owners who need reliable help with tax preparation, bookkeeping, payroll, business tax services, and accounting support.
                            </p>

                            <p class="mt-4 text-sm leading-7 text-[rgb(var(--color-text-soft))] md:text-base">
                                The goal is to make financial tasks feel more organized, easier to understand, and better connected throughout the year — not only during tax season.
                            </p>

                            <div class="mt-8 grid gap-3 sm:grid-cols-2">
                                {
                                    [
                                        "Tax preparation for individuals and businesses",
                                        "Bookkeeping and business record organization",
                                        "Payroll support for local employers",
                                        "Bilingual English and Spanish assistance",
                                    ].map((item) => (
                                        <div class="flex items-start gap-3 rounded-[1.35rem] border border-[rgb(var(--color-border)/0.58)] bg-[rgb(var(--color-bg)/0.42)] p-4">
                                            <CheckCircle2 class="mt-0.5 h-4.5 w-4.5 shrink-0 text-[rgb(var(--color-secondary))]" />
                                            <span class="text-sm font-bold leading-6 text-[rgb(var(--color-text))]">
                                                {item}
                                            </span>
                                        </div>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Values -->
    <section class="section-shell relative overflow-hidden">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-[-12rem] top-20 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.09)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-10 h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.09)] blur-3xl"></div>
        </div>

        <div class="container-wide">
            <SectionHeading
                eyebrow="How We Help"
                title="Built around clarity, organization, and local support."
                highlight="clarity, organization,"
                description="The office focuses on practical support that helps clients understand what is needed and feel more confident about their next step."
            />

            <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
                {
                    values.map((value) => {
                        const Icon = value.icon;

                        return (
                            <article class="group glow-card card-hover relative overflow-hidden p-6">
                                <div class="pointer-events-none absolute right-[-4rem] top-[-4rem] h-40 w-40 rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-2xl opacity-0 transition duration-300 group-hover:opacity-100"></div>

                                <div class="relative z-10">
                                    <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                        <Icon class="h-7 w-7" />
                                    </span>

                                    <h3 class="mt-5 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                        {value.title}
                                    </h3>

                                    <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                        {value.description}
                                    </p>
                                </div>
                            </article>
                        );
                    })
                }
            </div>
        </div>
    </section>

    <!-- Who We Help -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="container-wide">
            <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
                <SectionHeading
                    eyebrow="Who We Help"
                    title="Support for individuals, families, and local businesses."
                    highlight="individuals, families,"
                    description="East Coast Accounting & Tax Services supports a wide range of Miami clients with tax preparation, bookkeeping, payroll, and accounting needs."
                />

                <div class="grid gap-5">
                    {
                        whoWeHelp.map((item) => {
                            const Icon = item.icon;

                            return (
                                <article class="group glow-card card-hover p-6">
                                    <div class="relative z-10 flex gap-5">
                                        <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                            <Icon class="h-7 w-7" />
                                        </span>

                                        <div>
                                            <h3 class="font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                                {item.title}
                                            </h3>

                                            <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                                {item.description}
                                            </p>
                                        </div>
                                    </div>
                                </article>
                            );
                        })
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Services -->
    <section class="section-shell relative overflow-hidden">
        <div class="container-wide">
            <SectionHeading
                eyebrow="Core Services"
                title="Accounting support connected across the services clients need most."
                highlight="services clients need"
                description="From tax preparation to bookkeeping and payroll, East Coast Accounting & Tax Services helps keep related financial needs organized in one place."
            />

            <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
                {
                    services.map((service) => {
                        const Icon = service.icon;

                        return (
                            <a
                                href={service.href}
                                class="group glow-card card-hover relative overflow-hidden p-6"
                            >
                                <div class="pointer-events-none absolute right-[-4rem] top-[-4rem] h-40 w-40 rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-2xl opacity-0 transition duration-300 group-hover:opacity-100"></div>

                                <div class="relative z-10">
                                    <div class="flex items-start justify-between gap-4">
                                        <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                            <Icon class="h-7 w-7" />
                                        </span>

                                        <ArrowUpRight class="h-5 w-5 text-[rgb(var(--color-secondary))] transition group-hover:-translate-y-0.5 group-hover:translate-x-0.5" />
                                    </div>

                                    <h3 class="mt-5 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                        {service.label}
                                    </h3>

                                    <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                        Learn more about {service.label.toLowerCase()} and how the office can help.
                                    </p>
                                </div>
                            </a>
                        );
                    })
                }
            </div>
        </div>
    </section>

    <!-- Process -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="container-wide">
            <SectionHeading
                eyebrow="Simple Process"
                title="A clear path from first contact to next steps."
                highlight="clear path"
                description="Whether you need tax, bookkeeping, payroll, or accounting support, the first step is sharing what kind of help you need."
            />

            <div class="mt-12 grid gap-5 md:grid-cols-3">
                {
                    process.map((step, index) => (
                        <article class="glass-panel relative overflow-hidden rounded-[2rem] p-6">
                            <div class="pointer-events-none absolute right-[-3rem] top-[-3rem] h-32 w-32 rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-2xl"></div>

                            <div class="relative">
                                <div class="flex items-center justify-between gap-4">
                                    <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                                        <MessageSquareText class="h-7 w-7" />
                                    </span>

                                    <span class="font-inter text-5xl font-extrabold tracking-[-0.08em] text-[rgb(var(--color-secondary)/0.22)]">
                                        {String(index + 1).padStart(2, "0")}
                                    </span>
                                </div>

                                <h3 class="mt-5 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                    {step.title}
                                </h3>

                                <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                    {step.description}
                                </p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Office Info -->
    <section class="section-shell accounting-grid relative isolate overflow-hidden">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-[-12rem] top-20 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-10 h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.11)] blur-3xl"></div>
        </div>

        <div class="container-wide">
            <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
                <SectionHeading
                    eyebrow="Office Information"
                    title="Contact our Miami accounting office."
                    highlight="Miami accounting office"
                    description="East Coast Accounting & Tax Services is based in Miami and supports clients across Miami-Dade County and nearby South Florida communities."
                />

                <div class="glass-panel overflow-hidden rounded-[2.25rem] p-5 shadow-card">
                    <div class="rounded-[1.85rem] bg-[linear-gradient(135deg,rgb(var(--color-primary))_0%,rgb(var(--color-secondary))_100%)] p-6 text-white shadow-blue">
                        <Badge
                            variant="outline"
                            class="border-white/25 bg-white/10 !text-white"
                            icon={Building2}
                        >
                            Miami Office
                        </Badge>

                        <h2 class="mt-5 font-inter text-3xl font-extrabold tracking-[-0.055em] !text-white md:text-4xl">
                            {siteConfig.name}
                        </h2>

                        <div class="mt-6 grid gap-4">
                            <a
                                href="https://www.google.com/maps/search/?api=1&query=6874%20SW%208th%20St%2C%20Miami%2C%20FL%2033144"
                                target="_blank"
                                rel="noreferrer"
                                class="flex items-start gap-3 text-sm font-bold leading-6 !text-white/82 transition hover:!text-white"
                            >
                                <MapPin class="mt-0.5 h-4.5 w-4.5 shrink-0" />
                                <span>{siteConfig.address.full}</span>
                            </a>

                            <a
                                href={siteConfig.contact.phoneHref}
                                class="flex items-center gap-3 text-sm font-bold !text-white/82 transition hover:!text-white"
                            >
                                <Phone class="h-4.5 w-4.5 shrink-0" />
                                {siteConfig.contact.phone}
                            </a>

                            <a
                                href={siteConfig.contact.emailHref}
                                class="flex items-center gap-3 text-sm font-bold !text-white/82 transition hover:!text-white"
                            >
                                <Mail class="h-4.5 w-4.5 shrink-0" />
                                {siteConfig.contact.email}
                            </a>

                            <div class="flex items-center gap-3 text-sm font-bold !text-white/82">
                                <Clock3 class="h-4.5 w-4.5 shrink-0" />
                                {siteConfig.hours.label}
                            </div>
                        </div>

                        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                            <CTAButton href="/contact" variant="dark" icon={Send}>
                                Contact Our Office
                            </CTAButton>

                            <CTAButton
                                href="https://www.google.com/maps/search/?api=1&query=6874%20SW%208th%20St%2C%20Miami%2C%20FL%2033144"
                                variant="ghost"
                                icon={ArrowUpRight}
                                class="border-white/20 bg-white/10 text-white hover:border-white/35 hover:bg-white/16"
                            >
                                Open Map
                            </CTAButton>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="container-wide">
            <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
                <div>
                    <SectionHeading
                        eyebrow="About FAQ"
                        title="Common questions about East Coast Accounting."
                        highlight="questions"
                        description="Helpful answers about the office, services, bilingual support, and who we help."
                    />

                    <div class="mt-8">
                        <CTAButton href="/resources/faq" variant="secondary" icon={ArrowUpRight}>
                            View Full FAQ
                        </CTAButton>
                    </div>
                </div>

                <div class="grid gap-4">
                    {
                        faqs.map((faq, index) => (
                            <article class="rounded-[1.6rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-5 shadow-soft backdrop-blur">
                                <div class="flex gap-4">
                                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] font-inter text-xs font-extrabold text-[rgb(var(--color-secondary))]">
                                        {String(index + 1).padStart(2, "0")}
                                    </span>

                                    <div>
                                        <h3 class="font-inter text-lg font-extrabold tracking-[-0.045em] text-[rgb(var(--color-heading))]">
                                            {faq.question}
                                        </h3>

                                        <p class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                            {faq.answer}
                                        </p>
                                    </div>
                                </div>
                            </article>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="section-shell relative isolate overflow-hidden">
        <div class="container-wide">
            <div class="relative overflow-hidden rounded-[2.5rem] border border-[rgb(var(--color-border)/0.72)] bg-[linear-gradient(135deg,rgb(var(--color-primary))_0%,rgb(var(--color-secondary))_100%)] p-6 text-white shadow-blue sm:p-8 lg:p-10">
                <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_0%,rgba(255,255,255,0.3),transparent_34%),radial-gradient(circle_at_92%_100%,rgba(255,255,255,0.16),transparent_34%)]"></div>

                <div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
                    <div>
                        <Badge
                            variant="outline"
                            class="border-white/25 bg-white/10 !text-white"
                            icon={MessageSquareText}
                        >
                            Ready to Get Started?
                        </Badge>

                        <h2 class="mt-5 max-w-4xl font-inter text-3xl font-extrabold tracking-[-0.055em] !text-white md:text-4xl">
                            Contact East Coast Accounting & Tax Services today.
                        </h2>

                        <p class="mt-4 max-w-3xl text-sm leading-7 !text-white/78 md:text-base">
                            Tell us whether you need help with tax preparation, bookkeeping, payroll, business tax services, IRS questions, or general accounting support.
                        </p>
                    </div>

                    <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
                        <CTAButton href="/contact" variant="dark" icon={Send}>
                            Contact Our Office
                        </CTAButton>

                        <CTAButton
                            href={siteConfig.contact.phoneHref}
                            variant="ghost"
                            icon={Phone}
                            class="border-white/20 bg-white/10 text-white hover:border-white/35 hover:bg-white/16"
                        >
                            {siteConfig.contact.phone}
                        </CTAButton>
                    </div>
                </div>
            </div>
        </div>
    </section>
</MainLayout>

