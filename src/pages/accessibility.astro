---
import {
    ArrowLeft,
    CheckCircle2,
    Clock3,
    Eye,
    Keyboard,
    Mail,
    MapPin,
    MonitorSmartphone,
    Phone,
    Send,
    ShieldCheck,
    Sparkles,
    UserCheck,
    Volume2,
} from "@lucide/astro";

import MainLayout from "../layouts/MainLayout.astro";
import CTAButton from "../components/ui/CTAButton.astro";
import Badge from "../components/ui/Badge.astro";
import { siteConfig } from "../data/site";

const title = "Accessibility Statement";
const description =
    "Read the accessibility statement for the East Coast Accounting & Tax Services website, including our commitment to providing a usable experience for all visitors.";

const effectiveDate = "May 2026";

const accessibilityHighlights = [
    {
        title: "Usable design",
        description:
            "The website is designed with readability, contrast, responsive layouts, and clear navigation in mind.",
        icon: MonitorSmartphone,
    },
    {
        title: "Keyboard awareness",
        description:
            "Interactive website elements should be reasonably accessible to visitors using keyboard navigation.",
        icon: Keyboard,
    },
    {
        title: "Clear content",
        description:
            "The website uses structured sections, headings, buttons, and links to help visitors find information more easily.",
        icon: Eye,
    },
];

const sections = [
    {
        title: "1. Our Accessibility Commitment",
        body: [
            "East Coast Accounting & Tax Services is committed to providing a website experience that is accessible and usable for as many visitors as possible.",
            "Our goal is to make information about tax preparation, bookkeeping, payroll, accounting services, locations, resources, and contact options easier to access across different devices and user needs.",
        ],
    },
    {
        title: "2. Accessibility Efforts",
        body: [
            "This website is designed with accessibility considerations such as readable typography, responsive layouts, sufficient visual contrast, descriptive links, structured headings, and clear call-to-action buttons.",
            "We aim to support visitors using desktop computers, tablets, mobile devices, keyboards, screen readers, and other assistive technologies where reasonably possible.",
        ],
    },
    {
        title: "3. Ongoing Improvements",
        body: [
            "Accessibility is an ongoing effort. As the website grows, East Coast Accounting & Tax Services may continue improving page structure, navigation, content clarity, form usability, contrast, and compatibility with assistive tools.",
            "Website content, design, and functionality may be reviewed and updated over time to improve usability for all visitors.",
        ],
    },
    {
        title: "4. Third-Party Content and Tools",
        body: [
            "This website may include links to third-party platforms, maps, embedded tools, scheduling systems, form processors, analytics tools, or other external services.",
            "East Coast Accounting & Tax Services does not fully control the accessibility of third-party websites or tools, but we encourage visitors to contact us if they experience difficulty accessing important information connected to our services.",
        ],
    },
    {
        title: "5. Known Limitations",
        body: [
            "Although we work to make the website accessible, some content or functionality may not always meet every accessibility need or assistive technology configuration.",
            "If you encounter an issue, we welcome feedback so we can better understand the problem and work toward a reasonable improvement or alternative way to provide the information.",
        ],
    },
    {
        title: "6. Requesting Assistance",
        body: [
            "If you have difficulty accessing any part of this website, need help using a form, or need information in another format, please contact East Coast Accounting & Tax Services.",
            `You may contact the office by phone at ${siteConfig.contact.phone}, by email at ${siteConfig.contact.email}, or by using the contact page.`,
        ],
    },
    {
        title: "7. Feedback",
        body: [
            "When reporting an accessibility issue, it is helpful to include the page URL, a description of the problem, the device or browser you were using, and the assistive technology involved, if applicable.",
            "We will make reasonable efforts to review accessibility feedback and respond as appropriate.",
        ],
    },
    {
        title: "8. Contact Information",
        body: [
            `For accessibility questions or support, contact East Coast Accounting & Tax Services at ${siteConfig.contact.email} or ${siteConfig.contact.phone}.`,
        ],
    },
];

const featureList = [
    {
        label: "Responsive layouts",
        icon: MonitorSmartphone,
    },
    {
        label: "Readable content",
        icon: Eye,
    },
    {
        label: "Keyboard-friendly intent",
        icon: Keyboard,
    },
    {
        label: "Clear contact options",
        icon: Phone,
    },
];

const pageSchema = {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    description,
    url: `${siteConfig.url.replace(/\/$/, "")}/accessibility`,
};
---

<MainLayout
    title={title}
    description={description}
    noindex={false}
    schema={pageSchema}
>
    <section class="section-shell accounting-grid relative isolate overflow-hidden">
        <!-- Background effects -->
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-[-12rem] top-20 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.12)] blur-3xl"></div>

            <div class="absolute bottom-[-12rem] right-[-10rem] h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.13)] blur-3xl"></div>

            <div class="absolute inset-x-0 bottom-0 h-48 bg-[linear-gradient(to_top,rgb(var(--color-bg)),transparent)]"></div>
        </div>

        <div class="container-narrow">
            <a
                href="/"
                class="mb-6 inline-flex items-center gap-2 font-inter text-sm font-extrabold text-[rgb(var(--color-secondary))] transition hover:gap-3"
            >
                <ArrowLeft class="h-4 w-4" />
                Back to Home
            </a>

            <div class="glass-panel relative overflow-hidden rounded-[2.5rem] p-5 shadow-card sm:p-8 lg:p-10">
                <div class="pointer-events-none absolute inset-x-10 top-0 h-px bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.8),transparent)]"></div>

                <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgb(var(--color-secondary)/0.1),transparent_34rem)]"></div>

                <div class="relative">
                    <Badge variant="blue" icon={ShieldCheck} glow>
                        Website Accessibility
                    </Badge>

                    <h1 class="mt-6 text-balance font-inter text-4xl font-extrabold tracking-[-0.065em] text-[rgb(var(--color-heading))] sm:text-5xl lg:text-6xl">
                        Accessibility Statement
                    </h1>

                    <p class="lead-text mt-6">
                        East Coast Accounting & Tax Services is committed to making this website easier to use, read, and navigate for all visitors.
                    </p>

                    <div class="mt-8 flex flex-wrap gap-3">
                        <div class="inline-flex items-center gap-2 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] px-4 py-2 shadow-soft backdrop-blur">
                            <Clock3 class="h-4 w-4 text-[rgb(var(--color-secondary))]" />
                            <span class="font-inter text-sm font-bold text-[rgb(var(--color-heading))]">
                                Effective: {effectiveDate}
                            </span>
                        </div>

                        <div class="inline-flex items-center gap-2 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] px-4 py-2 shadow-soft backdrop-blur">
                            <UserCheck class="h-4 w-4 text-[rgb(var(--color-secondary))]" />
                            <span class="font-inter text-sm font-bold text-[rgb(var(--color-heading))]">
                                Applies to website visitors
                            </span>
                        </div>
                    </div>

                    <div class="mt-10 grid gap-4 md:grid-cols-3">
                        {
                            accessibilityHighlights.map((item) => {
                                const Icon = item.icon;

                                return (
                                    <article class="rounded-[1.6rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-5 shadow-soft backdrop-blur">
                                        <span class="flex h-12 w-12 items-center justify-center rounded-[1.1rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                                            <Icon class="h-6 w-6" />
                                        </span>

                                        <h2 class="mt-4 font-inter text-lg font-extrabold tracking-[-0.045em] text-[rgb(var(--color-heading))]">
                                            {item.title}
                                        </h2>

                                        <p class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                            {item.description}
                                        </p>
                                    </article>
                                );
                            })
                        }
                    </div>
                </div>
            </div>

            <!-- Accessibility Features Strip -->
            <div class="mt-8 overflow-hidden rounded-[2rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.74)] p-5 shadow-soft backdrop-blur sm:p-6">
                <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                    {
                        featureList.map((feature) => {
                            const Icon = feature.icon;

                            return (
                                <div class="rounded-[1.35rem] border border-[rgb(var(--color-border)/0.64)] bg-[rgb(var(--color-bg)/0.36)] p-4">
                                    <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                                        <Icon class="h-5 w-5" />
                                    </span>

                                    <p class="mt-3 font-inter text-sm font-extrabold text-[rgb(var(--color-heading))]">
                                        {feature.label}
                                    </p>
                                </div>
                            );
                        })
                    }
                </div>
            </div>

            <!-- Statement Content -->
            <div class="mt-8 rounded-[2.25rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.74)] p-5 shadow-soft backdrop-blur sm:p-8">
                <p class="rounded-[1.5rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-bg)/0.42)] p-4 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                    <strong class="text-[rgb(var(--color-heading))]">Important:</strong>
                    This Accessibility Statement describes the website’s accessibility commitment and feedback process. If you need assistance accessing information, please contact the office directly.
                </p>

                <div class="mt-8 grid gap-6">
                    {
                        sections.map((section) => (
                            <article class="rounded-[1.6rem] border border-[rgb(var(--color-border)/0.64)] bg-[rgb(var(--color-bg)/0.36)] p-5">
                                <h2 class="font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                    {section.title}
                                </h2>

                                <div class="mt-4 grid gap-4">
                                    {
                                        section.body.map((paragraph) => (
                                            <p class="text-sm leading-7 text-[rgb(var(--color-text-soft))] md:text-base">
                                                {paragraph}
                                            </p>
                                        ))
                                    }
                                </div>
                            </article>
                        ))
                    }
                </div>
            </div>

            <!-- Contact Strip -->
            <div class="mt-8 overflow-hidden rounded-[2rem] border border-[rgb(var(--color-border)/0.72)] bg-[linear-gradient(135deg,rgb(var(--color-primary))_0%,rgb(var(--color-secondary))_100%)] p-6 text-white shadow-blue md:p-8">
                <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
                    <div>
                        <Badge
                            variant="outline"
                            class="border-white/25 bg-white/10 !text-white"
                            icon={Sparkles}
                        >
                            Need Accessibility Help?
                        </Badge>

                        <h2 class="mt-5 max-w-3xl font-inter text-3xl font-extrabold tracking-[-0.055em] !text-white md:text-4xl">
                            Contact our Miami office if you need help accessing website information.
                        </h2>

                        <div class="mt-5 grid gap-3 text-sm font-bold !text-white/82">
                            <a
                                href={siteConfig.contact.phoneHref}
                                class="flex items-center gap-3 transition hover:!text-white"
                            >
                                <Phone class="h-4.5 w-4.5 shrink-0" />
                                {siteConfig.contact.phone}
                            </a>

                            <a
                                href={siteConfig.contact.emailHref}
                                class="flex items-center gap-3 transition hover:!text-white"
                            >
                                <Mail class="h-4.5 w-4.5 shrink-0" />
                                {siteConfig.contact.email}
                            </a>

                            <div class="flex items-start gap-3">
                                <MapPin class="mt-0.5 h-4.5 w-4.5 shrink-0" />
                                <span>{siteConfig.address.full}</span>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
                        <CTAButton href="/contact" variant="dark" icon={Send}>
                            Contact Our Office
                        </CTAButton>

                        <CTAButton
                            href="/privacy-policy"
                            variant="ghost"
                            class="border-white/20 bg-white/10 text-white hover:border-white/35 hover:bg-white/16"
                        >
                            Privacy Policy
                        </CTAButton>
                    </div>
                </div>
            </div>

            <!-- Related Legal Links -->
            <div class="mt-8 grid gap-4 sm:grid-cols-2">
                {
                    [
                        {
                            label: "Privacy Policy",
                            href: "/privacy-policy",
                            description:
                                "Read how website information may be collected, used, and protected.",
                        },
                        {
                            label: "Terms of Service",
                            href: "/terms-of-service",
                            description:
                                "Review general terms for using this website and requesting information.",
                        },
                    ].map((item) => (
                        <a
                            href={item.href}
                            class="group rounded-[1.6rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-5 shadow-soft backdrop-blur transition duration-300 hover:-translate-y-1 hover:border-[rgb(var(--color-secondary)/0.42)]"
                        >
                            <div class="flex items-start gap-4">
                                <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                                    <CheckCircle2 class="h-5 w-5" />
                                </span>

                                <span>
                                    <span class="block font-inter text-lg font-extrabold text-[rgb(var(--color-heading))]">
                                        {item.label}
                                    </span>

                                    <span class="mt-1 block text-sm leading-6 text-[rgb(var(--color-text-soft))]">
                                        {item.description}
                                    </span>
                                </span>
                            </div>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>
</MainLayout>