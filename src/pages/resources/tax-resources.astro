---
import {
    ArrowLeft,
    ArrowUpRight,
    BookOpenCheck,
    BriefcaseBusiness,
    CalendarDays,
    CheckCircle2,
    ClipboardCheck,
    FileCheck2,
    FileText,
    FolderCheck,
    HelpCircle,
    MessageSquareText,
    ReceiptText,
    Send,
    Sparkles,
    WalletCards,
} from "@lucide/astro";

import MainLayout from "../../layouts/MainLayout.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";
import CTAButton from "../../components/ui/CTAButton.astro";
import Badge from "../../components/ui/Badge.astro";

import { siteConfig } from "../../data/site";

const title = "Tax Resources";
const description =
    "Helpful tax preparation resources, document checklists, filing reminders, and organization tips for individuals and businesses in Miami, FL.";

const siteUrl = siteConfig.url.replace(/\/$/, "");

const personalTaxDocuments = [
    "W-2 forms from employers",
    "1099 forms for contract, freelance, or other income",
    "Government-issued ID",
    "Social Security numbers or taxpayer information",
    "Prior-year tax return, if available",
    "Mortgage interest statements, if applicable",
    "Education-related tax forms, if applicable",
    "Health insurance or marketplace forms, if applicable",
];

const businessTaxDocuments = [
    "Income and sales records",
    "Business expense records",
    "Bank and credit card statements",
    "Payroll records",
    "1099 contractor information",
    "Bookkeeping reports",
    "Prior-year business tax return",
    "Business entity information",
];

const organizationTips = [
    {
        title: "Separate personal and business records",
        description:
            "Keeping business income, expenses, bank activity, and receipts separate from personal records can make tax preparation easier to review.",
        icon: BriefcaseBusiness,
    },
    {
        title: "Keep receipts and proof of expenses",
        description:
            "Organized receipts, invoices, statements, and payment records can help support income and expense details when preparing taxes.",
        icon: ReceiptText,
    },
    {
        title: "Review bookkeeping before tax season",
        description:
            "Clean bookkeeping helps business owners understand income, expenses, payroll details, and what may still need attention.",
        icon: BookOpenCheck,
    },
    {
        title: "Ask early when something is unclear",
        description:
            "If you are unsure which forms or records are needed, contacting the office before deadlines can help reduce last-minute stress.",
        icon: HelpCircle,
    },
];

const taxResourceCards = [
    {
        title: "For Individuals & Families",
        description:
            "Personal tax preparation usually starts with income forms, personal records, prior-year information, and any documents connected to deductions or credits.",
        icon: FileText,
        items: [
            "Gather income forms",
            "Review prior-year tax return",
            "Organize personal tax documents",
            "Ask about missing forms early",
        ],
    },
    {
        title: "For Business Owners",
        description:
            "Business tax preparation often depends on clean bookkeeping, income reports, payroll records, expenses, contractor details, and entity information.",
        icon: BriefcaseBusiness,
        items: [
            "Review business income",
            "Organize expenses",
            "Prepare payroll records",
            "Check bookkeeping reports",
        ],
    },
    {
        title: "For Self-Employed Clients",
        description:
            "Self-employed professionals often need to organize 1099 income, business expenses, mileage records, software costs, and other work-related documents.",
        icon: WalletCards,
        items: [
            "Collect 1099 income forms",
            "Track work-related expenses",
            "Organize records by category",
            "Review business activity",
        ],
    },
];

const timelineItems = [
    {
        title: "Before tax season",
        description:
            "Start organizing income forms, business records, receipts, and prior-year documents before deadlines get close.",
        icon: CalendarDays,
    },
    {
        title: "During preparation",
        description:
            "Review what is complete, what is missing, and whether personal, business, bookkeeping, or payroll details need clarification.",
        icon: ClipboardCheck,
    },
    {
        title: "After filing",
        description:
            "Keep copies of important tax documents and continue organizing records throughout the year for next season.",
        icon: FolderCheck,
    },
];

const faqs = [
    {
        question: "What documents should I bring for tax preparation?",
        answer:
            "The documents needed depend on your situation, but common items include W-2s, 1099s, prior-year tax returns, ID information, income records, expense records, and any forms related to deductions, credits, business activity, or payroll.",
    },
    {
        question: "Can East Coast Accounting help if my business records are not organized?",
        answer:
            "Yes. East Coast Accounting & Tax Services can help review your current records and guide you toward better bookkeeping, tax preparation, or accounting support.",
    },
    {
        question: "Do business owners need bookkeeping before filing taxes?",
        answer:
            "Clean bookkeeping can make business tax preparation easier because it helps organize income, expenses, payroll information, and other records needed during filing.",
    },
    {
        question: "Do you provide tax support in English and Spanish?",
        answer:
            "Yes. East Coast Accounting & Tax Services provides bilingual support in English and Spanish for Miami individuals and businesses.",
    },
];

const taxResourcesSchema = {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    description,
    url: `${siteUrl}/resources/tax-resources`,
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
            "@type": "Answer",
            text: faq.answer,
        },
    })),
};
---

<MainLayout
    title={title}
    description={description}
    image="/images/og/tax-resources-og.webp"
    schema={[taxResourcesSchema, faqSchema]}
>
    <!-- Tax Resources Hero -->
    <section class="accounting-grid relative isolate overflow-hidden py-16 sm:py-20 lg:py-24">
        <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
            <div class="tax-resources-kenburns-bg absolute inset-0 overflow-hidden">
                <img
                    src="/images/resources/tax-resources-hero.webp"
                    alt=""
                    width="2400"
                    height="1600"
                    class="absolute inset-0 h-full min-h-full w-full min-w-full object-cover object-center"
                    loading="eager"
                    decoding="async"
                />
            </div>

            <!-- <div class="absolute inset-0 bg-[rgb(var(--color-bg)/0.8)]"></div> -->

            <!-- <div class="absolute inset-0 bg-[linear-gradient(90deg,rgb(var(--color-bg)/0.97)_0%,rgb(var(--color-bg)/0.76)_54%,rgb(var(--color-bg)/0.5)_100%)]"></div> -->

            <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_25%,rgb(var(--color-secondary)/0.12),transparent_34rem),radial-gradient(circle_at_80%_30%,rgb(var(--color-primary)/0.1),transparent_32rem)]"></div>

            <div class="absolute left-[-12rem] top-20 h-[32rem] w-[32rem] rounded-full bg-[rgb(var(--color-secondary)/0.14)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-[-8rem] h-[34rem] w-[34rem] rounded-full bg-[rgb(var(--color-primary)/0.13)] blur-3xl"></div>

            <div class="absolute inset-x-0 bottom-0 h-56 bg-[linear-gradient(to_top,rgb(var(--color-bg)),transparent)]"></div>
        </div>

        <div class="container-wide">
            <div class="grid gap-12 lg:grid-cols-[0.95fr_0.75fr] lg:items-center">
                <div class="relative z-10 max-w-3xl">
                    <a
                        href="/resources"
                        class="mb-6 inline-flex items-center gap-2 font-inter text-sm font-extrabold text-[rgb(var(--color-secondary))] transition hover:gap-3"
                    >
                        <ArrowLeft class="h-4 w-4" />
                        Back to Resources
                    </a>

                    <Badge variant="blue" icon={ReceiptText} glow>
                        Tax Preparation Guidance
                    </Badge>

                    <h1 class="mt-6 text-balance font-inter text-4xl font-extrabold tracking-[-0.065em] text-[rgb(var(--color-heading))] sm:text-5xl lg:text-6xl">
                        Tax resources to help you stay
                        <span class="gradient-text block">organized before filing.</span>
                    </h1>

                    <p class="lead-text mt-6">
                        Use these tax preparation reminders to understand what documents may be needed, how to organize your records, and when to contact East Coast Accounting & Tax Services for support.
                    </p>

                    <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                        <CTAButton href="/contact" icon={Send} size="lg">
                            Contact Our Office
                        </CTAButton>

                        <CTAButton
                            href="/services/tax-preparation"
                            variant="secondary"
                            icon={ArrowUpRight}
                            size="lg"
                        >
                            View Tax Preparation
                        </CTAButton>
                    </div>

                    <div class="mt-8 grid gap-3 sm:grid-cols-3">
                        {
                            [
                                {
                                    label: "Individuals",
                                    detail: "Personal tax reminders",
                                    icon: FileText,
                                },
                                {
                                    label: "Businesses",
                                    detail: "Records and reports",
                                    icon: BriefcaseBusiness,
                                },
                                {
                                    label: "Bookkeeping",
                                    detail: "Cleaner organization",
                                    icon: BookOpenCheck,
                                },
                            ].map((item) => {
                                const Icon = item.icon;

                                return (
                                    <div class="glass-panel rounded-[1.35rem] p-4">
                                        <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                                            <Icon class="h-5 w-5" />
                                        </span>

                                        <p class="mt-3 font-inter text-sm font-extrabold text-[rgb(var(--color-heading))]">
                                            {item.label}
                                        </p>

                                        <p class="mt-1 text-xs leading-5 text-[rgb(var(--color-text-soft))]">
                                            {item.detail}
                                        </p>
                                    </div>
                                );
                            })
                        }
                    </div>
                </div>

                <!-- Floating visual -->
                <div class="relative hidden md:block">
                    <div class="pointer-events-none absolute inset-0 rounded-full bg-[radial-gradient(circle,rgb(var(--color-secondary)/0.18),transparent_62%)] blur-3xl"></div>

                    <div class="pointer-events-none absolute left-1/2 top-1/2 h-64 w-64 -translate-x-1/2 -translate-y-1/2 rounded-full border border-[rgb(var(--color-secondary)/0.18)]"></div>

                    <img
                        src="/images/resources/tax-resources-floating.webp"
                        alt=""
                        width="900"
                        height="700"
                        loading="eager"
                        decoding="async"
                        class="tax-resources-floating-image relative z-10 mx-auto w-full max-w-[32rem] object-contain drop-shadow-[0_34px_80px_rgb(5_162_236/0.24)]"
                    />

                    <div class="absolute right-6 top-8 z-20 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.82)] px-4 py-2 shadow-soft backdrop-blur">
                        <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-secondary))]">
                            Tax checklist
                        </span>
                    </div>

                    <div class="absolute bottom-8 left-4 z-20 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.82)] px-4 py-2 shadow-soft backdrop-blur">
                        <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-heading))]">
                            Documents · Records · Filing
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Tax Resource Cards -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-1/2 top-0 h-px w-[min(92%,1180px)] -translate-x-1/2 bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.55),transparent)]"></div>

            <div class="absolute left-[-14rem] top-24 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-10 h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.1)] blur-3xl"></div>
        </div>

        <div class="container-wide">
            <SectionHeading
                eyebrow="Tax Preparation Basics"
                title="Start with the records that matter most."
                highlight="records that matter"
                description="Every tax situation is different, but most clients benefit from organizing income forms, expense records, prior-year information, and any documents connected to deductions, credits, payroll, or business activity."
            />

            <div class="mt-12 grid gap-5 md:grid-cols-3">
                {
                    taxResourceCards.map((card) => {
                        const Icon = card.icon;

                        return (
                            <article class="group glow-card card-hover relative overflow-hidden p-6">
                                <div class="pointer-events-none absolute right-[-4rem] top-[-4rem] h-40 w-40 rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-2xl opacity-0 transition duration-300 group-hover:opacity-100"></div>

                                <div class="pointer-events-none absolute bottom-4 right-5 text-[rgb(var(--color-primary)/0.045)] transition group-hover:text-[rgb(var(--color-secondary)/0.075)] dark:text-white/5">
                                    <Icon class="h-24 w-24" />
                                </div>

                                <div class="relative z-10 flex h-full flex-col">
                                    <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                        <Icon class="h-7 w-7" />
                                    </span>

                                    <h2 class="mt-5 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                        {card.title}
                                    </h2>

                                    <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                        {card.description}
                                    </p>

                                    <div class="mt-6 grid gap-3">
                                        {
                                            card.items.map((item) => (
                                                <div class="flex items-start gap-3">
                                                    <CheckCircle2 class="mt-0.5 h-4.5 w-4.5 shrink-0 text-[rgb(var(--color-secondary))]" />
                                                    <span class="text-sm font-bold leading-6 text-[rgb(var(--color-text))]">
                                                        {item}
                                                    </span>
                                                </div>
                                            ))
                                        }
                                    </div>
                                </div>
                            </article>
                        );
                    })
                }
            </div>
        </div>
    </section>

    <!-- Document Checklists -->
    <section class="section-shell relative overflow-hidden">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-[-12rem] top-20 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.09)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-10 h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.09)] blur-3xl"></div>
        </div>

        <div class="container-wide">
            <div class="grid gap-10 lg:items-start">
                <SectionHeading
                    eyebrow="Document Checklist"
                    title="Common documents to organize before tax preparation."
                    highlight="documents to organize"
                    description="The documents needed can vary by client. These lists are starting points to help individuals and business owners prepare for a more organized tax process."
                />

                <div class="grid gap-5">
                    <div class="glass-panel overflow-hidden rounded-[2.25rem] p-5">
                        <div class="rounded-[1.85rem] border border-[rgb(var(--color-border)/0.68)] bg-[rgb(var(--color-surface)/0.72)] p-6">
                            <Badge variant="blue" icon={FileCheck2}>
                                Individual Tax Checklist
                            </Badge>

                            <h2 class="mt-5 font-inter text-3xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                Personal tax preparation documents
                            </h2>

                            <div class="mt-8 grid gap-3 md:grid-cols-2">
                                {
                                    personalTaxDocuments.map((item) => (
                                        <div class="flex items-start gap-3 rounded-[1.35rem] border border-[rgb(var(--color-border)/0.58)] bg-[rgb(var(--color-bg)/0.42)] p-4">
                                            <CheckCircle2 class="mt-0.5 h-4.5 w-4.5 shrink-0 text-[rgb(var(--color-secondary))]" />
                                            <span class="text-sm font-bold leading-6 text-[rgb(var(--color-text))]">
                                                {item}
                                            </span>
                                        </div>
                                    ))
                                }
                            </div>
                        </div>
                    </div>

                    <div class="glass-panel overflow-hidden rounded-[2.25rem] p-5">
                        <div class="rounded-[1.85rem] border border-[rgb(var(--color-border)/0.68)] bg-[rgb(var(--color-surface)/0.72)] p-6">
                            <Badge variant="blue" icon={BriefcaseBusiness}>
                                Business Tax Checklist
                            </Badge>

                            <h2 class="mt-5 font-inter text-3xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                Business tax preparation documents
                            </h2>

                            <div class="mt-8 grid gap-3 md:grid-cols-2">
                                {
                                    businessTaxDocuments.map((item) => (
                                        <div class="flex items-start gap-3 rounded-[1.35rem] border border-[rgb(var(--color-border)/0.58)] bg-[rgb(var(--color-bg)/0.42)] p-4">
                                            <CheckCircle2 class="mt-0.5 h-4.5 w-4.5 shrink-0 text-[rgb(var(--color-secondary))]" />
                                            <span class="text-sm font-bold leading-6 text-[rgb(var(--color-text))]">
                                                {item}
                                            </span>
                                        </div>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <p class="mt-8 rounded-[1.5rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-4 text-sm leading-7 text-[rgb(var(--color-text-soft))] shadow-soft backdrop-blur">
                <strong>Note:</strong> This page is for general organization guidance only. Your specific tax situation may require additional documents or a different approach. Contact East Coast Accounting & Tax Services for help understanding what may apply to your situation.
            </p>
        </div>
    </section>

    <!-- Organization Tips -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="container-wide">
            <div class="grid gap-10 lg:items-start">
                <SectionHeading
                    eyebrow="Better Organization"
                    title="Small habits that can make tax season easier."
                    highlight="tax season easier"
                    description="Staying organized throughout the year can make tax preparation, bookkeeping, payroll, and accounting support easier to manage."
                />

                <div class="grid gap-5 md:grid-cols-2">
                    {
                        organizationTips.map((tip) => {
                            const Icon = tip.icon;

                            return (
                                <article class="group glow-card card-hover p-6">
                                    <div class="relative z-10">
                                        <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                            <Icon class="h-7 w-7" />
                                        </span>

                                        <h3 class="mt-5 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                            {tip.title}
                                        </h3>

                                        <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                            {tip.description}
                                        </p>
                                    </div>
                                </article>
                            );
                        })
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Timeline -->
    <section class="section-shell relative overflow-hidden">
        <div class="container-wide">
            <SectionHeading
                eyebrow="When to Prepare"
                title="A simple tax preparation timeline."
                highlight="timeline"
                description="Tax preparation becomes easier when documents, questions, and records are organized before the last minute."
            />

            <div class="mt-12 grid gap-5 md:grid-cols-3">
                {
                    timelineItems.map((item, index) => {
                        const Icon = item.icon;

                        return (
                            <article class="glass-panel relative overflow-hidden rounded-[2rem] p-6">
                                <div class="pointer-events-none absolute right-[-3rem] top-[-3rem] h-32 w-32 rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-2xl"></div>

                                <div class="relative">
                                    <div class="flex items-center justify-between gap-4">
                                        <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                                            <Icon class="h-7 w-7" />
                                        </span>

                                        <span class="font-inter text-5xl font-extrabold tracking-[-0.08em] text-[rgb(var(--color-secondary)/0.22)]">
                                            {String(index + 1).padStart(2, "0")}
                                        </span>
                                    </div>

                                    <h3 class="mt-5 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                        {item.title}
                                    </h3>

                                    <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                        {item.description}
                                    </p>
                                </div>
                            </article>
                        );
                    })
                }
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="container-wide">
            <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
                <div>
                    <SectionHeading
                        eyebrow="Tax Resource FAQ"
                        title="Common tax preparation questions."
                        highlight="questions"
                        description="Helpful answers for individuals and businesses preparing for tax season."
                    />

                    <div class="mt-8">
                        <CTAButton href="/resources/faq" variant="secondary" icon={HelpCircle}>
                            View Full FAQ
                        </CTAButton>
                    </div>
                </div>

                <div class="grid gap-4">
                    {
                        faqs.map((faq, index) => (
                            <article class="rounded-[1.6rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-5 shadow-soft backdrop-blur">
                                <div class="flex gap-4">
                                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] font-inter text-xs font-extrabold text-[rgb(var(--color-secondary))]">
                                        {String(index + 1).padStart(2, "0")}
                                    </span>

                                    <div>
                                        <h3 class="font-inter text-lg font-extrabold tracking-[-0.045em] text-[rgb(var(--color-heading))]">
                                            {faq.question}
                                        </h3>

                                        <p class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                            {faq.answer}
                                        </p>
                                    </div>
                                </div>
                            </article>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="section-shell relative isolate overflow-hidden">
        <div class="container-wide">
            <div class="relative overflow-hidden rounded-[2.5rem] border border-[rgb(var(--color-border)/0.72)] bg-[linear-gradient(135deg,rgb(var(--color-primary))_0%,rgb(var(--color-secondary))_100%)] p-6 text-white shadow-blue sm:p-8 lg:p-10">
                <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_0%,rgba(255,255,255,0.3),transparent_34%),radial-gradient(circle_at_92%_100%,rgba(255,255,255,0.16),transparent_34%)]"></div>

                <div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
                    <div>
                        <Badge
                            variant="outline"
                            class="border-white/25 bg-white/10 !text-white"
                            icon={MessageSquareText}
                        >
                            Need Help Preparing?
                        </Badge>

                        <h2 class="mt-5 max-w-4xl font-inter text-3xl font-extrabold tracking-[-0.055em] !text-white md:text-4xl">
                            Not sure which tax documents you need?
                        </h2>

                        <p class="mt-4 max-w-3xl text-sm leading-7 !text-white/78 md:text-base">
                            Contact East Coast Accounting & Tax Services and tell us whether you need personal tax preparation, business tax support, bookkeeping, payroll, or accounting guidance.
                        </p>
                    </div>

                    <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
                        <CTAButton href="/contact" variant="dark" icon={Send}>
                            Contact Our Office
                        </CTAButton>

                        <CTAButton
                            href="/services/tax-preparation"
                            variant="ghost"
                            icon={ArrowUpRight}
                            class="border-white/20 bg-white/10 text-white hover:border-white/35 hover:bg-white/16"
                        >
                            Tax Preparation
