---
import {
    ArrowLeft,
    ArrowUpRight,
    BookOpenCheck,
    BriefcaseBusiness,
    CheckCircle2,
    FileText,
    Languages,
    MapPin,
    MessageSquareText,
    Phone,
    ReceiptText,
    Send,
    Sparkles,
    UsersRound,
    WalletCards,
} from "@lucide/astro";

import MainLayout from "../../layouts/MainLayout.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";
import CTAButton from "../../components/ui/CTAButton.astro";
import Badge from "../../components/ui/Badge.astro";

import { siteConfig } from "../../data/site";

const title = "English & Spanish Tax and Accounting Support in Miami";
const description =
    "Bilingual English and Spanish tax preparation, bookkeeping, payroll, and accounting support for individuals and businesses in Miami, FL.";

const siteUrl = siteConfig.url.replace(/\/$/, "");

const supportCards = [
    {
        title: "Tax preparation in English and Spanish",
        description:
            "Clients can ask questions, share tax documents, and understand the preparation process in the language that feels most comfortable.",
        icon: ReceiptText,
        items: [
            "Personal tax preparation",
            "Business tax preparation",
            "Self-employed tax support",
            "Tax document questions",
        ],
    },
    {
        title: "Business support with clearer communication",
        description:
            "Business owners can discuss bookkeeping, payroll, expenses, records, and accounting needs with bilingual support from our Miami office.",
        icon: BriefcaseBusiness,
        items: [
            "Bookkeeping questions",
            "Payroll support",
            "Business tax guidance",
            "Financial record organization",
        ],
    },
    {
        title: "Support for Miami’s bilingual community",
        description:
            "Miami clients often prefer flexible communication. East Coast Accounting & Tax Services supports both English-speaking and Spanish-speaking clients.",
        icon: UsersRound,
        items: [
            "Individuals and families",
            "Small business owners",
            "Self-employed professionals",
            "Local Miami businesses",
        ],
    },
];

const whyItMatters = [
    {
        title: "Accounting conversations should feel clear",
        description:
            "Tax, bookkeeping, payroll, and accounting topics can already feel stressful. Bilingual support helps clients ask better questions and understand the next step.",
        icon: MessageSquareText,
    },
    {
        title: "Better understanding of documents",
        description:
            "Clients may need help understanding forms, records, income documents, expenses, and business information before filing or organizing their books.",
        icon: FileText,
    },
    {
        title: "Support for families and businesses",
        description:
            "East Coast Accounting & Tax Services supports individuals, families, self-employed professionals, and business owners in both English and Spanish.",
        icon: UsersRound,
    },
    {
        title: "Local Miami communication",
        description:
            "As a Miami-based accounting office, bilingual communication helps serve the local community with more comfort and clarity.",
        icon: MapPin,
    },
];

const bilingualServices = [
    {
        label: "Tax Preparation",
        href: "/services/tax-preparation",
        icon: ReceiptText,
    },
    {
        label: "Bookkeeping",
        href: "/services/bookkeeping",
        icon: BookOpenCheck,
    },
    {
        label: "Payroll Services",
        href: "/services/payroll",
        icon: WalletCards,
    },
    {
        label: "Business Tax Services",
        href: "/services/business-tax-services",
        icon: BriefcaseBusiness,
    },
];

const faqs = [
    {
        question: "Does East Coast Accounting & Tax Services speak Spanish?",
        answer:
            "Yes. East Coast Accounting & Tax Services provides bilingual support in English and Spanish for individuals, families, self-employed professionals, and businesses in Miami.",
    },
    {
        question: "Can I ask tax preparation questions in Spanish?",
        answer:
            "Yes. Clients can ask tax preparation questions in Spanish and receive help understanding what documents or next steps may be needed.",
    },
    {
        question: "Do you provide bilingual support for businesses?",
        answer:
            "Yes. Business owners can receive bilingual support for tax preparation, bookkeeping, payroll, business tax services, and accounting questions.",
    },
    {
        question: "Do you serve Spanish-speaking clients outside Miami?",
        answer:
            "East Coast Accounting & Tax Services is based in Miami and serves Miami-Dade County, while also supporting nearby South Florida communities when relevant.",
    },
];

const pageSchema = {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    description,
    url: `${siteUrl}/resources/english-spanish-support`,
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
            "@type": "Answer",
            text: faq.answer,
        },
    })),
};
---

<MainLayout
    title={title}
    description={description}
    image="/images/og/english-spanish-support-og.webp"
    schema={[pageSchema, faqSchema]}
>
    <!-- Bilingual Support Hero -->
    <section class="accounting-grid relative isolate overflow-hidden py-16 sm:py-20 lg:py-24">
        <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
            <div class="bilingual-kenburns-bg absolute inset-0 overflow-hidden">
                <img
                    src="/images/resources/english-spanish-support-hero.webp"
                    alt=""
                    width="2400"
                    height="1600"
                    class="absolute inset-0 h-full min-h-full w-full min-w-full object-cover object-center"
                    loading="eager"
                    decoding="async"
                />
            </div>

            <!-- <div class="absolute inset-0 bg-[rgb(var(--color-bg)/0.8)]"></div> -->

            <!-- <div class="absolute inset-0 bg-[linear-gradient(90deg,rgb(var(--color-bg)/0.97)_0%,rgb(var(--color-bg)/0.76)_54%,rgb(var(--color-bg)/0.5)_100%)]"></div> -->

            <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_25%,rgb(var(--color-secondary)/0.12),transparent_34rem),radial-gradient(circle_at_80%_30%,rgb(var(--color-primary)/0.1),transparent_32rem)]"></div>

            <div class="absolute left-[-12rem] top-20 h-[32rem] w-[32rem] rounded-full bg-[rgb(var(--color-secondary)/0.14)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-[-8rem] h-[34rem] w-[34rem] rounded-full bg-[rgb(var(--color-primary)/0.13)] blur-3xl"></div>

            <div class="absolute inset-x-0 bottom-0 h-56 bg-[linear-gradient(to_top,rgb(var(--color-bg)),transparent)]"></div>
        </div>

        <div class="container-wide">
            <div class="grid gap-12 lg:grid-cols-[0.95fr_0.75fr] lg:items-center">
                <div class="relative z-10 max-w-3xl">

                    <Badge variant="blue" icon={Languages} glow>
                        English & Spanish Support
                    </Badge>

                    <h1 class="mt-6 text-balance font-inter text-4xl font-extrabold tracking-[-0.065em] text-[rgb(var(--color-heading))] sm:text-5xl lg:text-6xl">
                        Tax and accounting support in
                        <span class="gradient-text block">English and Spanish.</span>
                    </h1>

                    <p class="lead-text mt-6">
                        East Coast Accounting & Tax Services helps Miami individuals, families, self-employed professionals, and businesses communicate clearly about taxes, bookkeeping, payroll, and accounting needs in English and Spanish.
                    </p>

                    <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                        <CTAButton href="/contact" icon={Send} size="lg">
                            Contact Our Office
                        </CTAButton>

                        <CTAButton
                            href={siteConfig.contact.phoneHref}
                            variant="secondary"
                            icon={Phone}
                            size="lg"
                        >
                            Call Now
                        </CTAButton>
                    </div>

                    <div class="mt-8 grid gap-3 sm:grid-cols-3">
                        {
                            [
                                {
                                    label: "English",
                                    detail: "Clear communication",
                                    icon: Languages,
                                },
                                {
                                    label: "Español",
                                    detail: "Apoyo en español",
                                    icon: MessageSquareText,
                                },
                                {
                                    label: "Miami",
                                    detail: "Local bilingual office",
                                    icon: MapPin,
                                },
                            ].map((item) => {
                                const Icon = item.icon;

                                return (
                                    <div class="glass-panel rounded-[1.35rem] p-4">
                                        <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                                            <Icon class="h-5 w-5" />
                                        </span>

                                        <p class="mt-3 font-inter text-sm font-extrabold text-[rgb(var(--color-heading))]">
                                            {item.label}
                                        </p>

                                        <p class="mt-1 text-xs leading-5 text-[rgb(var(--color-text-soft))]">
                                            {item.detail}
                                        </p>
                                    </div>
                                );
                            })
                        }
                    </div>
                </div>

                <!-- Floating visual -->
                <div class="relative hidden md:block">
                    <div class="pointer-events-none absolute inset-0 rounded-full bg-[radial-gradient(circle,rgb(var(--color-secondary)/0.18),transparent_62%)] blur-3xl"></div>

                    <div class="pointer-events-none absolute left-1/2 top-1/2 h-64 w-64 -translate-x-1/2 -translate-y-1/2 rounded-full border border-[rgb(var(--color-secondary)/0.18)]"></div>

                    <img
                        src="/images/resources/english-spanish-support-floating.webp"
                        alt=""
                        width="900"
                        height="700"
                        loading="eager"
                        decoding="async"
                        class="bilingual-floating-image relative z-10 mx-auto w-full max-w-[32rem] object-contain drop-shadow-[0_34px_80px_rgb(5_162_236/0.24)]"
                    />

                    <div class="absolute right-6 top-8 z-20 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.82)] px-4 py-2 shadow-soft backdrop-blur">
                        <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-secondary))]">
                            English
                        </span>
                    </div>

                    <div class="absolute bottom-8 left-4 z-20 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.82)] px-4 py-2 shadow-soft backdrop-blur">
                        <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-heading))]">
                            Español
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Support Cards -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-1/2 top-0 h-px w-[min(92%,1180px)] -translate-x-1/2 bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.55),transparent)]"></div>

            <div class="absolute left-[-14rem] top-24 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-10 h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.1)] blur-3xl"></div>
        </div>

        <div class="container-wide">
            <SectionHeading
                eyebrow="Bilingual Accounting Help"
                title="Clearer conversations for taxes, books, payroll, and business records."
                highlight="Clearer conversations"
                description="When clients can explain their situation comfortably, it becomes easier to understand documents, ask questions, and move toward the right financial support."
            />

            <div class="mt-12 grid gap-5 md:grid-cols-3">
                {
                    supportCards.map((card) => {
                        const Icon = card.icon;

                        return (
                            <article class="group glow-card card-hover relative overflow-hidden p-6">
                                <div class="pointer-events-none absolute right-[-4rem] top-[-4rem] h-40 w-40 rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-2xl opacity-0 transition duration-300 group-hover:opacity-100"></div>

                                <div class="pointer-events-none absolute bottom-4 right-5 text-[rgb(var(--color-primary)/0.045)] transition group-hover:text-[rgb(var(--color-secondary)/0.075)] dark:text-white/5">
                                    <Icon class="h-24 w-24" />
                                </div>

                                <div class="relative z-10 flex h-full flex-col">
                                    <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                        <Icon class="h-7 w-7" />
                                    </span>

                                    <h2 class="mt-5 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                        {card.title}
                                    </h2>

                                    <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                        {card.description}
                                    </p>

                                    <div class="mt-6 grid gap-3">
                                        {
                                            card.items.map((item) => (
                                                <div class="flex items-start gap-3">
                                                    <CheckCircle2 class="mt-0.5 h-4.5 w-4.5 shrink-0 text-[rgb(var(--color-secondary))]" />
                                                    <span class="text-sm font-bold leading-6 text-[rgb(var(--color-text))]">
                                                        {item}
                                                    </span>
                                                </div>
                                            ))
                                        }
                                    </div>
                                </div>
                            </article>
                        );
                    })
                }
            </div>
        </div>
    </section>

    <!-- Why It Matters -->
    <section class="section-shell relative overflow-hidden">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-[-12rem] top-20 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.09)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-10 h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.09)] blur-3xl"></div>
        </div>

        <div class="container-wide">
            <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
                <SectionHeading
                    eyebrow="Why Bilingual Support Matters"
                    title="Tax and accounting details are easier when communication is clear."
                    highlight="communication is clear"
                    description="Financial conversations often involve documents, deadlines, records, and important questions. Bilingual support helps clients feel more confident during the process."
                />

                <div class="grid gap-5 md:grid-cols-2">
                    {
                        whyItMatters.map((item) => {
                            const Icon = item.icon;

                            return (
                                <article class="group glow-card card-hover p-6">
                                    <div class="relative z-10">
                                        <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                            <Icon class="h-7 w-7" />
                                        </span>

                                        <h3 class="mt-5 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                            {item.title}
                                        </h3>

                                        <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                            {item.description}
                                        </p>
                                    </div>
                                </article>
                            );
                        })
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Bilingual Services -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="container-wide">
            <SectionHeading
                eyebrow="Services Available"
                title="Bilingual support across core tax and accounting services."
                highlight="Bilingual support"
                description="East Coast Accounting & Tax Services helps Miami clients discuss key financial needs in English and Spanish."
            />

            <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
                {
                    bilingualServices.map((service) => {
                        const Icon = service.icon;

                        return (
                            <a
                                href={service.href}
                                class="group glow-card card-hover relative overflow-hidden p-6"
                            >
                                <div class="pointer-events-none absolute right-[-4rem] top-[-4rem] h-40 w-40 rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-2xl opacity-0 transition duration-300 group-hover:opacity-100"></div>

                                <div class="relative z-10">
                                    <div class="flex items-start justify-between gap-4">
                                        <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                            <Icon class="h-7 w-7" />
                                        </span>

                                        <ArrowUpRight class="h-5 w-5 text-[rgb(var(--color-secondary))] transition group-hover:-translate-y-0.5 group-hover:translate-x-0.5" />
                                    </div>

                                    <h3 class="mt-5 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                        {service.label}
                                    </h3>

                                    <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                        Learn more about {service.label.toLowerCase()} and how East Coast Accounting can help.
                                    </p>
                                </div>
                            </a>
                        );
                    })
                }
            </div>
        </div>
    </section>

    <!-- Miami Support Panel -->
    <section class="section-shell accounting-grid relative isolate overflow-hidden">
        <div class="container-wide">
            <div class="relative overflow-hidden rounded-[2.5rem] border border-[rgb(var(--color-border)/0.72)] bg-[linear-gradient(135deg,rgb(var(--color-primary))_0%,rgb(var(--color-secondary))_100%)] p-6 text-white shadow-blue sm:p-8 lg:p-10">
                <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_0%,rgba(255,255,255,0.3),transparent_34%),radial-gradient(circle_at_92%_100%,rgba(255,255,255,0.16),transparent_34%)]"></div>

                <div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
                    <div>
                        <Badge
                            variant="outline"
                            class="border-white/25 bg-white/10 !text-white"
                            icon={MapPin}
                        >
                            Miami Bilingual Office
                        </Badge>

                        <h2 class="mt-5 max-w-4xl font-inter text-3xl font-extrabold tracking-[-0.055em] !text-white md:text-4xl">
                            Local support for Miami clients who prefer English or Spanish.
                        </h2>

                        <p class="mt-4 max-w-3xl text-sm leading-7 !text-white/78 md:text-base">
                            Our office is based in Miami and serves individuals and businesses across Miami-Dade County. Whether you need help with taxes, bookkeeping, payroll, or accounting support, our team can help you understand the next step.
                        </p>
                    </div>

                    <div class="grid gap-3 sm:grid-cols-3 lg:w-[28rem]">
                        {
                            [
                                "English",
                                "Español",
                                "Miami-Dade",
                            ].map((item) => (
                                <div class="rounded-2xl border border-white/15 bg-white/10 p-4 text-center backdrop-blur">
                                    <CheckCircle2 class="mx-auto h-5 w-5 text-white" />
                                    <p class="mt-3 font-inter text-sm font-extrabold !text-white">
                                        {item}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="container-wide">
            <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
                <div>
                    <SectionHeading
                        eyebrow="Bilingual Support FAQ"
                        title="Common questions about English and Spanish support."
                        highlight="questions"
                        description="Helpful answers for Miami clients who want bilingual tax and accounting communication."
                    />

                    <div class="mt-8">
                        <CTAButton href="/resources/faq" variant="secondary" icon={ArrowUpRight}>
                            View Full FAQ
                        </CTAButton>
                    </div>
                </div>

                <div class="grid gap-4">
                    {
                        faqs.map((faq, index) => (
                            <article class="rounded-[1.6rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-5 shadow-soft backdrop-blur">
                                <div class="flex gap-4">
                                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] font-inter text-xs font-extrabold text-[rgb(var(--color-secondary))]">
                                        {String(index + 1).padStart(2, "0")}
                                    </span>

                                    <div>
                                        <h3 class="font-inter text-lg font-extrabold tracking-[-0.045em] text-[rgb(var(--color-heading))]">
                                            {faq.question}
                                        </h3>

                                        <p class="mt-2 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                            {faq.answer}
                                        </p>
                                    </div>
                                </div>
                            </article>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="section-shell relative isolate overflow-hidden">
        <div class="container-wide">
            <div class="relative overflow-hidden rounded-[2.5rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.74)] p-6 shadow-card backdrop-blur sm:p-8 lg:p-10">
                <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_0%,rgb(var(--color-secondary)/0.12),transparent_34rem)]"></div>

                <div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
                    <div>
                        <Badge variant="blue" icon={MessageSquareText}>
                            Need Bilingual Help?
                        </Badge>

                        <h2 class="mt-5 max-w-4xl font-inter text-3xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))] md:text-4xl">
                            Contact our Miami office in English or Spanish.
                        </h2>

                        <p class="mt-4 max-w-3xl text-sm leading-7 text-[rgb(var(--color-text-soft))] md:text-base">
                            Tell us what type of support you need, and our office will help guide you toward the right next step for tax preparation, bookkeeping, payroll, or accounting services.
                        </p>
                    </div>

                    <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
                        <CTAButton href="/contact" icon={Send}>
                            Contact Our Office
                        </CTAButton>

                        <CTAButton href={siteConfig.contact.phoneHref} variant="secondary" icon={Phone}>
                            {siteConfig.contact.phone}
                        </CTAButton>
                    </div>
                </div>
            </div>
        </div>
    </section>
</MainLayout>

<style>
    .bilingual-kenburns-bg {
        inset: 0;
        width: 100%;
        height: 100%;
        opacity: 0.26;
        transform: scale(1.08);
        transform-origin: center center;
        animation: bilingual-kenburns 18s ease-in-out infinite alternate;
    }

    .bilingual-kenburns-bg img {
        object-fit: cover;
        object-position: center center;
    }

    :root[data-theme="dark"] .bilingual-kenburns-bg {
        opacity: 0.17;
    }

    @keyframes bilingual-kenburns {
        0% {
            transform: scale(1.08) translate3d(0, 0, 0);
        }

        100% {
            transform: scale(1.18) translate3d(-1.5%, -1.2%, 0);
        }
    }

    @keyframes bilingual-float {
        0%,
        100% {
            transform: translateY(0) rotate(1deg) scale(1);
        }

        50% {
            transform: translateY(-14px) rotate(-1deg) scale(1.02);
        }
    }

    .bilingual-floating-image {
        animation: bilingual-float 7.4s ease-in-out infinite;
    }

    @media (max-width: 1023px) {
        .bilingual-kenburns-bg img {
            object-position: center top;
        }
    }

    @media (max-width: 767px) {
        .bilingual-kenburns-bg {
            transform: scale(1.12);
        }

        .bilingual-kenburns-bg img {
            object-position: center center;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .bilingual-kenburns-bg,
        .bilingual-floating-image {
            animation: none;
        }

        .bilingual-kenburns-bg {
            transform: scale(1.1);
        }
    }
</style>