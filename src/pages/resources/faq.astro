---
import {
    ArrowLeft,
    ArrowUpRight,
    BookOpenCheck,
    BriefcaseBusiness,
    Calculator,
    CheckCircle2,
    ChevronDown,
    Clock3,
    FileQuestion,
    HelpCircle,
    Languages,
    MessageSquareText,
    Phone,
    ReceiptText,
    Send,
    Sparkles,
    WalletCards,
} from "@lucide/astro";

import MainLayout from "../../layouts/MainLayout.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";
import CTAButton from "../../components/ui/CTAButton.astro";
import Badge from "../../components/ui/Badge.astro";

import { siteConfig } from "../../data/site";

const title = "Frequently Asked Questions";
const description =
    "Answers to common questions about tax preparation, bookkeeping, payroll, accounting services, bilingual support, and working with East Coast Accounting & Tax Services in Miami, FL.";

const siteUrl = siteConfig.url.replace(/\/$/, "");

const faqGroups = [
    {
        category: "Tax Preparation",
        eyebrow: "Tax Help",
        icon: ReceiptText,
        questions: [
            {
                question: "What documents do I need for tax preparation?",
                answer:
                    "The documents needed depend on your situation. Common items include W-2s, 1099s, prior-year tax returns, identification, income records, expense records, business documents, payroll records, and any forms related to deductions or credits.",
            },
            {
                question: "Do you help with both personal and business tax preparation?",
                answer:
                    "Yes. East Coast Accounting & Tax Services helps individuals, families, self-employed professionals, and businesses with tax preparation and related accounting support.",
            },
            {
                question: "Can you help if I am missing a tax document?",
                answer:
                    "Yes. If you are not sure which document is missing or what may be needed, you can contact the office and explain your situation so the team can help guide the next step.",
            },
            {
                question: "Do you help self-employed clients and 1099 workers?",
                answer:
                    "Yes. The office supports self-employed professionals, freelancers, independent contractors, and 1099 workers with tax preparation, expense organization, and accounting support.",
            },
        ],
    },
    {
        category: "Bookkeeping",
        eyebrow: "Better Records",
        icon: BookOpenCheck,
        questions: [
            {
                question: "Can bookkeeping help if my business records are behind?",
                answer:
                    "Yes. Bookkeeping support can help review, organize, and clean up business records so income, expenses, and financial activity are easier to understand.",
            },
            {
                question: "Why is bookkeeping important for tax season?",
                answer:
                    "Bookkeeping helps organize business income, expenses, payroll details, and records that may be needed for tax preparation. Cleaner books can make tax season less stressful.",
            },
            {
                question: "Do small businesses need monthly bookkeeping?",
                answer:
                    "Many small businesses benefit from regular bookkeeping because it keeps financial records updated throughout the year instead of waiting until tax season.",
            },
            {
                question: "Can you help organize income and expenses?",
                answer:
                    "Yes. East Coast Accounting & Tax Services can help business owners and self-employed professionals organize income, expenses, and financial records.",
            },
        ],
    },
    {
        category: "Payroll",
        eyebrow: "Employer Support",
        icon: WalletCards,
        questions: [
            {
                question: "Do you provide payroll services for small businesses?",
                answer:
                    "Yes. East Coast Accounting & Tax Services provides payroll support for small businesses and local employers.",
            },
            {
                question: "Can payroll support help with employee records?",
                answer:
                    "Yes. Payroll support can help keep employee pay, payroll records, and related business information more organized.",
            },
            {
                question: "Do restaurants, contractors, and healthcare offices need payroll support?",
                answer:
                    "Many businesses with employees can benefit from payroll support, including restaurants, contractors, healthcare practices, and local service businesses.",
            },
            {
                question: "Can payroll and bookkeeping work together?",
                answer:
                    "Yes. Payroll and bookkeeping are closely connected because payroll activity affects business records, expenses, and tax preparation.",
            },
        ],
    },
    {
        category: "Accounting Services",
        eyebrow: "Financial Organization",
        icon: Calculator,
        questions: [
            {
                question: "What accounting services do you offer?",
                answer:
                    "East Coast Accounting & Tax Services provides support with tax preparation, bookkeeping, payroll, business tax services, small business accounting, IRS tax help, and general accounting organization.",
            },
            {
                question: "Do you work with small businesses?",
                answer:
                    "Yes. The office supports small businesses in Miami and nearby communities with tax, bookkeeping, payroll, and accounting needs.",
            },
            {
                question: "Can accounting support help me understand my business better?",
                answer:
                    "Yes. Cleaner records and organized reports can help business owners better understand income, expenses, payroll, and financial activity.",
            },
            {
                question: "Do you provide year-round support?",
                answer:
                    "Yes. East Coast Accounting & Tax Services supports clients throughout the year, not only during tax season.",
            },
        ],
    },
    {
        category: "Office & Bilingual Support",
        eyebrow: "Miami Office",
        icon: Languages,
        questions: [
            {
                question: "Where is East Coast Accounting & Tax Services located?",
                answer:
                    `East Coast Accounting & Tax Services is located at ${siteConfig.address.full}.`,
            },
            {
                question: "Do you provide support in English and Spanish?",
                answer:
                    "Yes. The office provides bilingual support in English and Spanish for individuals and businesses in Miami.",
            },
            {
                question: "What areas do you serve?",
                answer:
                    "East Coast Accounting & Tax Services serves Miami-Dade County and nearby South Florida communities, including Miami, West Miami, Coral Gables, Doral, Kendall, Hialeah, Brickell, Homestead, and South Miami.",
            },
            {
                question: "How can I contact the office?",
                answer:
                    `You can contact the office by phone at ${siteConfig.contact.phone}, by email at ${siteConfig.contact.email}, or by submitting the contact form on the website.`,
            },
        ],
    },
];

const allFaqs = faqGroups.flatMap((group) => group.questions);

const featuredCards = [
    {
        title: "Tax preparation questions",
        description:
            "Find answers about documents, personal taxes, business taxes, 1099 income, and filing preparation.",
        icon: ReceiptText,
    },
    {
        title: "Business support questions",
        description:
            "Learn how bookkeeping, payroll, and accounting support can help small businesses stay organized.",
        icon: BriefcaseBusiness,
    },
    {
        title: "Bilingual office questions",
        description:
            "Get information about English and Spanish support, office location, and service areas near Miami.",
        icon: Languages,
    },
];

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: allFaqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
            "@type": "Answer",
            text: faq.answer,
        },
    })),
};

const pageSchema = {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    description,
    url: `${siteUrl}/resources/faq`,
};
---

<MainLayout
    title={title}
    description={description}
    image="/images/og/faq-og.webp"
    schema={[pageSchema, faqSchema]}
>
    <!-- FAQ Hero -->
    <section class="accounting-grid relative isolate overflow-hidden py-16 sm:py-20 lg:py-24">
        <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
            <div class="faq-kenburns-bg absolute inset-0 overflow-hidden">
                <img
                    src="/images/resources/faq-hero.webp"
                    alt=""
                    width="2400"
                    height="1600"
                    class="absolute inset-0 h-full min-h-full w-full min-w-full object-cover object-center"
                    loading="eager"
                    decoding="async"
                />
            </div>

            <!-- <div class="absolute inset-0 bg-[rgb(var(--color-bg)/0.8)]"></div> -->

            <!-- <div class="absolute inset-0 bg-[linear-gradient(90deg,rgb(var(--color-bg)/0.97)_0%,rgb(var(--color-bg)/0.76)_54%,rgb(var(--color-bg)/0.5)_100%)]"></div> -->

            <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_25%,rgb(var(--color-secondary)/0.12),transparent_34rem),radial-gradient(circle_at_80%_30%,rgb(var(--color-primary)/0.1),transparent_32rem)]"></div>

            <div class="absolute left-[-12rem] top-20 h-[32rem] w-[32rem] rounded-full bg-[rgb(var(--color-secondary)/0.14)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-[-8rem] h-[34rem] w-[34rem] rounded-full bg-[rgb(var(--color-primary)/0.13)] blur-3xl"></div>

            <div class="absolute inset-x-0 bottom-0 h-56 bg-[linear-gradient(to_top,rgb(var(--color-bg)),transparent)]"></div>
        </div>

        <div class="container-wide">
            <div class="grid gap-12 lg:grid-cols-[0.95fr_0.75fr] lg:items-center">
                <div class="relative z-10 max-w-3xl">
                    <a
                        href="/resources"
                        class="mb-6 inline-flex items-center gap-2 font-inter text-sm font-extrabold text-[rgb(var(--color-secondary))] transition hover:gap-3"
                    >
                        <ArrowLeft class="h-4 w-4" />
                        Back to Resources
                    </a>

                    <Badge variant="blue" icon={FileQuestion} glow>
                        Common Client Questions
                    </Badge>

                    <h1 class="mt-6 text-balance font-inter text-4xl font-extrabold tracking-[-0.065em] text-[rgb(var(--color-heading))] sm:text-5xl lg:text-6xl">
                        Frequently asked questions about
                        <span class="gradient-text block">tax and accounting support.</span>
                    </h1>

                    <p class="lead-text mt-6">
                        Get clear answers about tax preparation, bookkeeping, payroll, accounting services, bilingual support, and working with East Coast Accounting & Tax Services in Miami.
                    </p>

                    <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                        <CTAButton href="/contact" icon={Send} size="lg">
                            Contact Our Office
                        </CTAButton>

                        <CTAButton
                            href="/resources/tax-resources"
                            variant="secondary"
                            icon={ArrowUpRight}
                            size="lg"
                        >
                            View Tax Resources
                        </CTAButton>
                    </div>

                    <div class="mt-8 grid gap-3 sm:grid-cols-3">
                        {
                            [
                                {
                                    label: "Tax Help",
                                    detail: "Documents and filing",
                                    icon: ReceiptText,
                                },
                                {
                                    label: "Business",
                                    detail: "Books and payroll",
                                    icon: BriefcaseBusiness,
                                },
                                {
                                    label: "Bilingual",
                                    detail: "English & Spanish",
                                    icon: Languages,
                                },
                            ].map((item) => {
                                const Icon = item.icon;

                                return (
                                    <div class="glass-panel rounded-[1.35rem] p-4">
                                        <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                                            <Icon class="h-5 w-5" />
                                        </span>

                                        <p class="mt-3 font-inter text-sm font-extrabold text-[rgb(var(--color-heading))]">
                                            {item.label}
                                        </p>

                                        <p class="mt-1 text-xs leading-5 text-[rgb(var(--color-text-soft))]">
                                            {item.detail}
                                        </p>
                                    </div>
                                );
                            })
                        }
                    </div>
                </div>

                <!-- Floating visual -->
                <div class="relative hidden md:block">
                    <div class="pointer-events-none absolute inset-0 rounded-full bg-[radial-gradient(circle,rgb(var(--color-secondary)/0.18),transparent_62%)] blur-3xl"></div>

                    <div class="pointer-events-none absolute left-1/2 top-1/2 h-64 w-64 -translate-x-1/2 -translate-y-1/2 rounded-full border border-[rgb(var(--color-secondary)/0.18)]"></div>

                    <img
                        src="/images/resources/faq-floating.webp"
                        alt=""
                        width="900"
                        height="700"
                        loading="eager"
                        decoding="async"
                        class="faq-floating-image relative z-10 mx-auto w-full max-w-[32rem] object-contain drop-shadow-[0_34px_80px_rgb(5_162_236/0.24)]"
                    />

                    <div class="absolute right-6 top-8 z-20 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.82)] px-4 py-2 shadow-soft backdrop-blur">
                        <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-secondary))]">
                            FAQ
                        </span>
                    </div>

                    <div class="absolute bottom-8 left-4 z-20 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.82)] px-4 py-2 shadow-soft backdrop-blur">
                        <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-heading))]">
                            Taxes · Books · Payroll
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured FAQ Cards -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-1/2 top-0 h-px w-[min(92%,1180px)] -translate-x-1/2 bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.55),transparent)]"></div>

            <div class="absolute left-[-14rem] top-24 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-10 h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.1)] blur-3xl"></div>
        </div>

        <div class="container-wide">
            <SectionHeading
                eyebrow="FAQ Overview"
                title="Answers organized around the services clients ask about most."
                highlight="services clients ask about"
                description="Start with common questions about tax preparation, bookkeeping, payroll, accounting services, office support, and bilingual communication."
            />

            <div class="mt-12 grid gap-5 md:grid-cols-3">
                {
                    featuredCards.map((card) => {
                        const Icon = card.icon;

                        return (
                            <article class="group glow-card card-hover relative overflow-hidden p-6">
                                <div class="pointer-events-none absolute right-[-4rem] top-[-4rem] h-40 w-40 rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-2xl opacity-0 transition duration-300 group-hover:opacity-100"></div>

                                <div class="relative z-10">
                                    <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                        <Icon class="h-7 w-7" />
                                    </span>

                                    <h2 class="mt-5 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                        {card.title}
                                    </h2>

                                    <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                        {card.description}
                                    </p>
                                </div>
                            </article>
                        );
                    })
                }
            </div>
        </div>
    </section>

    <!-- FAQ Accordion -->
    <section class="section-shell relative overflow-hidden">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-[-12rem] top-20 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.09)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-10 h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.09)] blur-3xl"></div>
        </div>

        <div class="container-wide">
            <div class="grid gap-10 lg:items-start">

                <div class="grid gap-6" data-faq-list>
                    {
                        faqGroups.map((group) => {
                            const GroupIcon = group.icon;

                            return (
                                <section class="rounded-[2.25rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] p-4 shadow-soft backdrop-blur sm:p-5">
                                    <div class="mb-4 flex items-start gap-4 px-1">
                                        <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-[1.1rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                                            <GroupIcon class="h-6 w-6" />
                                        </span>

                                        <div>
                                            <Badge variant="soft" size="sm">
                                                {group.eyebrow}
                                            </Badge>

                                            <h2 class="mt-3 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                                {group.category}
                                            </h2>
                                        </div>
                                    </div>

                                    <div class="grid gap-3">
                                        {group.questions.map((faq, index) => (
                                            <article
                                                class="faq-item overflow-hidden rounded-[1.5rem] border border-[rgb(var(--color-border)/0.68)] bg-[rgb(var(--color-bg)/0.36)] transition duration-300"
                                                data-faq-item
                                            >
                                                <button
                                                    type="button"
                                                    class="flex w-full items-start justify-between gap-4 p-5 text-left transition hover:bg-[rgb(var(--color-secondary)/0.055)]"
                                                    aria-expanded={index === 0 ? "true" : "false"}
                                                    data-faq-trigger
                                                >
                                                    <span class="flex gap-4">
                                                        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] font-inter text-xs font-extrabold text-[rgb(var(--color-secondary))]">
                                                            {String(index + 1).padStart(2, "0")}
                                                        </span>

                                                        <span class="block font-inter text-lg font-extrabold tracking-[-0.04em] text-[rgb(var(--color-heading))]">
                                                            {faq.question}
                                                        </span>
                                                    </span>

                                                    <span class="mt-1 flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.62)] text-[rgb(var(--color-secondary))] transition duration-300">
                                                        <ChevronDown
                                                            class:list={[
                                                                "h-4.5 w-4.5 transition duration-300",
                                                                index === 0 ? "rotate-180" : "",
                                                            ]}
                                                            data-faq-icon
                                                        />
                                                    </span>
                                                </button>

                                                <div
                                                    class:list={[
                                                        "faq-panel grid transition-all duration-300 ease-out",
                                                        index === 0 ? "grid-rows-[1fr]" : "grid-rows-[0fr]",
                                                    ]}
                                                    data-faq-panel
                                                >
                                                    <div class="overflow-hidden">
                                                        <div class="px-5 pb-5 pl-[5.25rem]">
                                                            <p class="text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                                                {faq.answer}
                                                            </p>
                                                        </div>
                                                    </div>
                                                </div>
                                            </article>
                                        ))}
                                    </div>
                                </section>
                            );
                        })
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Strip -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="container-wide">
            <div class="relative overflow-hidden rounded-[2.5rem] border border-[rgb(var(--color-border)/0.72)] bg-[linear-gradient(135deg,rgb(var(--color-primary))_0%,rgb(var(--color-secondary))_100%)] p-6 text-white shadow-blue sm:p-8 lg:p-10">
                <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_0%,rgba(255,255,255,0.3),transparent_34%),radial-gradient(circle_at_92%_100%,rgba(255,255,255,0.16),transparent_34%)]"></div>

                <div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
                    <div>
                        <Badge
                            variant="outline"
                            class="border-white/25 bg-white/10 !text-white"
                            icon={MessageSquareText}
                        >
                            Still Have Questions?
                        </Badge>

                        <h2 class="mt-5 max-w-4xl font-inter text-3xl font-extrabold tracking-[-0.055em] !text-white md:text-4xl">
                            Send a message and tell us what you need help with.
                        </h2>

                        <p class="mt-4 max-w-3xl text-sm leading-7 !text-white/78 md:text-base">
                            If your question depends on your personal tax situation, business records, payroll, bookkeeping, or IRS-related details, contact the office for more specific guidance.
                        </p>
                    </div>

                    <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
                        <CTAButton href="/contact" variant="dark" icon={Send}>
                            Contact Our Office
                        </CTAButton>

                        <CTAButton
                            href="/resources/tax-resources"
                            variant="ghost"
                            icon={ArrowUpRight}
                            class="border-white/20 bg-white/10 text-white hover:border-white/35 hover:bg-white/16"
                        >
                            Tax Resources
                        </CTAButton>
                    </div>
                </div>
            </div>
        </div>
    </section>
</MainLayout>

<script>
    const faqItems = document.querySelectorAll("[data-faq-item]");

    faqItems.forEach((item) => {
        const trigger = item.querySelector("[data-faq-trigger]");
        const panel = item.querySelector("[data-faq-panel]");
        const icon = item.querySelector("[data-faq-icon]");

        trigger?.addEventListener("click", () => {
            const isOpen = trigger.getAttribute("aria-expanded") === "true";

            trigger.setAttribute("aria-expanded", String(!isOpen));

            panel?.classList.toggle("grid-rows-[1fr]", !isOpen);
            panel?.classList.toggle("grid-rows-[0fr]", isOpen);
            icon?.classList.toggle("rotate-180", !isOpen);
        });
    });
</script>

<style>
    .faq-kenburns-bg {
        inset: 0;
        width: 100%;
        height: 100%;
        opacity: 0.26;
        transform: scale(1.08);
        transform-origin: center center;
        animation: faq-kenburns 18s ease-in-out infinite alternate;
    }

    .faq-kenburns-bg img {
        object-fit: cover;
        object-position: center center;
    }

    :root[data-theme="dark"] .faq-kenburns-bg {
        opacity: 0.17;
    }

    @keyframes faq-kenburns {
        0% {
            transform: scale(1.08) translate3d(0, 0, 0);
        }

        100% {
            transform: scale(1.18) translate3d(-1.5%, -1.2%, 0);
        }
    }

    @keyframes faq-float {
        0%,
        100% {
            transform: translateY(0) rotate(1deg) scale(1);
        }

        50% {
            transform: translateY(-14px) rotate(-1deg) scale(1.02);
        }
    }

    .faq-floating-image {
        animation: faq-float 7.4s ease-in-out infinite;
    }

    @media (max-width: 1023px) {
        .faq-kenburns-bg img {
            object-position: center top;
        }
    }

    @media (max-width: 767px) {
        .faq-kenburns-bg {
            transform: scale(1.12);
        }

        .faq-kenburns-bg img {
            object-position: center center;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .faq-kenburns-bg,
        .faq-floating-image {
            animation: none;
        }

        .faq-kenburns-bg {
            transform: scale(1.1);
        }
    }
</style>