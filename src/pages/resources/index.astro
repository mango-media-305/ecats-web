---
import {
    ArrowUpRight,
    BookOpenCheck,
    CheckCircle2,
    FileQuestion,
    FileText,
    Languages,
    MessageSquareText,
    ReceiptText,
    Send,
    Sparkles,
} from "@lucide/astro";

import MainLayout from "../../layouts/MainLayout.astro";
import SectionHeading from "../../components/ui/SectionHeading.astro";
import CTAButton from "../../components/ui/CTAButton.astro";
import Badge from "../../components/ui/Badge.astro";

import { siteConfig } from "../../data/site";

const title = "Tax & Accounting Resources";
const description =
    "Helpful tax, bookkeeping, payroll, FAQ, and bilingual support resources from East Coast Accounting & Tax Services in Miami, FL.";

const siteUrl = siteConfig.url.replace(/\/$/, "");

const resources = [
    {
        title: "Tax Resources",
        eyebrow: "Tax Help",
        description:
            "Helpful tax tips, document reminders, filing preparation guidance, and organization support for individuals and businesses.",
        href: "/resources/tax-resources",
        icon: ReceiptText,
        features: [
            "Tax document checklist",
            "Personal tax preparation reminders",
            "Business tax preparation guidance",
            "Year-round organization tips",
        ],
    },
    {
        title: "FAQ",
        eyebrow: "Common Questions",
        description:
            "Answers to common questions about tax preparation, bookkeeping, payroll, accounting services, and working with our Miami office.",
        href: "/resources/faq",
        icon: FileQuestion,
        features: [
            "Service questions",
            "Office and contact questions",
            "Tax season questions",
            "Business support questions",
        ],
    },
    {
        title: "English & Spanish Support",
        eyebrow: "Bilingual Help",
        description:
            "Learn how East Coast Accounting & Tax Services supports Miami clients in both English and Spanish.",
        href: "/resources/english-spanish-support",
        icon: Languages,
        features: [
            "English and Spanish communication",
            "Support for individuals and businesses",
            "Miami community focus",
            "Clearer accounting conversations",
        ],
    },
];

const helpfulTopics = [
    {
        title: "Prepare before tax season",
        description:
            "Gathering tax forms, income records, business expenses, payroll details, and bookkeeping documents early can make the filing process easier.",
        icon: FileText,
    },
    {
        title: "Keep business records organized",
        description:
            "Clear bookkeeping helps business owners understand income, expenses, payroll, and tax-related documentation throughout the year.",
        icon: BookOpenCheck,
    },
    {
        title: "Ask questions before you feel behind",
        description:
            "If you are not sure what documents are needed or which service fits your situation, contacting the office early can help clarify the next step.",
        icon: MessageSquareText,
    },
];

const resourcesSchema = {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    description,
    url: `${siteUrl}/resources`,
    mainEntity: {
        "@type": "ItemList",
        itemListElement: resources.map((resource, index) => ({
            "@type": "ListItem",
            position: index + 1,
            name: resource.title,
            url: `${siteUrl}${resource.href}`,
        })),
    },
};
---

<MainLayout
    title={title}
    description={description}
    image="/images/og/resources-og.webp"
    schema={resourcesSchema}
>
    <!-- Resources Hero -->
    <section class="accounting-grid relative isolate overflow-hidden py-16 sm:py-20 lg:py-24">
        <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
            <div class="resources-kenburns-bg absolute inset-0 overflow-hidden">
                <img
                    src="/images/resources/resources-hero.webp"
                    alt=""
                    width="2400"
                    height="1600"
                    class="absolute inset-0 h-full min-h-full w-full min-w-full object-cover object-center"
                    loading="eager"
                    decoding="async"
                />
            </div>

            <!-- <div class="absolute inset-0 bg-[rgb(var(--color-bg)/0.8)]"></div> -->

            <!-- <div class="absolute inset-0 bg-[linear-gradient(90deg,rgb(var(--color-bg)/0.97)_0%,rgb(var(--color-bg)/0.76)_54%,rgb(var(--color-bg)/0.5)_100%)]"></div> -->

            <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_25%,rgb(var(--color-secondary)/0.12),transparent_34rem),radial-gradient(circle_at_80%_30%,rgb(var(--color-primary)/0.1),transparent_32rem)]"></div>

            <div class="absolute left-[-12rem] top-20 h-[32rem] w-[32rem] rounded-full bg-[rgb(var(--color-secondary)/0.14)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-[-8rem] h-[34rem] w-[34rem] rounded-full bg-[rgb(var(--color-primary)/0.13)] blur-3xl"></div>

            <div class="absolute inset-x-0 bottom-0 h-56 bg-[linear-gradient(to_top,rgb(var(--color-bg)),transparent)]"></div>
        </div>

        <div class="container-wide">
            <div class="grid gap-12 lg:grid-cols-[0.95fr_0.75fr] lg:items-center">
                <div class="relative z-10 max-w-3xl">
                    <Badge variant="blue" icon={Sparkles} glow>
                        Helpful Tax & Accounting Guidance
                    </Badge>

                    <h1 class="mt-6 text-balance font-inter text-4xl font-extrabold tracking-[-0.065em] text-[rgb(var(--color-heading))] sm:text-5xl lg:text-6xl">
                        Resources to help you feel more
                        <span class="gradient-text block">organized and prepared.</span>
                    </h1>

                    <p class="lead-text mt-6">
                        Explore helpful tax resources, frequently asked questions, and bilingual support information from East Coast Accounting & Tax Services in Miami, FL.
                    </p>

                    <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                        <CTAButton href="/contact" icon={Send} size="lg">
                            Contact Our Office
                        </CTAButton>

                        <CTAButton
                            href="/resources/tax-resources"
                            variant="secondary"
                            icon={ArrowUpRight}
                            size="lg"
                        >
                            View Tax Resources
                        </CTAButton>
                    </div>

                    <div class="mt-8 grid gap-3 sm:grid-cols-3">
                        {
                            [
                                {
                                    label: "Tax Tips",
                                    detail: "Helpful filing reminders",
                                    icon: ReceiptText,
                                },
                                {
                                    label: "FAQ",
                                    detail: "Common client questions",
                                    icon: FileQuestion,
                                },
                                {
                                    label: "EN / ES",
                                    detail: "Bilingual support",
                                    icon: Languages,
                                },
                            ].map((item) => {
                                const Icon = item.icon;

                                return (
                                    <div class="glass-panel rounded-[1.35rem] p-4">
                                        <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))]">
                                            <Icon class="h-5 w-5" />
                                        </span>

                                        <p class="mt-3 font-inter text-sm font-extrabold text-[rgb(var(--color-heading))]">
                                            {item.label}
                                        </p>

                                        <p class="mt-1 text-xs leading-5 text-[rgb(var(--color-text-soft))]">
                                            {item.detail}
                                        </p>
                                    </div>
                                );
                            })
                        }
                    </div>
                </div>

                <!-- Floating visual -->
                <div class="relative hidden md:block">
                    <div class="pointer-events-none absolute inset-0 rounded-full bg-[radial-gradient(circle,rgb(var(--color-secondary)/0.18),transparent_62%)] blur-3xl"></div>

                    <div class="pointer-events-none absolute left-1/2 top-1/2 h-64 w-64 -translate-x-1/2 -translate-y-1/2 rounded-full border border-[rgb(var(--color-secondary)/0.18)]"></div>

                    <img
                        src="/images/resources/resources-floating-documents.webp"
                        alt=""
                        width="900"
                        height="700"
                        loading="eager"
                        decoding="async"
                        class="resources-floating-image relative z-10 mx-auto w-full max-w-[32rem] object-contain drop-shadow-[0_34px_80px_rgb(5_162_236/0.24)]"
                    />

                    <div class="absolute right-6 top-8 z-20 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.82)] px-4 py-2 shadow-soft backdrop-blur">
                        <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-secondary))]">
                            Tax Resources
                        </span>
                    </div>

                    <div class="absolute bottom-8 left-4 z-20 rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.82)] px-4 py-2 shadow-soft backdrop-blur">
                        <span class="font-inter text-xs font-extrabold uppercase tracking-[0.12em] text-[rgb(var(--color-heading))]">
                            FAQ · Bilingual Support
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Resource Cards -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-1/2 top-0 h-px w-[min(92%,1180px)] -translate-x-1/2 bg-[linear-gradient(90deg,transparent,rgb(var(--color-secondary)/0.55),transparent)]"></div>

            <div class="absolute left-[-14rem] top-24 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-10 h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.1)] blur-3xl"></div>
        </div>

        <div class="container-wide">
            <SectionHeading
                eyebrow="Resource Center"
                title="Find the guidance you need before contacting the office."
                highlight="guidance you need"
                description="These pages help clients understand common tax preparation, bookkeeping, payroll, and accounting questions before taking the next step."
            />

            <div class="mt-12 grid gap-5 md:grid-cols-3">
                {
                    resources.map((resource) => {
                        const Icon = resource.icon;

                        return (
                            <article class="group glow-card card-hover relative overflow-hidden p-6">
                                <div class="pointer-events-none absolute right-[-4rem] top-[-4rem] h-40 w-40 rounded-full bg-[rgb(var(--color-secondary)/0.1)] blur-2xl opacity-0 transition duration-300 group-hover:opacity-100"></div>

                                <div class="pointer-events-none absolute bottom-4 right-5 text-[rgb(var(--color-primary)/0.045)] transition group-hover:text-[rgb(var(--color-secondary)/0.075)] dark:text-white/5">
                                    <Icon class="h-24 w-24" />
                                </div>

                                <div class="relative z-10 flex h-full flex-col">
                                    <div class="flex items-start justify-between gap-4">
                                        <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                            <Icon class="h-7 w-7" />
                                        </span>

                                        <a
                                            href={resource.href}
                                            aria-label={`View ${resource.title}`}
                                            class="flex h-10 w-10 items-center justify-center rounded-full border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.72)] text-[rgb(var(--color-heading))] transition duration-300 group-hover:-translate-y-1 group-hover:translate-x-1 group-hover:border-[rgb(var(--color-secondary)/0.45)] group-hover:bg-[rgb(var(--color-secondary))] group-hover:text-white dark:group-hover:text-[rgb(3_11_29)]"
                                        >
                                            <ArrowUpRight class="h-4.5 w-4.5" />
                                        </a>
                                    </div>

                                    <Badge variant="soft" size="sm" class="mt-7">
                                        {resource.eyebrow}
                                    </Badge>

                                    <h2 class="mt-4 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                        {resource.title}
                                    </h2>

                                    <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                        {resource.description}
                                    </p>

                                    <div class="mt-6 grid gap-3">
                                        {
                                            resource.features.map((feature) => (
                                                <div class="flex items-start gap-3">
                                                    <CheckCircle2 class="mt-0.5 h-4.5 w-4.5 shrink-0 text-[rgb(var(--color-secondary))]" />
                                                    <span class="text-sm font-bold leading-6 text-[rgb(var(--color-text))]">
                                                        {feature}
                                                    </span>
                                                </div>
                                            ))
                                        }
                                    </div>

                                    <div class="mt-auto pt-7">
                                        <a
                                            href={resource.href}
                                            class="group/link inline-flex items-center gap-2 font-inter text-sm font-extrabold text-[rgb(var(--color-secondary))]"
                                        >
                                            View resource
                                            <ArrowUpRight class="h-4 w-4 transition group-hover/link:translate-x-0.5 group-hover/link:-translate-y-0.5" />
                                        </a>
                                    </div>
                                </div>
                            </article>
                        );
                    })
                }
            </div>
        </div>
    </section>

    <!-- Helpful Topics -->
    <section class="section-shell relative overflow-hidden">
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute left-[-12rem] top-20 h-[28rem] w-[28rem] rounded-full bg-[rgb(var(--color-secondary)/0.09)] blur-3xl"></div>

            <div class="absolute right-[-12rem] bottom-10 h-[30rem] w-[30rem] rounded-full bg-[rgb(var(--color-primary)/0.09)] blur-3xl"></div>
        </div>

        <div class="container-wide">
            <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
                <SectionHeading
                    eyebrow="Helpful Guidance"
                    title="Simple reminders that can make accounting feel easier."
                    highlight="accounting feel easier"
                    description="Good preparation starts before tax season. These reminders can help individuals and businesses stay more organized throughout the year."
                />

                <div class="grid gap-5 md:grid-cols-2">
                    {
                        helpfulTopics.map((topic, index) => {
                            const Icon = topic.icon;

                            return (
                                <article
                                    class:list={[
                                        "group glow-card card-hover p-6",
                                        index === 2 ? "md:col-span-2" : "",
                                    ]}
                                >
                                    <div class="relative z-10">
                                        <span class="flex h-14 w-14 items-center justify-center rounded-[1.25rem] bg-[rgb(var(--color-secondary)/0.1)] text-[rgb(var(--color-secondary))] transition duration-300 group-hover:scale-105 group-hover:bg-[rgb(var(--color-secondary)/0.16)]">
                                            <Icon class="h-7 w-7" />
                                        </span>

                                        <h3 class="mt-5 font-inter text-2xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))]">
                                            {topic.title}
                                        </h3>

                                        <p class="mt-3 text-sm leading-7 text-[rgb(var(--color-text-soft))]">
                                            {topic.description}
                                        </p>
                                    </div>
                                </article>
                            );
                        })
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Bilingual Support Highlight -->
    <section class="section-shell relative overflow-hidden bg-[rgb(var(--color-bg-soft)/0.5)]">
        <div class="container-wide">
            <div class="relative overflow-hidden rounded-[2.5rem] border border-[rgb(var(--color-border)/0.72)] bg-[linear-gradient(135deg,rgb(var(--color-primary))_0%,rgb(var(--color-secondary))_100%)] p-6 text-white shadow-blue sm:p-8 lg:p-10">
                <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_0%,rgba(255,255,255,0.3),transparent_34%),radial-gradient(circle_at_92%_100%,rgba(255,255,255,0.16),transparent_34%)]"></div>

                <div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
                    <div>
                        <Badge
                            variant="outline"
                            class="border-white/25 bg-white/10 !text-white"
                            icon={Languages}
                        >
                            English & Spanish Support
                        </Badge>

                        <h2 class="mt-5 max-w-4xl font-inter text-3xl font-extrabold tracking-[-0.055em] !text-white md:text-4xl">
                            Clear communication matters when handling taxes, books, and payroll.
                        </h2>

                        <p class="mt-4 max-w-3xl text-sm leading-7 !text-white/78 md:text-base">
                            East Coast Accounting & Tax Services supports Miami clients in English and Spanish, helping individuals and businesses feel more comfortable asking questions and understanding their next steps.
                        </p>
                    </div>

                    <div class="grid gap-3 sm:grid-cols-3 lg:w-[28rem]">
                        {
                            [
                                "English",
                                "Spanish",
                                "Miami support",
                            ].map((item) => (
                                <div class="rounded-2xl border border-white/15 bg-white/10 p-4 text-center backdrop-blur">
                                    <CheckCircle2 class="mx-auto h-5 w-5 text-white" />
                                    <p class="mt-3 font-inter text-sm font-extrabold !text-white">
                                        {item}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="section-shell relative isolate overflow-hidden">
        <div class="container-wide">
            <div class="relative overflow-hidden rounded-[2.5rem] border border-[rgb(var(--color-border)/0.72)] bg-[rgb(var(--color-surface)/0.74)] p-6 shadow-card backdrop-blur sm:p-8 lg:p-10">
                <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_0%,rgb(var(--color-secondary)/0.12),transparent_34rem)]"></div>

                <div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
                    <div>
                        <Badge variant="blue" icon={MessageSquareText}>
                            Need More Help?
                        </Badge>

                        <h2 class="mt-5 max-w-4xl font-inter text-3xl font-extrabold tracking-[-0.055em] text-[rgb(var(--color-heading))] md:text-4xl">
                            Have a question about taxes, bookkeeping, payroll, or accounting?
                        </h2>

                        <p class="mt-4 max-w-3xl text-sm leading-7 text-[rgb(var(--color-text-soft))] md:text-base">
                            Send a message to East Coast Accounting & Tax Services and tell us what type of support you need. Our Miami office will guide you toward the right next step.
                        </p>
                    </div>

                    <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
                        <CTAButton href="/contact" icon={Send}>
                            Contact Our Office
                        </CTAButton>

                        <CTAButton href="/resources/faq" variant="secondary" icon={ArrowUpRight}>
                            View FAQ
                        </CTAButton>
                    </div>
                </div>
            </div>
        </div>
    </section>
</MainLayout>

<style>
    .resources-kenburns-bg {
        inset: 0;
        width: 100%;
        height: 100%;
        opacity: 0.26;
        transform: scale(1.08);
        transform-origin: center center;
        animation: resources-kenburns 18s ease-in-out infinite alternate;
    }

    .resources-kenburns-bg img {
        object-fit: cover;
        object-position: center center;
    }

    :root[data-theme="dark"] .resources-kenburns-bg {
        opacity: 0.17;
    }

    @keyframes resources-kenburns {
        0% {
            transform: scale(1.08) translate3d(0, 0, 0);
        }

        100% {
            transform: scale(1.18) translate3d(-1.5%, -1.2%, 0);
        }
    }

    @keyframes resources-float {
        0%,
        100% {
            transform: translateY(0) rotate(1deg) scale(1);
        }

        50% {
            transform: translateY(-14px) rotate(-1deg) scale(1.02);
        }
    }

    .resources-floating-image {
        animation: resources-float 7.4s ease-in-out infinite;
    }

    @media (max-width: 1023px) {
        .resources-kenburns-bg img {
            object-position: center top;
        }
    }

    @media (max-width: 767px) {
        .resources-kenburns-bg {
            transform: scale(1.12);
        }

        .resources-kenburns-bg img {
            object-position: center center;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .resources-kenburns-bg,
        .resources-floating-image {
            animation: none;
        }

        .resources-kenburns-bg {
            transform: scale(1.1);
        }
    }
</style>